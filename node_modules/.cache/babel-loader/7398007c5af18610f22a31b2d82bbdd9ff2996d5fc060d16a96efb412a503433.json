{"ast":null,"code":"export default {\n  name: 'SiteFooter',\n  data() {\n    return {\n      currentYear: new Date().getFullYear()\n    };\n  }\n};","map":{"version":3,"names":["name","data","currentYear","Date","getFullYear"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/SiteFooter.vue"],"sourcesContent":["<template>\n  <footer class=\"footer\">\n    <div class=\"footer-content\">\n      \n      <div class=\"footer-logo\">\n        <router-link to=\"/\" class=\"logo-link\">\n          <span class=\"logo-text\">Amine<span class=\"logo-dot\">.</span></span>\n        </router-link>\n      </div>\n      \n      <div class=\"copyright\">\n        <span class=\"copyright-year\">&copy; {{ currentYear }} Amine Itji.</span>\n        <span class=\"copyright-rights\">Tous droits réservés.</span>\n      </div>\n      \n      <div class=\"social-links\">\n        <a href=\"https://github.com/amineitji\" target=\"_blank\" class=\"social-link\" aria-label=\"GitHub\">\n          <i class=\"bi bi-github\"></i>\n        </a>\n        <a href=\"https://fr.linkedin.com/in/amine-itji-5a8696268\" target=\"_blank\" class=\"social-link\" aria-label=\"LinkedIn\">\n          <i class=\"bi bi-linkedin\"></i>\n        </a>\n        <a href=\"mailto:amineitji@gmail.com\" class=\"social-link\" aria-label=\"Email\">\n          <i class=\"bi bi-envelope-fill\"></i>\n        </a>\n      </div>\n      \n    </div>\n  </footer>\n</template>\n\n<script>\nexport default {\n  name: 'SiteFooter',\n  data() {\n    return {\n      currentYear: new Date().getFullYear(),\n    };\n  },\n};\n</script>\n\n<style scoped>\n/* Variables Premium Tech */\n:root {\n  --footer-bg: rgba(3, 7, 18, 0.4); /* Fond très transparent */\n  --border-color: rgba(255, 255, 255, 0.08);\n  --text-primary: #f9fafb;\n  --text-secondary: #9ca3af;\n  --text-muted: #6b7280;\n  --primary-blue: #3b82f6;\n  --transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n/* Base Footer Styles */\n.footer {\n  position: relative; /* On enlève le fixed pour un scroll naturel */\n  width: 100%;\n  background-color: var(--footer-bg);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  border-top: 1px solid var(--border-color);\n  z-index: 100;\n  margin-top: auto; /* Pousse le footer tout en bas si le contenu est court */\n}\n\n.footer-content {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 32px 40px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  flex-wrap: wrap;\n  gap: 20px;\n}\n\n/* Footer Logo */\n.logo-link {\n  text-decoration: none;\n}\n\n.logo-text {\n  color: var(--text-primary);\n  font-weight: 700;\n  font-size: 1.2rem;\n  letter-spacing: -0.03em;\n  font-family: 'Inter', sans-serif;\n  opacity: 0.8;\n  transition: var(--transition);\n}\n\n.logo-link:hover .logo-text {\n  opacity: 1;\n}\n\n.logo-dot {\n  color: var(--primary-blue);\n  font-size: 1.5rem;\n  line-height: 0;\n  position: relative;\n  top: 1px;\n}\n\n/* Copyright Styles */\n.copyright {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  color: var(--text-secondary);\n  font-size: 0.9rem;\n  font-weight: 400;\n}\n\n.copyright-rights {\n  color: var(--text-muted);\n}\n\n/* Social Links */\n.social-links {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n}\n\n.social-link {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--text-secondary);\n  font-size: 1.2rem;\n  transition: var(--transition);\n  text-decoration: none;\n}\n\n.social-link:hover {\n  color: var(--text-primary);\n  transform: translateY(-3px);\n  text-shadow: 0 0 15px rgba(255, 255, 255, 0.3);\n}\n\n/* Responsive Adjustments */\n@media (max-width: 768px) {\n  .footer-content {\n    flex-direction: column;\n    text-align: center;\n    padding: 32px 24px;\n    gap: 24px;\n  }\n  \n  .copyright {\n    flex-direction: column;\n    gap: 4px;\n    order: 3; /* Place le copyright tout en bas sur mobile */\n  }\n\n  .social-links {\n    order: 2; /* Place les réseaux sociaux au milieu sur mobile */\n  }\n}\n</style>"],"mappings":"AAgCA,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,WAAW,CAAC;IACtC,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}