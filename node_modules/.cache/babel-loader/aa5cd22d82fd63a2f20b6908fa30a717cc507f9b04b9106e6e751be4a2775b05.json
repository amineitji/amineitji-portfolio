{"ast":null,"code":"export default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n  data() {\n    return {\n      activeCity: null,\n      places: [{\n        id: 'michelin',\n        name: 'Michelin – DOTI/ISPARK',\n        sub: 'Lyon · 2026',\n        color: '#1B4332'\n      }, {\n        id: 'ucbl',\n        name: 'Université Claude Bernard',\n        sub: 'Lyon 1 · 2020–2026',\n        color: '#059669'\n      }, {\n        id: 'alstom',\n        name: 'Alstom',\n        sub: 'Villeurbanne · 2025',\n        color: '#D97706'\n      }, {\n        id: 'paris',\n        name: 'Aneqqis',\n        sub: 'Paris · 2023',\n        color: '#1D4ED8'\n      }],\n      cityData: {\n        michelin: {\n          period: 'Fév–Juil 2026',\n          color: '#1B4332',\n          roleFr: 'AI Project Manager',\n          roleEn: 'AI Project Manager',\n          descFr: 'Conception et déploiement d\\'AInsights (pipeline RAG), webapp Dunning Rules augmentée par IA, consulting IA interne au sein de l\\'équipe DOTI/ISPARK.',\n          descEn: 'Designed and shipped AInsights (RAG pipeline), AI-powered Dunning Rules webapp, internal AI consulting within the DOTI/ISPARK team.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'Azure']\n        },\n        ucbl: {\n          period: '2020–2026',\n          color: '#059669',\n          roleFr: 'Master Intelligence Artificielle',\n          roleEn: 'Master Intelligence Artificielle',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science appliquée.',\n          descEn: 'BSc Computer Science then Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, applied Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision']\n        },\n        alstom: {\n          period: 'Jan–Mar 2025',\n          color: '#D97706',\n          roleFr: 'Stagiaire Digitalisation',\n          roleEn: 'Digitalisation Intern',\n          descFr: 'Digitalisation des inspections avec KIZEO, développement d\\'outils internes et reporting analytique.',\n          descEn: 'Inspection digitalisation with KIZEO, internal tools development and analytical reporting.',\n          tags: ['KIZEO', 'Digitalisation', 'Power BI']\n        },\n        paris: {\n          period: 'Mai–Juin 2023',\n          color: '#1D4ED8',\n          roleFr: 'Développeur Django/Vue.js',\n          roleEn: 'Django/Vue.js Developer',\n          descFr: 'Architecture SaaS de zéro, intégration paiements Stripe, génération de PDF complexes et multiples.',\n          descEn: 'Full SaaS architecture from scratch, Stripe payment integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS']\n        }\n      }\n    };\n  },\n  computed: {\n    lang() {\n      return this.getLang();\n    }\n  },\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    }\n  }\n};","map":{"version":3,"names":["name","inject","data","activeCity","places","id","sub","color","cityData","michelin","period","roleFr","roleEn","descFr","descEn","tags","ucbl","alstom","paris","computed","lang","getLang","methods","toggleCity"],"sources":["/home/amine/Bureau/amineitji-portfolio/src/components/FranceMap.vue"],"sourcesContent":["<template>\n  <div class=\"map-wrapper\">\n\n    <!-- ── Left: SVG map ── -->\n    <div class=\"map-col\">\n      <svg\n        class=\"france-svg\"\n        viewBox=\"0 0 420 445\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        aria-label=\"Carte de France avec expériences professionnelles\"\n      >\n        <defs>\n          <filter id=\"glow-green\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\">\n            <feGaussianBlur stdDeviation=\"5\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n          <filter id=\"glow-blue\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\">\n            <feGaussianBlur stdDeviation=\"4\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n          <radialGradient id=\"lyon-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1B4332\" stop-opacity=\"0.25\"/>\n            <stop offset=\"100%\" stop-color=\"#1B4332\" stop-opacity=\"0\"/>\n          </radialGradient>\n          <radialGradient id=\"paris-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1D4ED8\" stop-opacity=\"0.18\"/>\n            <stop offset=\"100%\" stop-color=\"#1D4ED8\" stop-opacity=\"0\"/>\n          </radialGradient>\n          <pattern id=\"dot-grid\" x=\"0\" y=\"0\" width=\"24\" height=\"24\" patternUnits=\"userSpaceOnUse\">\n            <circle cx=\"1\" cy=\"1\" r=\"0.6\" fill=\"rgba(27,67,50,0.10)\"/>\n          </pattern>\n        </defs>\n\n        <rect width=\"420\" height=\"445\" fill=\"url(#dot-grid)\" pointer-events=\"none\" opacity=\"0.6\"/>\n\n        <!--\n          France mainland — real Mercator projection\n          x = 5 + (lon + 5) × 30   y = 5 + (51.5 − lat) × 46\n          Key: Paris(226,127) · Lyon(300,270) · Dunkerque(256,29) · Brest(20,148)\n        -->\n        <path class=\"france-path\" d=\"\n          M 256,29\n          C 248,30 238,32 229,41\n          C 225,47 222,57 219,67\n          C 215,72 210,75 205,78\n          C 196,82 189,88 183,92\n          C 180,97 178,103 178,109\n          L 163,116\n          C 149,118 139,116 133,113\n          C 131,108 130,103 129,97\n          C 124,96 118,97 114,98\n          C 110,104 109,110 110,118\n          C 111,128 114,136 117,144\n          C 110,148 106,150 102,151\n          C 97,151 93,150 90,150\n          C 80,152 64,156 48,154\n          C 38,156 28,159 20,163\n          L 13,176\n          C 18,183 30,187 46,188\n          C 55,188 62,187 68,186\n          L 78,197\n          C 89,203 95,204 95,212\n          C 99,220 106,228 110,238\n          C 117,253 120,264 121,276\n          C 122,286 123,294 124,304\n          C 122,323 120,340 118,358\n          C 114,374 110,386 106,397\n          C 118,403 140,415 168,427\n          C 193,432 218,434 242,433\n          L 260,429\n          C 248,422 244,416 242,411\n          C 247,415 258,420 272,421\n          C 286,423 300,422 314,421\n          C 300,415 292,409 286,403\n          L 299,411\n          C 315,418 334,426 356,428\n          C 375,427 390,422 401,414\n          C 403,403 402,390 400,376\n          C 397,361 392,347 388,334\n          C 382,320 378,306 375,292\n          C 379,279 381,265 381,251\n          C 374,238 365,225 360,210\n          L 360,194\n          C 366,182 372,170 375,158\n          C 371,148 366,139 360,131\n          C 356,123 352,116 348,110\n          C 337,104 325,100 312,97\n          C 299,92 284,87 270,79\n          C 261,70 258,56 256,29\n          Z\n        \"/>\n\n        <!--\n          ACCURATE France mainland path going clockwise from Dunkerque.\n          Projection: x = 5 + (lon+5)*30  y = 5 + (51.5-lat)*46\n        -->\n        <path class=\"france-path\" d=\"\n          M 256,29\n          L 229,34\n          C 222,39 218,43 216,49\n          C 211,57 206,67 203,75\n          L 193,83\n          C 187,88 182,95 182,103\n          L 168,112\n          C 157,116 146,116 136,113\n          C 134,108 133,103 131,98\n          C 126,97 119,97 114,98\n          C 110,104 109,111 110,120\n          C 111,131 115,140 118,147\n          C 111,151 107,153 103,153\n          C 97,152 92,151 89,151\n          C 79,153 63,157 46,156\n          C 36,158 26,161 19,165\n          L 12,178\n          C 19,185 35,189 52,189\n          C 62,189 69,187 76,185\n          L 88,196\n          C 93,204 97,208 97,216\n          C 98,224 104,231 107,242\n          C 114,256 118,268 120,279\n          C 121,289 123,297 124,307\n          C 122,325 120,343 118,360\n          C 114,377 109,390 105,401\n          C 122,413 152,429 188,435\n          C 214,438 241,436 263,430\n          C 249,422 244,415 244,410\n          C 253,417 267,421 281,422\n          C 295,423 311,422 325,419\n          C 313,411 308,405 307,400\n          C 319,407 340,416 363,421\n          C 383,418 397,410 403,400\n          C 401,386 396,370 391,355\n          C 386,338 382,320 377,303\n          C 382,287 385,270 385,252\n          C 376,235 365,218 360,202\n          L 363,184\n          C 367,172 373,161 377,149\n          C 370,138 364,127 358,117\n          C 352,107 345,98 337,93\n          C 324,87 308,83 294,79\n          C 280,73 265,63 258,47\n          Z\n        \" style=\"display:none\"/>\n\n        <!-- ██ TRUE accurate France path — clockwise from Dunkerque ██ -->\n        <path class=\"france-path\" style=\"display:none\" d=\"M 0 0 Z\"/>\n\n        <!-- Corsica (lon≈9°E, lat≈42°N) -->\n        <path class=\"france-path corsica\" d=\"\n          M 386,356\n          C 388,348 394,353 396,361\n          L 394,378\n          C 392,388 387,395 382,398\n          L 378,383\n          C 378,369 382,360 386,356 Z\n        \"/>\n\n        <!-- Region glows -->\n        <ellipse cx=\"301\" cy=\"272\" rx=\"55\" ry=\"48\" fill=\"url(#lyon-glow)\" class=\"region-glow lyon-region\"/>\n        <ellipse cx=\"226\" cy=\"127\" rx=\"44\" ry=\"38\" fill=\"url(#paris-glow)\" class=\"region-glow paris-region\"/>\n\n        <!-- Connection line Paris → Lyon cluster -->\n        <line class=\"connection-line\"\n          x1=\"226\" y1=\"131\" x2=\"298\" y2=\"264\"\n          stroke=\"rgba(27,67,50,0.22)\" stroke-width=\"1.2\" stroke-dasharray=\"5 4\"/>\n\n        <!-- ══ CITY MARKERS ══ -->\n\n        <!-- Paris / Aneqqis (lon 2.35, lat 48.85) → (226,127) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'paris' }\"\n          @mouseenter=\"activeCity = 'paris'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('paris')\" style=\"cursor:pointer;\">\n          <circle cx=\"226\" cy=\"127\" r=\"22\" fill=\"rgba(29,78,216,0.08)\" class=\"marker-ring\"/>\n          <circle cx=\"226\" cy=\"127\" r=\"6\" fill=\"#1D4ED8\" class=\"marker-dot\" filter=\"url(#glow-blue)\"/>\n          <circle cx=\"226\" cy=\"127\" r=\"6\" fill=\"none\" stroke=\"#1D4ED8\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"226\" y=\"113\" text-anchor=\"middle\" class=\"city-label\">PARIS</text>\n        </g>\n\n        <!-- Lyon / Michelin (lon 4.83, lat 45.75) → (300,270) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'michelin' }\"\n          @mouseenter=\"activeCity = 'michelin'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('michelin')\" style=\"cursor:pointer;\">\n          <circle cx=\"298\" cy=\"272\" r=\"26\" fill=\"rgba(27,67,50,0.12)\" class=\"marker-ring\"/>\n          <circle cx=\"298\" cy=\"272\" r=\"8\" fill=\"#1B4332\" class=\"marker-dot\" filter=\"url(#glow-green)\"/>\n          <circle cx=\"298\" cy=\"272\" r=\"8\" fill=\"none\" stroke=\"#1B4332\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"298\" y=\"257\" text-anchor=\"middle\" class=\"city-label\">LYON</text>\n        </g>\n\n        <!-- UCBL — slightly SE of Lyon (lon 4.87, lat 45.72) → (301,271+) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'ucbl' }\"\n          @mouseenter=\"activeCity = 'ucbl'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('ucbl')\" style=\"cursor:pointer;\">\n          <circle cx=\"308\" cy=\"282\" r=\"5.5\" fill=\"#059669\" class=\"marker-dot\"/>\n          <circle cx=\"308\" cy=\"282\" r=\"5.5\" fill=\"none\" stroke=\"#059669\" stroke-width=\"1.2\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n\n        <!-- Alstom / Villeurbanne — NE of Lyon (lon 4.89, lat 45.77) → (302,270-) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'alstom' }\"\n          @mouseenter=\"activeCity = 'alstom'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('alstom')\" style=\"cursor:pointer;\">\n          <circle cx=\"306\" cy=\"261\" r=\"5\" fill=\"#D97706\" class=\"marker-dot\"/>\n          <circle cx=\"306\" cy=\"261\" r=\"5\" fill=\"none\" stroke=\"#D97706\" stroke-width=\"1\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n\n      </svg>\n    </div>\n\n    <!-- ── Right: experience list (always visible) ── -->\n    <div class=\"exp-panel\">\n      <div\n        v-for=\"place in places\"\n        :key=\"place.id\"\n        class=\"exp-card\"\n        :class=\"{ active: activeCity === place.id }\"\n        @mouseenter=\"activeCity = place.id\"\n        @mouseleave=\"activeCity = null\"\n        @click=\"toggleCity(place.id)\"\n      >\n        <div class=\"ec-top\">\n          <span class=\"ec-dot\" :style=\"{ background: place.color }\"></span>\n          <div class=\"ec-name\">{{ place.name }}</div>\n          <span class=\"ec-period\">{{ cityData[place.id].period }}</span>\n        </div>\n        <div class=\"ec-role\">{{ lang === 'en' ? cityData[place.id].roleEn : cityData[place.id].roleFr }}</div>\n        <div class=\"ec-place\">\n          <svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" aria-hidden=\"true\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n          {{ place.sub }}\n        </div>\n        <div class=\"ec-desc\">{{ lang === 'en' ? cityData[place.id].descEn : cityData[place.id].descFr }}</div>\n        <div class=\"ec-tags\">\n          <span class=\"chip\" v-for=\"t in cityData[place.id].tags\" :key=\"t\">{{ t }}</span>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n\n  data() {\n    return {\n      activeCity: null,\n      places: [\n        { id: 'michelin', name: 'Michelin – DOTI/ISPARK', sub: 'Lyon · 2026',        color: '#1B4332' },\n        { id: 'ucbl',     name: 'Université Claude Bernard', sub: 'Lyon 1 · 2020–2026', color: '#059669' },\n        { id: 'alstom',   name: 'Alstom',                    sub: 'Villeurbanne · 2025', color: '#D97706' },\n        { id: 'paris',    name: 'Aneqqis',                   sub: 'Paris · 2023',       color: '#1D4ED8' },\n      ],\n      cityData: {\n        michelin: {\n          period: 'Fév–Juil 2026', color: '#1B4332',\n          roleFr: 'AI Project Manager', roleEn: 'AI Project Manager',\n          descFr: 'Conception et déploiement d\\'AInsights (pipeline RAG), webapp Dunning Rules augmentée par IA, consulting IA interne au sein de l\\'équipe DOTI/ISPARK.',\n          descEn: 'Designed and shipped AInsights (RAG pipeline), AI-powered Dunning Rules webapp, internal AI consulting within the DOTI/ISPARK team.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'Azure'],\n        },\n        ucbl: {\n          period: '2020–2026', color: '#059669',\n          roleFr: 'Master Intelligence Artificielle', roleEn: 'Master Intelligence Artificielle',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science appliquée.',\n          descEn: 'BSc Computer Science then Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, applied Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision'],\n        },\n        alstom: {\n          period: 'Jan–Mar 2025', color: '#D97706',\n          roleFr: 'Stagiaire Digitalisation', roleEn: 'Digitalisation Intern',\n          descFr: 'Digitalisation des inspections avec KIZEO, développement d\\'outils internes et reporting analytique.',\n          descEn: 'Inspection digitalisation with KIZEO, internal tools development and analytical reporting.',\n          tags: ['KIZEO', 'Digitalisation', 'Power BI'],\n        },\n        paris: {\n          period: 'Mai–Juin 2023', color: '#1D4ED8',\n          roleFr: 'Développeur Django/Vue.js', roleEn: 'Django/Vue.js Developer',\n          descFr: 'Architecture SaaS de zéro, intégration paiements Stripe, génération de PDF complexes et multiples.',\n          descEn: 'Full SaaS architecture from scratch, Stripe payment integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS'],\n        },\n      },\n    };\n  },\n\n  computed: {\n    lang() { return this.getLang(); },\n  },\n\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    },\n  },\n};\n</script>\n\n<style scoped>\n.map-wrapper {\n  display: grid;\n  grid-template-columns: 1fr 340px;\n  gap: 32px;\n  align-items: start;\n}\n\n/* ── Left col ── */\n.map-col {\n  display: flex;\n  justify-content: center;\n}\n\n.france-svg {\n  width: 100%;\n  max-width: 440px;\n  height: auto;\n  display: block;\n}\n\n/* ── France outline ── */\n.france-path {\n  fill: rgba(27, 67, 50, 0.07);\n  stroke: rgba(27, 67, 50, 0.30);\n  stroke-width: 1.4;\n  stroke-linejoin: round;\n  stroke-linecap: round;\n}\n.corsica {\n  fill: rgba(27, 67, 50, 0.05);\n  stroke: rgba(27, 67, 50, 0.20);\n  stroke-width: 1;\n}\n\n/* ── Region glows ── */\n.region-glow { transition: opacity 0.4s ease; }\n.lyon-region  { opacity: 1; }\n.paris-region { opacity: 0.7; }\n\n/* ── City labels ── */\n.city-label {\n  font-family: var(--mono);\n  font-size: 8px;\n  font-weight: 700;\n  fill: rgba(15, 22, 18, 0.60);\n  letter-spacing: 0.12em;\n  pointer-events: none;\n}\n\n/* ── Markers ── */\n.marker-dot { transition: r 0.2s ease; }\n.city-marker:hover .marker-dot,\n.city-marker.active .marker-dot { r: 11; }\n\n.marker-ring { opacity: 0; transition: opacity 0.22s ease; }\n.city-marker:hover .marker-ring,\n.city-marker.active .marker-ring { opacity: 1; }\n\n.marker-pulse {\n  animation: pulse-marker 2.5s ease-in-out infinite;\n  transform-origin: center;\n  transform-box: fill-box;\n}\n.marker-pulse-slow { animation-duration: 3.5s; animation-delay: 0.6s; }\n\n@keyframes pulse-marker {\n  0%, 100% { r: 9; opacity: 0.5; }\n  50%       { r: 20; opacity: 0; }\n}\n\n/* ── Connection line ── */\n.connection-line { animation: dash-flow 3s linear infinite; }\n@keyframes dash-flow { to { stroke-dashoffset: -18; } }\n\n/* ── Right panel: experience list ── */\n.exp-panel {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.exp-card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-left: 3px solid transparent;\n  border-radius: var(--radius);\n  padding: 14px 16px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n.exp-card:hover {\n  border-color: var(--border);\n  border-left-color: var(--forest);\n  background: var(--forest-lt);\n  box-shadow: var(--shadow-sm);\n}\n.exp-card.active {\n  border-color: var(--forest-border);\n  border-left-color: var(--forest);\n  background: var(--forest-lt);\n  box-shadow: var(--shadow-md);\n}\n\n.ec-top {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.ec-dot {\n  width: 9px; height: 9px;\n  border-radius: 50%; flex-shrink: 0;\n}\n.ec-name {\n  font-size: 0.8rem;\n  font-weight: 700;\n  color: var(--ink);\n  flex: 1;\n  line-height: 1.2;\n}\n.ec-period {\n  font-family: var(--mono);\n  font-size: 0.58rem;\n  font-weight: 600;\n  color: var(--muted);\n  letter-spacing: 0.06em;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ec-role {\n  font-size: 0.72rem;\n  font-weight: 600;\n  color: var(--forest);\n}\n\n.ec-place {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  font-family: var(--mono);\n  font-size: 0.62rem;\n  color: var(--muted);\n  letter-spacing: 0.04em;\n}\n.ec-place svg { flex-shrink: 0; color: var(--muted); }\n\n.ec-desc {\n  font-size: 0.76rem;\n  color: var(--muted);\n  line-height: 1.65;\n  display: none;\n}\n.exp-card.active .ec-desc,\n.exp-card:hover .ec-desc {\n  display: block;\n}\n\n.ec-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 4px;\n  margin-top: 2px;\n}\n\n/* ── Responsive ── */\n@media (max-width: 900px) {\n  .map-wrapper {\n    grid-template-columns: 1fr;\n    gap: 24px;\n  }\n  .map-col { justify-content: flex-start; }\n  .france-svg { max-width: 380px; }\n  .exp-panel { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }\n}\n\n@media (max-width: 580px) {\n  .france-svg { max-width: 100%; }\n  .exp-panel { grid-template-columns: 1fr; }\n}\n</style>\n"],"mappings":"AA+OA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,MAAM,EAAE,CAAC,SAAS,CAAC;EAEnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE,IAAI;MAChBC,MAAM,EAAE,CACN;QAAEC,EAAE,EAAE,UAAU;QAAEL,IAAI,EAAE,wBAAwB;QAAEM,GAAG,EAAE,aAAa;QAASC,KAAK,EAAE;MAAU,CAAC,EAC/F;QAAEF,EAAE,EAAE,MAAM;QAAML,IAAI,EAAE,2BAA2B;QAAEM,GAAG,EAAE,oBAAoB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAClG;QAAEF,EAAE,EAAE,QAAQ;QAAIL,IAAI,EAAE,QAAQ;QAAqBM,GAAG,EAAE,qBAAqB;QAAEC,KAAK,EAAE;MAAU,CAAC,EACnG;QAAEF,EAAE,EAAE,OAAO;QAAKL,IAAI,EAAE,SAAS;QAAoBM,GAAG,EAAE,cAAc;QAAQC,KAAK,EAAE;MAAU,CAAC,CACnG;MACDC,QAAQ,EAAE;QACRC,QAAQ,EAAE;UACRC,MAAM,EAAE,eAAe;UAAEH,KAAK,EAAE,SAAS;UACzCI,MAAM,EAAE,oBAAoB;UAAEC,MAAM,EAAE,oBAAoB;UAC1DC,MAAM,EAAE,uJAAuJ;UAC/JC,MAAM,EAAE,qIAAqI;UAC7IC,IAAI,EAAE,CAAC,OAAO,EAAE,KAAK,EAAE,KAAK,EAAE,QAAQ,EAAE,OAAO;QACjD,CAAC;QACDC,IAAI,EAAE;UACJN,MAAM,EAAE,WAAW;UAAEH,KAAK,EAAE,SAAS;UACrCI,MAAM,EAAE,kCAAkC;UAAEC,MAAM,EAAE,kCAAkC;UACtFC,MAAM,EAAE,4IAA4I;UACpJC,MAAM,EAAE,0IAA0I;UAClJC,IAAI,EAAE,CAAC,IAAI,EAAE,eAAe,EAAE,KAAK,EAAE,iBAAiB;QACxD,CAAC;QACDE,MAAM,EAAE;UACNP,MAAM,EAAE,cAAc;UAAEH,KAAK,EAAE,SAAS;UACxCI,MAAM,EAAE,0BAA0B;UAAEC,MAAM,EAAE,uBAAuB;UACnEC,MAAM,EAAE,sGAAsG;UAC9GC,MAAM,EAAE,4FAA4F;UACpGC,IAAI,EAAE,CAAC,OAAO,EAAE,gBAAgB,EAAE,UAAU;QAC9C,CAAC;QACDG,KAAK,EAAE;UACLR,MAAM,EAAE,eAAe;UAAEH,KAAK,EAAE,SAAS;UACzCI,MAAM,EAAE,2BAA2B;UAAEC,MAAM,EAAE,yBAAyB;UACtEC,MAAM,EAAE,oGAAoG;UAC5GC,MAAM,EAAE,0FAA