{"ast":null,"code":"import { resolveComponent as _resolveComponent, createVNode as _createVNode, resolveDynamicComponent as _resolveDynamicComponent, openBlock as _openBlock, createBlock as _createBlock, Transition as _Transition, withCtx as _withCtx, createElementVNode as _createElementVNode, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  id: \"app\",\n  class: \"app-container\"\n};\nconst _hoisted_2 = {\n  class: \"main-content\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  const _component_SiteHeader = _resolveComponent(\"SiteHeader\");\n  const _component_router_view = _resolveComponent(\"router-view\");\n  const _component_SiteFooter = _resolveComponent(\"SiteFooter\");\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createVNode(_component_SiteHeader), _createElementVNode(\"div\", _hoisted_2, [_createVNode(_component_router_view, null, {\n    default: _withCtx(({\n      Component\n    }) => [_createVNode(_Transition, {\n      name: \"page\",\n      mode: \"out-in\"\n    }, {\n      default: _withCtx(() => [(_openBlock(), _createBlock(_resolveDynamicComponent(Component)))]),\n      _: 2 /* DYNAMIC */\n    }, 1024 /* DYNAMIC_SLOTS */)]),\n    _: 1 /* STABLE */\n  })]), _createVNode(_component_SiteFooter)]);\n}","map":{"version":3,"names":["id","class","_createElementBlock","_hoisted_1","_createVNode","_component_SiteHeader","_createElementVNode","_hoisted_2","_component_router_view","default","_withCtx","Component","_Transition","name","mode","_createBlock","_resolveDynamicComponent","_","_component_SiteFooter"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"app-container\">\n    <SiteHeader />\n    <div class=\"main-content\">\n      <router-view v-slot=\"{ Component }\">\n        <transition name=\"page\" mode=\"out-in\">\n          <component :is=\"Component\" />\n        </transition>\n      </router-view>\n    </div>\n    <SiteFooter />\n  </div>\n</template>\n\n<script>\nimport SiteFooter from './components/SiteFooter.vue';\nimport SiteHeader from './components/SiteHeader.vue';\n\nexport default {\n  name: 'App',\n  components: {\n    SiteHeader,\n    SiteFooter,\n  },\n};\n</script>\n\n<style>\n/* ============================================================\n   DESIGN SYSTEM — Amine Itji Portfolio Premium\n   \"Ultra-Premium Minimaliste / Tech Visionary / Glassmorphism B2B\"\n   ============================================================ */\n\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n\n:root {\n  /* Couleurs de fond */\n  --color-bg:          #030712;\n  --color-bg-2:        #070d1a;\n\n  /* Cartes Glassmorphism */\n  --color-card:        rgba(17, 24, 39, 0.45);\n  --color-card-hover:  rgba(17, 24, 39, 0.65);\n  --color-border:      rgba(255, 255, 255, 0.07);\n  --color-border-hover:rgba(255, 255, 255, 0.16);\n\n  /* Accents */\n  --primary-blue:      #3b82f6;\n  --primary-purple:    #8b5cf6;\n  --primary-cyan:      #06b6d4;\n  --blue-glow:         rgba(59, 130, 246, 0.25);\n  --purple-glow:       rgba(139, 92, 246, 0.25);\n  --cyan-glow:         rgba(6, 182, 212, 0.25);\n\n  /* Typographie */\n  --text-main:         #f9fafb;\n  --text-secondary:    #d1d5db;\n  --text-muted:        #6b7280;\n\n  /* Transitions */\n  --ease-premium:      cubic-bezier(0.16, 1, 0.3, 1);\n  --transition-smooth: all 0.4s var(--ease-premium);\n  --transition-fast:   all 0.2s ease;\n}\n\n/* Reset */\n*, *::before, *::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nbody {\n  font-family: 'Inter', system-ui, -apple-system, sans-serif;\n  line-height: 1.6;\n  overflow-x: hidden;\n  background: var(--color-bg);\n  color: var(--text-main);\n}\n\n/* Scrollbar Premium */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: var(--color-bg); }\n::-webkit-scrollbar-thumb {\n  background: rgba(139, 92, 246, 0.3);\n  border-radius: 3px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(139, 92, 246, 0.6);\n}\n\n/* ============================================================\n   APP LAYOUT\n   ============================================================ */\n#app {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: var(--color-bg);\n  position: relative;\n}\n\n.main-content {\n  flex: 1;\n  padding: 0 5%;\n  padding-bottom: 100px;\n  min-height: calc(100vh - 80px);\n  position: relative;\n  width: 100%;\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n/* ============================================================\n   PAGE TRANSITIONS\n   ============================================================ */\n.page-enter-active,\n.page-leave-active {\n  transition: opacity 0.4s var(--ease-premium), transform 0.4s var(--ease-premium);\n}\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(24px);\n}\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-16px);\n}\n\n/* ============================================================\n   SHARED BACKGROUND ELEMENTS\n   ============================================================ */\n.bg-grid {\n  position: fixed;\n  inset: 0;\n  background-image:\n    linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);\n  background-size: 48px 48px;\n  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, transparent 80%);\n  -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, transparent 80%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n.blob {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(130px);\n  opacity: 0.35;\n  z-index: 0;\n  pointer-events: none;\n  animation: blobFloat 22s ease-in-out infinite alternate;\n}\n\n.blob-blue {\n  background: var(--primary-blue);\n  width: 700px; height: 700px;\n  top: -15%; left: -12%;\n  animation-duration: 24s;\n}\n\n.blob-purple {\n  background: var(--primary-purple);\n  width: 550px; height: 550px;\n  bottom: 15%; right: -10%;\n  animation-duration: 18s;\n  animation-delay: -8s;\n}\n\n.blob-cyan {\n  background: var(--primary-cyan);\n  width: 400px; height: 400px;\n  top: 50%; left: 60%;\n  animation-duration: 20s;\n  animation-delay: -4s;\n  opacity: 0.2;\n}\n\n@keyframes blobFloat {\n  0%   { transform: translate(0, 0) scale(1); }\n  33%  { transform: translate(40px, -30px) scale(1.05); }\n  66%  { transform: translate(-20px, 40px) scale(0.97); }\n  100% { transform: translate(20px, -10px) scale(1.02); }\n}\n\n/* ============================================================\n   GLOBAL GLASS CARD SYSTEM\n   ============================================================ */\n.glass-card {\n  background: var(--color-card);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border: 1px solid var(--color-border);\n  border-radius: 24px;\n  transition: var(--transition-smooth);\n}\n\n.glass-card:hover {\n  background: var(--color-card-hover);\n  border-color: var(--color-border-hover);\n  box-shadow: 0 24px 48px rgba(0, 0, 0, 0.45);\n}\n\n/* ============================================================\n   GLOBAL BUTTON SYSTEM\n   ============================================================ */\n.btn-glow {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 28px;\n  background: linear-gradient(135deg, var(--primary-blue), var(--primary-purple));\n  color: white;\n  text-decoration: none;\n  border-radius: 100px;\n  font-weight: 600;\n  font-size: 0.95rem;\n  letter-spacing: 0.01em;\n  border: none;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n  transition: var(--transition-smooth);\n  box-shadow: 0 0 0 0 var(--blue-glow);\n}\n\n.btn-glow::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.btn-glow:hover {\n  transform: translateY(-3px);\n  box-shadow: 0 12px 35px var(--blue-glow), 0 0 0 1px rgba(59,130,246,0.3);\n}\n\n.btn-glow:hover::before {\n  opacity: 1;\n}\n\n.btn-glow.large {\n  padding: 16px 36px;\n  font-size: 1.05rem;\n}\n\n.btn-outline {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 28px;\n  background: transparent;\n  color: var(--text-main);\n  text-decoration: none;\n  border-radius: 100px;\n  font-weight: 500;\n  font-size: 0.95rem;\n  border: 1px solid var(--color-border-hover);\n  cursor: pointer;\n  transition: var(--transition-smooth);\n}\n\n.btn-outline:hover {\n  background: rgba(255,255,255,0.06);\n  border-color: rgba(255,255,255,0.25);\n  transform: translateY(-2px);\n}\n\n/* ============================================================\n   GLOBAL SECTION HEADINGS\n   ============================================================ */\n.section-heading {\n  margin-bottom: 56px;\n}\n\n.section-label {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 0.75rem;\n  font-weight: 600;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: var(--primary-cyan);\n  margin-bottom: 16px;\n  padding: 6px 14px;\n  background: rgba(6,182,212,0.08);\n  border: 1px solid rgba(6,182,212,0.2);\n  border-radius: 100px;\n}\n\n.section-heading h2 {\n  font-size: clamp(2rem, 3.5vw, 2.8rem);\n  font-weight: 700;\n  letter-spacing: -0.03em;\n  line-height: 1.15;\n  color: var(--text-main);\n  margin-bottom: 16px;\n}\n\n.section-heading p {\n  color: var(--text-muted);\n  font-size: 1.1rem;\n  max-width: 560px;\n  line-height: 1.7;\n}\n\n/* ============================================================\n   FADE-IN ANIMATIONS\n   ============================================================ */\n.fade-in-up {\n  opacity: 0;\n  transform: translateY(32px);\n  animation: fadeInUp 0.9s var(--ease-premium) forwards;\n}\n\n@keyframes fadeInUp {\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n/* ============================================================\n   TECH TAGS / BADGES\n   ============================================================ */\n.tech-chip {\n  display: inline-flex;\n  align-items: center;\n  font-size: 0.75rem;\n  font-weight: 500;\n  padding: 4px 10px;\n  border-radius: 100px;\n  background: rgba(255,255,255,0.05);\n  border: 1px solid var(--color-border);\n  color: var(--text-secondary);\n  white-space: nowrap;\n  transition: var(--transition-fast);\n}\n\n.tech-chip:hover {\n  background: rgba(59,130,246,0.1);\n  border-color: rgba(59,130,246,0.3);\n  color: #93c5fd;\n}\n\n.status-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 7px 14px;\n  background: rgba(6, 182, 212, 0.08);\n  border: 1px solid rgba(6, 182, 212, 0.2);\n  border-radius: 100px;\n  font-size: 0.8rem;\n  font-weight: 500;\n  color: #67e8f9;\n  letter-spacing: 0.02em;\n}\n\n.pulse-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--primary-cyan);\n  box-shadow: 0 0 8px var(--primary-cyan);\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; transform: scale(1); }\n  50% { opacity: 0.6; transform: scale(0.85); }\n}\n\n/* ============================================================\n   RESPONSIVE\n   ============================================================ */\n@media (max-width: 1024px) {\n  .main-content {\n    padding: 0 4%;\n    padding-bottom: 80px;\n  }\n}\n\n@media (max-width: 768px) {\n  .main-content {\n    padding: 0 16px;\n    padding-bottom: 60px;\n  }\n  .blob { display: none; }\n}\n</style>"],"mappings":";;EACOA,EAAE,EAAC,KAAK;EAACC,KAAK,EAAC;;;EAEbA,KAAK,EAAC;AAAc;;;;;uBAF3BC,mBAAA,CAUM,OAVNC,UAUM,GATJC,YAAA,CAAcC,qBAAA,GACdC,mBAAA,CAMM,OANNC,UAMM,GALJH,YAAA,CAIcI,sBAAA;IARpBC,OAAA,EAAAC,QAAA,CAKQ,CAEa;MAHQC;IAAS,OAC9BP,YAAA,CAEaQ,WAAA;MAFDC,IAAI,EAAC,MAAM;MAACC,IAAI,EAAC;;MALrCL,OAAA,EAAAC,QAAA,CAMU,MAA6B,E,cAA7BK,YAAA,CAA6BC,wBANvC,CAM0BL,SAAS,I;MANnCM,CAAA;;IAAAA,CAAA;QAUIb,YAAA,CAAcc,qBAAA,E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}