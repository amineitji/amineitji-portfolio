{"ast":null,"code":"export default {\n  name: 'HomePage'\n};","map":{"version":3,"names":["name"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/HomePage.vue"],"sourcesContent":["<template>\n  <div class=\"premium-layout\">\n    <div class=\"ambient-glow\"></div>\n\n    <header class=\"hero\">\n      <div class=\"hero-container\">\n        <div class=\"hero-content fade-in-up\">\n          <div class=\"status-pill\">\n            <span class=\"dot\"></span>\n            Disponibilité Freelance : Ouverte\n          </div>\n          \n          <h1 class=\"hero-title\">\n            Devenez le leader de votre secteur grâce à \n            <span class=\"gradient-text\">l'IA & au Web.</span>\n          </h1>\n          \n          <p class=\"hero-description\">\n            Je suis <strong>Amine Itji</strong>. La semaine, je pilote des projets d'intelligence artificielle en tant qu'<strong>AI Project Manager chez Michelin</strong>. \n            En parallèle, j'accompagne mes clients en tant que <strong>Freelance</strong> pour concevoir des applications web sur-mesure et intégrer l'IA dans leurs processus.\n          </p>\n\n          <div class=\"hero-cta\">\n            <a href=\"mailto:amineitji@gmail.com?subject=Nouveau Projet\" class=\"btn-primary\">\n              Me confier votre projet\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"icon\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>\n            </a>\n            <router-link to=\"/projets\" class=\"btn-secondary\">\n              Découvrir mon travail\n            </router-link>\n          </div>\n        </div>\n\n        <div class=\"hero-image fade-in-up\" style=\"animation-delay: 0.2s;\">\n          <div class=\"image-frame\">\n            <img src=\"pp.jpeg\" alt=\"Amine Itji\" />\n          </div>\n        </div>\n      </div>\n    </header>\n\n    <section class=\"logos-section fade-in-up\" style=\"animation-delay: 0.3s;\">\n      <p class=\"logos-title\">EXPERTISE FORGÉE AUPRÈS DE</p>\n      <div class=\"logos-grid\">\n        <div class=\"logo-item\">\n          <span class=\"text-xl\">🏭</span> Michelin <span class=\"tag\">AI Project Manager</span>\n        </div>\n        <div class=\"logo-item\">\n          <span class=\"text-xl\">🚀</span> DiagERP <span class=\"tag\">Co-fondateur & CTO</span>\n        </div>\n        <div class=\"logo-item\">\n          <span class=\"text-xl\">🎓</span> Univ. Lyon 1 <span class=\"tag\">Master 2 IA</span>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"bento-section fade-in-up\" style=\"animation-delay: 0.4s;\">\n      <div class=\"section-heading\">\n        <h2>Mes Services Indépendants</h2>\n        <p>Une exécution technique de haut niveau pour vos projets B2B ou B2C.</p>\n      </div>\n\n      <div class=\"bento-grid\">\n        <div class=\"bento-card col-span-1\">\n          <div class=\"bento-icon\">💻</div>\n          <h3>Développement SaaS & Web</h3>\n          <p>Création d'architectures robustes (Django / Vue.js), de l'API jusqu'au déploiement. Spécialiste des systèmes de facturation (Stripe) et plateformes B2B.</p>\n        </div>\n\n        <div class=\"bento-card col-span-2 highlight-card\">\n          <div class=\"bento-header-flex\">\n            <div class=\"bento-icon ai-glow\">🤖</div>\n            <span class=\"expert-badge\">Expertise Principale</span>\n          </div>\n          <h3>Intelligence Artificielle & Agents LLM</h3>\n          <p>L'IA n'est plus une option, c'est un avantage compétitif. J'intègre des modèles génératifs de pointe (GPT, Claude) à vos outils internes. Création d'agents autonomes, systèmes RAG sur vos données privées et optimisation de prompts (Prompt Engineering).</p>\n        </div>\n\n        <div class=\"bento-card col-span-full data-card\">\n          <div class=\"bento-content-row\">\n            <div class=\"bento-icon\">📊</div>\n            <div>\n              <h3>Extraction de Données & Scraping B2B</h3>\n              <p>Mise en place de robots d'extraction de données massives pour alimenter vos bases de données ou vos modèles d'IA. Contournement d'anti-bots et nettoyage de données.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"work-section fade-in-up\" style=\"animation-delay: 0.5s;\">\n      <div class=\"section-heading\">\n        <h2>Réalisations Sélectionnées</h2>\n      </div>\n\n      <div class=\"projects-grid\">\n        <a href=\"https://diagerp.fr\" target=\"_blank\" class=\"project-card\">\n          <div class=\"project-img-wrapper\">\n             <div class=\"img-placeholder bg-erp\"></div>\n             <div class=\"project-overlay\">Visiter le SaaS ↗</div>\n          </div>\n          <div class=\"project-info\">\n            <div class=\"project-meta\">SaaS B2B • Co-fondateur</div>\n            <h3>DiagERP</h3>\n            <p>Logiciel de gestion complet pour les diagnostiqueurs immobiliers en production.</p>\n          </div>\n        </a>\n\n        <a href=\"https://diagimmomarches.fr\" target=\"_blank\" class=\"project-card\">\n          <div class=\"project-img-wrapper\">\n             <div class=\"img-placeholder bg-client\"></div>\n             <div class=\"project-overlay\">Visiter le site ↗</div>\n          </div>\n          <div class=\"project-info\">\n            <div class=\"project-meta\">Web & SEO • Projet Client</div>\n            <h3>DiagImmoMarches</h3>\n            <p>Plateforme web haute performance génératrice de leads pour le marché immobilier.</p>\n          </div>\n        </a>\n      </div>\n    </section>\n\n    <section class=\"cta-section fade-in-up\" style=\"animation-delay: 0.6s;\">\n      <div class=\"cta-container\">\n        <h2>Un projet ambitieux ?</h2>\n        <p>Les meilleurs projets commencent par une simple discussion. Parlez-moi de votre vision.</p>\n        <a href=\"mailto:amineitji@gmail.com\" class=\"btn-primary btn-large\">\n          Démarrer une conversation\n        </a>\n      </div>\n    </section>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'HomePage'\n};\n</script>\n\n<style scoped>\n/* ==========================================================================\n   VARIABLES & THEME (Premium Dark Mode)\n   ========================================================================== */\n:root {\n  --bg-dark: #09090b; /* Noir très profond type Zinc-950 */\n  --bg-card: #18181b; /* Gris très foncé pour les cartes */\n  --bg-card-hover: #27272a;\n  \n  --border-color: rgba(255, 255, 255, 0.08);\n  --border-hover: rgba(255, 255, 255, 0.2);\n  \n  --text-main: #f8fafc;\n  --text-muted: #a1a1aa;\n  \n  --accent-color: #ffffff; /* Le blanc agit comme accent principal */\n  --accent-glow: #3b82f6; /* Bleu très léger pour l'IA */\n  \n  --radius-lg: 24px;\n  --radius-md: 16px;\n  \n  --transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);\n}\n\n.premium-layout {\n  background-color: var(--bg-dark);\n  color: var(--text-main);\n  min-height: 100vh;\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n  overflow-x: hidden;\n  line-height: 1.5;\n}\n\n/* Glow subtil en haut de la page */\n.ambient-glow {\n  position: absolute;\n  top: -20%;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 80vw;\n  height: 50vh;\n  background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, rgba(9, 9, 11, 0) 70%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n/* ==========================================================================\n   TYPOGRAPHIE & UTILITAIRES\n   ========================================================================== */\nh1, h2, h3 {\n  letter-spacing: -0.03em;\n  font-weight: 600;\n  margin: 0;\n}\n\n.gradient-text {\n  background: linear-gradient(180deg, #ffffff 0%, #a1a1aa 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.section-heading {\n  text-align: left;\n  margin-bottom: 40px;\n}\n.section-heading h2 {\n  font-size: 2rem;\n  margin-bottom: 8px;\n}\n.section-heading p {\n  color: var(--text-muted);\n  font-size: 1.1rem;\n}\n\n/* Boutons */\n.btn-primary, .btn-secondary {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 12px 24px;\n  border-radius: 100px;\n  font-weight: 500;\n  font-size: 1rem;\n  text-decoration: none;\n  transition: var(--transition);\n  cursor: pointer;\n}\n\n.btn-primary {\n  background-color: var(--accent-color);\n  color: var(--bg-dark);\n}\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 10px 25px rgba(255, 255, 255, 0.15);\n}\n\n.btn-secondary {\n  background-color: transparent;\n  color: var(--text-main);\n  border: 1px solid var(--border-color);\n}\n.btn-secondary:hover {\n  background-color: var(--bg-card);\n  border-color: var(--border-hover);\n}\n\n.icon {\n  width: 18px; height: 18px;\n}\n\n/* ==========================================================================\n   1. HERO SECTION\n   ========================================================================== */\n.hero {\n  padding: 140px 24px 80px;\n  position: relative;\n  z-index: 1;\n}\n\n.hero-container {\n  max-width: 1200px;\n  margin: 0 auto;\n  display: flex;\n  align-items: center;\n  gap: 60px;\n}\n\n.hero-content {\n  flex: 1.2;\n}\n\n.status-pill {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 14px;\n  border-radius: 100px;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid var(--border-color);\n  font-size: 0.85rem;\n  color: var(--text-muted);\n  margin-bottom: 32px;\n}\n.dot {\n  width: 8px; height: 8px;\n  background-color: #22c55e;\n  border-radius: 50%;\n  box-shadow: 0 0 10px rgba(34, 197, 94, 0.5);\n}\n\n.hero-title {\n  font-size: clamp(2.5rem, 5vw, 4.5rem);\n  line-height: 1.1;\n  margin-bottom: 24px;\n}\n\n.hero-description {\n  font-size: 1.125rem;\n  color: var(--text-muted);\n  line-height: 1.7;\n  margin-bottom: 40px;\n  max-width: 600px;\n}\n.hero-description strong {\n  color: var(--text-main);\n  font-weight: 500;\n}\n\n.hero-cta {\n  display: flex;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n/* L'IMAGE DU HERO (Classe et grande) */\n.hero-image {\n  flex: 1;\n  display: flex;\n  justify-content: flex-end;\n}\n\n.image-frame {\n  width: 100%;\n  max-width: 500px; /* Taille généreuse */\n  aspect-ratio: 4/5; /* Format portrait élégant */\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n}\n\n.image-frame img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  filter: contrast(1.05) saturate(0.9); /* Donne un look très légèrement cinématique */\n  transition: transform 0.7s ease;\n}\n.image-frame:hover img {\n  transform: scale(1.03);\n}\n\n/* ==========================================================================\n   2. LOGOS / SOCIAL PROOF\n   ========================================================================== */\n.logos-section {\n  max-width: 1200px;\n  margin: 0 auto 80px;\n  padding: 0 24px;\n}\n\n.logos-title {\n  font-size: 0.75rem;\n  color: var(--text-muted);\n  letter-spacing: 0.1em;\n  margin-bottom: 24px;\n}\n\n.logos-grid {\n  display: flex;\n  gap: 32px;\n  flex-wrap: wrap;\n  border-top: 1px solid var(--border-color);\n  border-bottom: 1px solid var(--border-color);\n  padding: 32px 0;\n}\n\n.logo-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  font-weight: 600;\n  font-size: 1.1rem;\n}\n.text-xl { font-size: 1.5rem; }\n.tag {\n  font-size: 0.75rem;\n  font-weight: 500;\n  padding: 4px 10px;\n  border-radius: 6px;\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  color: var(--text-muted);\n}\n\n/* ==========================================================================\n   3. SERVICES (BENTO BOX)\n   ========================================================================== */\n.bento-section {\n  max-width: 1200px;\n  margin: 0 auto 120px;\n  padding: 0 24px;\n}\n\n.bento-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 20px;\n}\n\n.bento-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  border-radius: var(--radius-lg);\n  padding: 40px;\n  transition: var(--transition);\n  display: flex;\n  flex-direction: column;\n}\n.bento-card:hover {\n  border-color: var(--border-hover);\n  background: var(--bg-card-hover);\n}\n\n.bento-icon {\n  font-size: 2rem;\n  margin-bottom: 24px;\n}\n\n.bento-card h3 {\n  font-size: 1.5rem;\n  margin-bottom: 16px;\n}\n\n.bento-card p {\n  color: var(--text-muted);\n  line-height: 1.6;\n}\n\n/* Tailles de la grille */\n.col-span-1 { grid-column: span 1; }\n.col-span-2 { grid-column: span 2; }\n.col-span-full { grid-column: span 3; }\n\n/* Carte IA mise en avant */\n.highlight-card {\n  position: relative;\n  overflow: hidden;\n}\n.highlight-card::before {\n  content: '';\n  position: absolute;\n  top: 0; right: 0; width: 300px; height: 300px;\n  background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);\n  pointer-events: none;\n}\n.bento-header-flex {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n}\n.expert-badge {\n  font-size: 0.75rem;\n  background: rgba(255, 255, 255, 0.1);\n  padding: 6px 12px;\n  border-radius: 100px;\n}\n\n/* Carte Data horizontale */\n.data-card .bento-content-row {\n  display: flex;\n  align-items: flex-start;\n  gap: 24px;\n}\n.data-card .bento-icon { margin-bottom: 0; }\n.data-card p { max-width: 800px; }\n\n/* ==========================================================================\n   4. RÉALISATIONS\n   ========================================================================== */\n.work-section {\n  max-width: 1200px;\n  margin: 0 auto 120px;\n  padding: 0 24px;\n}\n\n.projects-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 32px;\n}\n\n.project-card {\n  text-decoration: none;\n  display: block;\n  group: true;\n}\n\n.project-img-wrapper {\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n  border: 1px solid var(--border-color);\n  position: relative;\n  aspect-ratio: 16/10;\n  margin-bottom: 24px;\n}\n\n.img-placeholder {\n  width: 100%;\n  height: 100%;\n  transition: transform 0.5s ease;\n}\n.bg-erp { background: linear-gradient(145deg, #1e293b, #0f172a); }\n.bg-client { background: linear-gradient(145deg, #27272a, #18181b); }\n\n.project-overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0;\n  transition: opacity 0.3s ease;\n  font-weight: 500;\n  color: white;\n}\n\n.project-card:hover .img-placeholder { transform: scale(1.05); }\n.project-card:hover .project-overlay { opacity: 1; }\n\n.project-meta {\n  font-size: 0.85rem;\n  color: var(--text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.project-info h3 {\n  color: var(--text-main);\n  font-size: 1.5rem;\n  margin-bottom: 8px;\n}\n\n.project-info p {\n  color: var(--text-muted);\n  line-height: 1.5;\n}\n\n/* ==========================================================================\n   5. CTA FINAL\n   ========================================================================== */\n.cta-section {\n  max-width: 800px;\n  margin: 0 auto 120px;\n  padding: 0 24px;\n}\n\n.cta-container {\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  border-radius: var(--radius-lg);\n  padding: 80px 40px;\n  text-align: center;\n}\n\n.cta-container h2 {\n  font-size: 2.5rem;\n  margin-bottom: 16px;\n}\n\n.cta-container p {\n  color: var(--text-muted);\n  font-size: 1.1rem;\n  margin-bottom: 40px;\n}\n\n.btn-large {\n  padding: 16px 32px;\n  font-size: 1.1rem;\n}\n\n/* ==========================================================================\n   ANIMATIONS D'ENTRÉE\n   ========================================================================== */\n.fade-in-up {\n  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n  opacity: 0;\n  transform: translateY(20px);\n}\n\n@keyframes fadeInUp {\n  from { opacity: 0; transform: translateY(20px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n/* ==========================================================================\n   RESPONSIVE (Mobile & Tablette)\n   ========================================================================== */\n@media (max-width: 1024px) {\n  .hero-title { font-size: 3.5rem; }\n  .bento-grid { grid-template-columns: 1fr; }\n  .col-span-1, .col-span-2, .col-span-full { grid-column: 1 / -1; }\n  .data-card .bento-content-row { flex-direction: column; gap: 16px; }\n}\n\n@media (max-width: 768px) {\n  .hero-container {\n    flex-direction: column;\n    text-align: center;\n    gap: 40px;\n  }\n  .hero-content {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .hero-cta { justify-content: center; }\n  \n  .hero-image {\n    width: 100%;\n    justify-content: center;\n  }\n  .image-frame {\n    max-width: 100%;\n    aspect-ratio: 1/1; /* Carré sur mobile */\n  }\n\n  .projects-grid { grid-template-columns: 1fr; }\n  \n  .logos-grid { flex-direction: column; gap: 16px; }\n  \n  .cta-container { padding: 40px 20px; }\n}\n</style>"],"mappings":"AAwIA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}