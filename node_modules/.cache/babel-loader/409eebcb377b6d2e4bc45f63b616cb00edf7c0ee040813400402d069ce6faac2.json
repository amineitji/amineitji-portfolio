>.</span></span>\n      </router-link>\n    </div>\n    \n    <button class=\"navbar-toggler\" type=\"button\" @click=\"toggleNavbar\" aria-label=\"Toggle navigation\">\n      <div class=\"menu-icon\" :class=\"{ 'is-active': isCollapsed }\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n    </button>\n    \n    <div :class=\"['navbar-menu', { 'is-open': isCollapsed }]\">\n      \n      <ul class=\"nav-links\">\n        <li class=\"nav-item\" v-for=\"item in navItems\" :key=\"item.name\">\n          <router-link\n            :to=\"item.link\"\n            class=\"nav-link\"\n            :class=\"{ 'active': isActive(item.link) }\"\n            @click=\"closeMenu\"\n          >\n            <span class=\"nav-text\">{{ item.name }}</span>\n            <div class=\"nav-indicator\"></div>\n          </router-link>\n        </li>\n      </ul>\n      \n      <div class=\"nav-actions\">\n        <div class=\"lang-switch\">\n          <button :class=\"{ active: currentLang === 'fr' }\" @click=\"setLang('fr')\">FR</button>\n          <span class=\"separator\">/</span>\n          <button :class=\"{ active: currentLang === 'en' }\" @click=\"setLang('en')\">EN</button>\n        </div>\n\n        <div class=\"availability-indicator\">\n          <div class=\"status-dot\"></div>\n          <span class=\"status-text\">Disponible</span>\n        </div>\n\n        <div class=\"mobile-contact\" v-if=\"isCollapsed\">\n          <a href=\"mailto:amineitji@gmail.com\" class=\"mobile-contact-btn\">\n            Me contacter\n          </a>\n        </div>\n      </div>\n\n    </div>\n  </nav>\n</template>\n\n<script>\nexport default {\n  name: 'SiteHeader',\n  data() {\n    return {\n      isCollapsed: false,\n      currentLang: 'fr', // Gestion de la langue\n      navItems: [\n        { name: 'Accueil', link: '/' },\n        { name: 'À propos', link: '/profil' },\n        { name: 'Projets', link: '/projets' },\n        { name: 'Services', link: '/services' },\n      ],\n    };\n  },\n  methods: {\n    toggleNavbar() {\n      this.isCollapsed = !this.isCollapsed;\n      if (this.isCollapsed) {\n        document.body.style.overflow = 'hidden';\n      } else {\n        document.body.style.overflow = '';\n      }\n    },\n    isActive(link) {\n      if (link === '/') {\n        return this.$route.path === '/';\n      }\n      return this.$route.path.startsWith(link);\n    },\n    closeMenu() {\n      if (this.isCollapsed) {\n        this.isCollapsed = false;\n        document.body.style.overflow = '';\n      }\n    },\n    setLang(lang) {\n      this.currentLang = lang;\n      // Ajoutez ici la logique i18n si vous utilisez vue-i18n\n      // ex: this.$i18n.locale = lang;\n    }\n  },\n  watch: {\n    $route() {\n      this.isCollapsed = false;\n      document.body.style.overflow = '';\n    }\n  },\n  beforeUnmount() {\n    document.body.style.overflow = '';\n  }\n};\n</script>\n\n<style scoped>\n/* Variables Premium Tech */\n:root {\n  --nav-bg: rgba(3, 7, 18, 0.75);\n  --border-color: rgba(255, 255, 255, 0.08);\n  --text-primary: #f9fafb;\n  --text-secondary: #9ca3af;\n  --primary-blue: #3b82f6;\n  --primary-purple: #8b5cf6;\n  --success-green: #10b981;\n  --transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n/* Navbar principale */\n.navbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 16px 40px;\n  background: var(--nav-bg);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  border-bottom: 1px solid var(--border-color);\n  position: sticky;\n  top: 0;\n  z-index: 1000;\n}\n\n/* Logo Typographique */\n.logo-link {\n  text-decoration: none;\n  display: inline-block;\n}\n\n.logo-text {\n  color: var(--text-primary);\n  font-weight: 700;\n  font-size: 1.4rem;\n  letter-spacing: -0.03em;\n  font-family: 'Inter', sans-serif;\n  transition: var(--transition);\n}\n\n.logo-dot {\n  color: var(--primary-blue);\n  font-size: 1.8rem;\n  line-height: 0;\n  position: relative;\n  top: 2px;\n  text-shadow: 0 0 15px rgba(59, 130, 246, 0.6);\n}\n\n.logo-link:hover .logo-text {\n  opacity: 0.8;\n}\n\n/* Navigation Links */\n.navbar-menu {\n  display: flex;\n  align-items: center;\n  flex: 1;\n  justify-content: space-between;\n  margin-left: 60px;\n}\n\n.nav-links {\n  display: flex;\n  list-style: none;\n  margin: 0;\n  padding: 0;\n  gap: 8px;\n}\n\n.nav-link {\n  position: relative;\n  display: flex;\n  align-items: center;\n  padding: 8px 16px;\n  color: var(--text-secondary);\n  text-decoration: none;\n  font-size: 0.95rem;\n  font-weight: 500;\n  transition: var(--transition);\n  border-radius: 100px;\n}\n\n.nav-text {\n  position: relative;\n  z-index: 2;\n}\n\n.nav-indicator {\n  position: absolute;\n  bottom: 0;\n  left: 50%;\n  width: 0;\n  height: 2px;\n  background: linear-gradient(90deg, var(--primary-blue), var(--primary-purple));\n  transition: all 0.3s ease;\n  transform: translateX(-50%);\n  border-radius: 2px;\n  opacity: 0;\n}\n\n.nav-link:hover {\n  color: var(--text-primary);\n  background: rgba(255, 255, 255, 0.05);\n}\n\n.nav-link.active {\n  color: var(--text-primary);\n}\n\n.nav-link.active .nav-indicator {\n  width: 40%;\n  opacity: 1;\n}\n\n/* Nav Actions (Droite) */\n.nav-actions {\n  display: flex;\n  align-items: center;\n  gap: 24px;\n}\n\n/* Switch FR/EN Discret */\n.lang-switch {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid var(--border-color);\n  padding: 4px 8px;\n  border-radius: 100px;\n}\n\n.lang-switch button {\n  background: none;\n  border: none;\n  color: var(--text-secondary);\n  font-size: 0.75rem;\n  font-weight: 600;\n  cursor: pointer;\n  padding: 2px 6px;\n  border-radius: 100px;\n  transition: var(--transition);\n}\n\n.lang-switch button:hover {\n  color: var(--text-primary);\n}\n\n.lang-switch button.active {\n  color: var(--text-primary);\n  background: rgba(255, 255, 255, 0.1);\n}\n\n.separator {\n  color: var(--border-color);\n  font-size: 0.8rem;\n}\n\n/* Indicateur de disponibilité */\n.availability-indicator {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 14px;\n  background: rgba(16, 185, 129, 0.05);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n  border-radius: 100px;\n  font-size: 0.8rem;\n  color: var(--success-green);\n  font-weight: 500;\n}\n\n.status-dot {\n  width: 6px;\n  height: 6px;\n  background: var(--success-green);\n  border-radius: 50%;\n  box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);\n  animation: pulse 2s infinite;\n}\n\n@keyframes pulse {\n  0% { opacity: 1; transform: scale(1); }\n  50% { opacity: 0.5; transform: scale(1.2); }\n  100% { opacity: 1; transform: scale(1); }\n}\n\n/* Hamburger Menu */\n.navbar-toggler {\n  display: none;\n  background: transparent;\n  border: none;\n  cursor: pointer;\n  padding: 8px;\n  border-radius: 8px;\n  transition: var(--transition);\n}\n\n.menu-icon {\n  width: 24px;\n  height: 20px;\n  position: relative;\n  transform: rotate(0deg);\n  transition: 0.3s ease-in-out;\n}\n\n.menu-icon span {\n  display: block;\n  position: absolute;\n  height: 2px;\n  width: 100%;\n  background: var(--text-primary);\n  border-radius: 2px;\n  opacity: 1;\n  left: 0;\n  transform: rotate(0deg);\n  transition: 0.2s ease-in-out;\n}\n\n.menu-icon span:nth-child(1) { top: 0px; }\n.menu-icon span:nth-child(2) { top: 8px; }\n.menu-icon span:nth-child(3) { top: 16px; }\n\n.menu-icon.is-active span:nth-child(1) {\n  top: 8px;\n  transform: rotate(135deg);\n}\n\n.menu-icon.is-active span:nth-child(2) {\n  opacity: 0;\n  left: -60px;\n}\n\n.menu-icon.is-active span:nth-child(3) {\n  top: 8px;\n  transform: rotate(-135deg);\n}\n\n/* Mobile Contact Button */\n.mobile-contact {\n  width: 100%;\n  margin-top: 32px;\n  display: none;\n}\n\n.mobile-contact-btn {\n  display: block;\n  width: 100%;\n  text-align: center;\n  padding: 14px;\n  background: linear-gradient(90deg, var(--primary-blue), var(--primary-purple));\n  color: white;\n  text-decoration: none;\n  border-radius: 100px;\n  font-weight: 600;\n  transition: var(--transition);\n}\n\n/* Responsive Design */\n@media (max-width: 1024px) {\n  .availability-indicator {\n    display: none; /* Caché sur tablette pour faire de la place */\n  }\n}\n\n@media (max-width: 768px) {\n  .navbar {\n    padding: 16px 24px;\n  }\n  \n  .navbar-toggler {\n    display: block;\n    z-index: 1002;\n  }\n  \n  .navbar-menu {\n    position: fixed;\n    top: 0;\n    right: -100%;\n    width: 100%;\n    height: 100vh;\n    background: rgba(3, 7, 18, 0.98);\n    backdrop-filter: blur(30px);\n    transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 40px 24px;\n    margin-left: 0;\n    z-index: 1000;\n  }\n  \n  .navbar-menu.is-open {\n    right: 0;\n  }\n  \n  .nav-links {\n    flex-direction: column;\n    align-items: center;\n    width: 100%;\n    gap: 16px;\n    margin-bottom: 40px;\n  }\n  \n  .nav-item {\n    width: 100%;\n  }\n  \n  .nav-link {\n    width: 100%;\n    justify-content: center;\n    padding: 16px;\n    font-size: 1.2rem;\n    border-radius: 16px;\n    background: rgba(255, 255, 255, 0.03);\n    border: 1px solid var(--border-color);\n  }\n  \n  .nav-link:hover,\n  .nav-link.active {\n    background: rgba(255, 255, 255, 0.08);\n  }\n  \n  .nav-indicator {\n    display: none;\n  }\n\n  .nav-actions {\n    flex-direction: column;\n    width: 100%;\n    gap: 20px;\n  }\n\n  .availability-indicator {\n    display: flex; /* Réaffiché dans le menu mobile */\n    width: fit-content;\n  }\n\n  .mobile-contact {\n    display: block;\n  }\n}\n</style>"],"mappings":";;;EACOA,KAAK,EAAC;AAAQ;;EACZA,KAAK,EAAC;AAAM;gEAEbC,mBAAA,CAAmE;EAA7DD,KAAK,EAAC;AAAW,I,aAJ/BE,gBAAA,CAIgC,OAAK,G,aAAAD,mBAAA,CAA+B;EAAzBD,KAAK,EAAC;AAAU,GAAC,GAAC,E;gEAMrDC,mBAAA,CAAa;gEACbA,mBAAA,CAAa;gEACbA,mBAAA,CAAa;oBAFbE,UAAa,EACbC,UAAa