gradient(135deg, rgba(139,92,246,0.2) 0%, rgba(59,130,246,0.1) 100%)',\n          mailto: \"mailto:amineitji@gmail.com?subject=Devis - Pack Expert Sur Mesure&body=Bonjour Amine,%0A%0AJe souhaite discuter d'un projet sur mesure.%0A%0ADescription du besoin : \",\n          features: [\n            \"Application Web ou SaaS complète sur mesure\",\n            \"Espace membre, back-office d'administration\",\n            \"Paiement en ligne Stripe intégré\",\n            \"Intégration d'Intelligence Artificielle ou d'agents LLM\",\n            \"Architecture Cloud évolutive (AWS / Docker)\",\n            \"API REST documentée et sécurisée\",\n            \"Tests automatisés et CI/CD\",\n            \"Accompagnement, formation et documentation complète\"\n          ]\n        }\n      }\n    };\n  },\n\n  computed: {\n    currentPackData() {\n      return this.selectedPack ? this.packsData[this.selectedPack] : {};\n    },\n    missionMailto() {\n      return \"mailto:amineitji@gmail.com?subject=Mission Freelance&body=Bonjour Amine,%0A%0AJ'ai un projet de développement et souhaite discuter d'une mission.%0A%0ADescription : \";\n    }\n  },\n\n  methods: {\n    openModal(pack) {\n      this.selectedPack = pack;\n      document.body.style.overflow = 'hidden';\n    },\n    closeModal() {\n      this.selectedPack = null;\n      document.body.style.overflow = '';\n    }\n  },\n\n  beforeUnmount() {\n    document.body.style.overflow = '';\n  }\n};\n</script>\n\n<style scoped>\n/* ============================================================\n   LAYOUT & BG\n   ============================================================ */\n.services-page {\n  min-height: 100vh;\n  padding: 60px 0 0;\n  position: relative;\n  overflow: hidden;\n}\n\n.bg-grid {\n  position: fixed;\n  inset: 0;\n  background-image:\n    linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);\n  background-size: 48px 48p