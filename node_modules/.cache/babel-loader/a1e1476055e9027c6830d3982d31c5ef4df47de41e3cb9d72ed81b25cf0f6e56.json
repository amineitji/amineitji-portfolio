{"ast":null,"code":"export default {\n  name: 'ServicesPage',\n  data() {\n    return {\n      selectedPack: null,\n      packsData: {\n        basic: {\n          tier: 'STARTER',\n          title: 'Pack Présence',\n          price: '600€',\n          headerGradient: 'linear-gradient(135deg, rgba(16,185,129,0.15) 0%, rgba(6,182,212,0.08) 100%)',\n          mailto: \"mailto:amineitji@gmail.com?subject=Devis - Pack Présence Starter&body=Bonjour Amine,%0A%0AJe suis intéressé par le Pack Présence à 600€.%0A%0AMon projet : \",\n          features: [\"Site vitrine jusqu'à 3 pages (Accueil, Services, Contact)\", \"Design moderne 100% responsive (Mobile / Tablette / PC)\", \"Formulaire de contact fonctionnel\", \"Intégration Google Maps & réseaux sociaux\", \"Nom de domaine et hébergement configurés\", \"Optimisation SEO on-page de base\", \"Livraison avec accès aux sources\"]\n        },\n        avance: {\n          tier: 'BUSINESS',\n          title: 'Pack Pro',\n          price: '950€',\n          headerGradient: 'linear-gradient(135deg, rgba(59,130,246,0.15) 0%, rgba(139,92,246,0.08) 100%)',\n          mailto: \"mailto:amineitji@gmail.com?subject=Devis - Pack Pro Business&body=Bonjour Amine,%0A%0AJe suis intéressé par le Pack Pro à 950€.%0A%0AMon projet : \",\n          features: [\"Tout du Pack Présence, sans limitation\", \"Jusqu'à 7 pages entièrement personnalisées\", \"Design Premium avec animations et transitions fluides\", \"Galerie photos / portfolio dynamique\", \"Section blog ou actualités\", \"SEO avancé : Core Web Vitals, données structurées, sitemap\", \"Score Lighthouse 90+ garanti\", \"1 mois de maintenance et corrections offert\"]\n        },\n        premium: {\n          tier: 'EXCELLENCE',\n          title: 'Pack Expert',\n          price: 'Sur devis — dès 1 500€',\n          headerGradient: 'linear-gradient(135deg, rgba(139,92,246,0.2) 0%, rgba(59,130,246,0.1) 100%)',\n          mailto: \"mailto:amineitji@gmail.com?subject=Devis - Pack Expert Sur Mesure&body=Bonjour Amine,%0A%0AJe souhaite discuter d'un projet sur mesure.%0A%0ADescription du besoin : \",\n          features: [\"Application Web ou SaaS complète sur mesure\", \"Espace membre, back-office d'administration\", \"Paiement en ligne Stripe intégré\", \"Intégration d'Intelligence Artificielle ou d'agents LLM\", \"Architecture Cloud évolutive (AWS / Docker)\", \"API REST documentée et sécurisée\", \"Tests automatisés et CI/CD\", \"Accompagnement, formation et documentation complète\"]\n        }\n      }\n    };\n  },\n  computed: {\n    currentPackData() {\n      return this.selectedPack ? this.packsData[this.selectedPack] : {};\n    },\n    missionMailto() {\n      return \"mailto:amineitji@gmail.com?subject=Mission Freelance&body=Bonjour Amine,%0A%0AJ'ai un projet de développement et souhaite discuter d'une mission.%0A%0ADescription : \";\n    }\n  },\n  methods: {\n    openModal(pack) {\n      this.selectedPack = pack;\n      document.body.style.overflow = 'hidden';\n    },\n    closeModal() {\n      this.selectedPack = null;\n      document.body.style.overflow = '';\n    }\n  },\n  beforeUnmount() {\n    document.body.style.overflow = '';\n  }\n};","map":{"version":3,"names":["name","data","selectedPack","packsData","basic","tier","title","price","headerGradient","mailto","features","avance","premium","computed","currentPackData","missionMailto","methods","openModal","pack","document","body","style","overflow","closeModal","beforeUnmount"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/views/MesServices.vue"],"sourcesContent":["<template>\n  <div class=\"services-page\">\n\n    <!-- Arrière-plan -->\n    <div class=\"bg-grid\"></div>\n    <div class=\"blob blob-blue\"></div>\n    <div class=\"blob blob-purple\"></div>\n\n    <!-- ======================================================\n         HEADER\n         ====================================================== -->\n    <header class=\"page-header fade-in-up\">\n      <span class=\"section-label\">\n        <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg>\n        Offres & Tarifs\n      </span>\n      <h1>Construisons votre<br><span class=\"gradient-text\">avantage compétitif.</span></h1>\n      <p>\n        Du site vitrine stratégique à la plateforme SaaS intégrant de l'IA — je livre des solutions techniques qui génèrent de la valeur mesurable, pas juste du code.\n      </p>\n      <div class=\"header-disclaimer\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"></line><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"></line></svg>\n        <span>Activité freelance exercée en dehors de mon poste d'AI Project Manager chez Michelin.</span>\n      </div>\n    </header>\n\n    <!-- ======================================================\n         SECTION 1 — PACKS SITES WEB\n         ====================================================== -->\n    <section class=\"section fade-in-up\" style=\"animation-delay:0.15s;\">\n      <div class=\"section-heading\">\n        <span class=\"section-label\">\n          <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect><line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\"></line><line x1=\"9\" y1=\"21\" x2=\"9\" y2=\"9\"></line></svg>\n          Sites Web\n        </span>\n        <h2>Création de sites & landing pages</h2>\n        <p>Des fondations web solides qui convertissent vos visiteurs en clients.</p>\n      </div>\n\n      <div class=\"packs-grid\">\n\n        <!-- Pack Starter -->\n        <div class=\"pack-card\" @click=\"openModal('basic')\">\n          <div class=\"pack-glow\" style=\"background: radial-gradient(circle, rgba(16,185,129,0.2) 0%, transparent 70%);\"></div>\n          <div class=\"pack-top\">\n            <span class=\"pack-tier\" style=\"background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.25); color: #34d399;\">STARTER</span>\n          </div>\n          <h3 class=\"pack-name\">Pack Présence</h3>\n          <div class=\"pack-price\">\n            <span class=\"price-amount\">600€</span>\n            <span class=\"price-note\">tout inclus</span>\n          </div>\n          <p class=\"pack-tagline\">Idéal pour établir une présence professionnelle rapide.</p>\n\n          <ul class=\"pack-features\">\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Site One-Page ou jusqu'à 3 pages\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Design Responsive (Mobile & Desktop)\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Formulaire de contact + Google Maps\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              SEO de base + hébergement configuré\n            </li>\n          </ul>\n\n          <div class=\"pack-meta\">\n            <span>\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>\n              Livraison en ~1 semaine\n            </span>\n          </div>\n\n          <button class=\"pack-cta\" style=\"background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.25); color: #34d399;\">\n            Voir les détails\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>\n          </button>\n        </div>\n\n        <!-- Pack Pro -->\n        <div class=\"pack-card\" @click=\"openModal('avance')\">\n          <div class=\"pack-glow\" style=\"background: radial-gradient(circle, rgba(59,130,246,0.2) 0%, transparent 70%);\"></div>\n          <div class=\"pack-top\">\n            <span class=\"pack-tier\" style=\"background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.3); color: #60a5fa;\">BUSINESS</span>\n          </div>\n          <h3 class=\"pack-name\">Pack Pro</h3>\n          <div class=\"pack-price\">\n            <span class=\"price-amount\">950€</span>\n            <span class=\"price-note\">tout inclus</span>\n          </div>\n          <p class=\"pack-tagline\">Pour les entreprises qui veulent être vues et cliquées.</p>\n\n          <ul class=\"pack-features\">\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Tout du Pack Présence + jusqu'à 7 pages\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Design Premium + animations fluides\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Optimisation SEO avancée (Lighthouse 90+)\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              1 mois de maintenance offert\n            </li>\n          </ul>\n\n          <div class=\"pack-meta\">\n            <span>\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>\n              Livraison en ~2 semaines\n            </span>\n          </div>\n\n          <button class=\"pack-cta\" style=\"background: rgba(59,130,246,0.12); border-color: rgba(59,130,246,0.3); color: #60a5fa;\">\n            Voir les détails\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>\n          </button>\n        </div>\n\n        <!-- Pack Expert / Featured -->\n        <div class=\"pack-card is-featured\" @click=\"openModal('premium')\">\n          <div class=\"featured-ribbon\">Recommandé</div>\n          <div class=\"pack-glow\" style=\"background: radial-gradient(circle, rgba(139,92,246,0.3) 0%, transparent 70%);\"></div>\n          <div class=\"pack-top\">\n            <span class=\"pack-tier\" style=\"background: rgba(139,92,246,0.15); border-color: rgba(139,92,246,0.35); color: #c4b5fd;\">EXCELLENCE</span>\n          </div>\n          <h3 class=\"pack-name\">Pack Expert</h3>\n          <div class=\"pack-price\">\n            <span class=\"price-amount\">Sur devis</span>\n            <span class=\"price-note\">dès 1 500€</span>\n          </div>\n          <p class=\"pack-tagline\">Applications SaaS, intégrations IA, besoins complexes.</p>\n\n          <ul class=\"pack-features\">\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Application Web ou SaaS sur mesure\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              E-commerce / Espace membre / Back-office\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Intégration IA, agents LLM et API\n            </li>\n            <li>\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n              Architecture évolutive + accompagnement\n            </li>\n          </ul>\n\n          <div class=\"pack-meta\">\n            <span>\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>\n              3+ semaines selon complexité\n            </span>\n          </div>\n\n          <button class=\"pack-cta\" style=\"background: linear-gradient(135deg, rgba(139,92,246,0.25), rgba(59,130,246,0.15)); border-color: rgba(139,92,246,0.4); color: #c4b5fd;\">\n            Demander un devis\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>\n          </button>\n        </div>\n\n      </div>\n    </section>\n\n    <!-- ======================================================\n         SECTION 2 — MISSIONS FREELANCE / TJM\n         ====================================================== -->\n    <section class=\"section fade-in-up\" style=\"animation-delay: 0.3s;\">\n      <div class=\"section-heading\">\n        <span class=\"section-label\">\n          <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z\"></path><line x1=\"7\" y1=\"7\" x2=\"7.01\" y2=\"7\"></line></svg>\n          Missions Freelance\n        </span>\n        <h2>Expertise technique à la mission</h2>\n        <p>Pour vos projets ponctuels ou vos besoins en renfort d'équipe — facturation transparente au TJM.</p>\n      </div>\n\n      <div class=\"mission-card\">\n        <!-- Header -->\n        <div class=\"mission-header\">\n          <div class=\"mission-header-left\">\n            <div class=\"mission-icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"></polygon></svg>\n            </div>\n            <div>\n              <h3>Développement Full-Stack & IA</h3>\n              <p>Vue.js · Django · Python · LLM / Agents IA</p>\n            </div>\n          </div>\n          <div class=\"mission-tjm\">\n            <span class=\"tjm-amount\">350€</span>\n            <span class=\"tjm-unit\">/ jour</span>\n          </div>\n        </div>\n\n        <!-- Domaines -->\n        <div class=\"mission-domains\">\n          <div class=\"domain-col\">\n            <div class=\"domain-icon\" style=\"background: rgba(59,130,246,0.1); color: #60a5fa;\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"16 18 22 12 16 6\"></polyline><polyline points=\"8 6 2 12 8 18\"></polyline></svg>\n            </div>\n            <h4>Front-end</h4>\n            <ul>\n              <li>Vue.js 3 / Nuxt / TypeScript</li>\n              <li>Interfaces réactives & Design Systems</li>\n              <li>Intégration maquettes Figma</li>\n            </ul>\n          </div>\n          <div class=\"domain-col\">\n            <div class=\"domain-icon\" style=\"background: rgba(139,92,246,0.1); color: #a78bfa;\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"></ellipse><path d=\"M21 12c0 1.66-4 3-9 3s-9-1.34-9-3\"></path><path d=\"M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5\"></path></svg>\n            </div>\n            <h4>Back-end</h4>\n            <ul>\n              <li>API REST Django / FastAPI</li>\n              <li>PostgreSQL, Redis</li>\n              <li>AWS, Docker, CI/CD</li>\n            </ul>\n          </div>\n          <div class=\"domain-col\">\n            <div class=\"domain-icon\" style=\"background: rgba(6,182,212,0.1); color: #67e8f9;\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg>\n            </div>\n            <h4>Intelligence Artificielle</h4>\n            <ul>\n              <li>Agents LLM & pipelines RAG</li>\n              <li>Computer Vision (YOLO, OpenCV)</li>\n              <li>Prompt Engineering & fine-tuning</li>\n            </ul>\n          </div>\n        </div>\n\n        <!-- Grille de prix indicatifs -->\n        <div class=\"mission-pricing\">\n          <div class=\"pricing-row\">\n            <div class=\"pricing-item\">\n              <span class=\"pricing-label\">MVP (prototype rapide)</span>\n              <span class=\"pricing-value\">~2 500€</span>\n            </div>\n            <div class=\"pricing-divider\"></div>\n            <div class=\"pricing-item\">\n              <span class=\"pricing-label\">Application métier complète</span>\n              <span class=\"pricing-value\">~4 500€+</span>\n            </div>\n            <div class=\"pricing-divider\"></div>\n            <div class=\"pricing-item\">\n              <span class=\"pricing-label\">Intégration IA / Agent LLM</span>\n              <span class=\"pricing-value\">Sur devis</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- CTA -->\n        <div class=\"mission-cta\">\n          <a :href=\"missionMailto\" class=\"btn-glow\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"></path><polyline points=\"22,6 12,13 2,6\"></polyline></svg>\n            Discuter de votre projet\n          </a>\n          <p class=\"mission-note\">Réponse garantie sous 24h · Devis gratuit · Appel de découverte offert</p>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======================================================\n         SECTION 3 — GARANTIES / PROCESSUS\n         ====================================================== -->\n    <section class=\"section fade-in-up\" style=\"animation-delay: 0.45s;\">\n      <div class=\"section-heading\">\n        <span class=\"section-label\">\n          <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg>\n          Pourquoi moi\n        </span>\n        <h2>Ce que vous obtenez en plus du code</h2>\n      </div>\n\n      <div class=\"guarantees-grid\">\n        <div class=\"guarantee-card\">\n          <div class=\"g-icon\" style=\"background: rgba(59,130,246,0.1); color: #60a5fa;\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"></polyline></svg>\n          </div>\n          <h4>Expérience Industrie</h4>\n          <p>AI Project Manager chez Michelin. Je comprends les enjeux business et le niveau d'exigence des grandes entreprises.</p>\n        </div>\n        <div class=\"guarantee-card\">\n          <div class=\"g-icon\" style=\"background: rgba(139,92,246,0.1); color: #a78bfa;\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"></rect><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"></line><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"></line></svg>\n          </div>\n          <h4>Référence en Production</h4>\n          <p>DiagERP est un SaaS B2B actif, pas un démo. Vous engagez quelqu'un qui a déjà livré et maintient des produits réels.</p>\n        </div>\n        <div class=\"guarantee-card\">\n          <div class=\"g-icon\" style=\"background: rgba(6,182,212,0.1); color: #67e8f9;\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"></line><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path></svg>\n          </div>\n          <h4>Double Compétence Rare</h4>\n          <p>Master 2 IA + Développeur Full-Stack. Je conçois et j'implémente des solutions IA de A à Z, sans intermédiaire.</p>\n        </div>\n        <div class=\"guarantee-card\">\n          <div class=\"g-icon\" style=\"background: rgba(245,158,11,0.1); color: #fbbf24;\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg>\n          </div>\n          <h4>Communication Transparente</h4>\n          <p>Points d'avancement réguliers, code commenté, documentation livrée. Vous ne serez jamais dans le noir sur l'état de votre projet.</p>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======================================================\n         BOTTOM CTA\n         ====================================================== -->\n    <section class=\"bottom-cta fade-in-up\" style=\"animation-delay: 0.55s;\">\n      <div class=\"cta-panel\">\n        <div class=\"cta-glow\"></div>\n        <div class=\"cta-content\">\n          <div class=\"status-pill\">\n            <span class=\"pulse-dot\"></span>\n            Disponible pour de nouveaux projets\n          </div>\n          <h2>Prêt à construire quelque chose d'ambitieux ?</h2>\n          <p>Décrivez-moi votre défi en 2 phrases. Je reviens avec un premier retour sous 24h, sans engagement.</p>\n          <a href=\"mailto:amineitji@gmail.com?subject=Demande de devis freelance\" class=\"btn-glow large\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"></path><polyline points=\"22,6 12,13 2,6\"></polyline></svg>\n            Obtenir mon devis gratuit\n          </a>\n        </div>\n      </div>\n    </section>\n\n    <!-- ======================================================\n         MODAL\n         ====================================================== -->\n    <transition name=\"modal-fade\">\n      <div v-if=\"selectedPack\" class=\"modal-overlay\" @click=\"closeModal\">\n        <div class=\"modal-box\" @click.stop>\n          <button class=\"modal-close\" @click=\"closeModal\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line></svg>\n          </button>\n\n          <div class=\"modal-header\" :style=\"{ background: currentPackData.headerGradient }\">\n            <span class=\"modal-tier\">{{ currentPackData.tier }}</span>\n            <h3 class=\"modal-title\">{{ currentPackData.title }}</h3>\n            <div class=\"modal-price-tag\">{{ currentPackData.price }}</div>\n          </div>\n\n          <div class=\"modal-body\">\n            <h4>Ce qui est inclus</h4>\n            <ul class=\"modal-features\">\n              <li v-for=\"(feat, i) in currentPackData.features\" :key=\"i\">\n                <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                {{ feat }}\n              </li>\n            </ul>\n\n            <div class=\"modal-actions\">\n              <a :href=\"currentPackData.mailto\" class=\"btn-glow\" style=\"width: 100%; justify-content: center;\">\n                <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"></path><polyline points=\"22,6 12,13 2,6\"></polyline></svg>\n                Commander ce pack\n              </a>\n              <p class=\"modal-footnote\">Réponse sous 24h · Devis détaillé gratuit</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </transition>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ServicesPage',\n  data(