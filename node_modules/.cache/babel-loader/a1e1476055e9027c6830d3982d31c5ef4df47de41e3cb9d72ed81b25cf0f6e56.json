p: -60px;\n  right: -60px;\n  width: 240px;\n  height: 240px;\n  border-radius: 50%;\n  filter: blur(50px);\n  pointer-events: none;\n  opacity: 0;\n  transition: opacity 0.5s ease;\n}\n\n.pack-card:hover .pack-glow {\n  opacity: 1;\n}\n\n.featured-ribbon {\n  position: absolute;\n  top: 20px;\n  right: -26px;\n  background: linear-gradient(135deg, #8b5cf6, #3b82f6);\n  color: white;\n  font-size: 0.68rem;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  padding: 5px 36px;\n  transform: rotate(45deg);\n  box-shadow: 0 4px 16px rgba(139,92,246,0.4);\n}\n\n.pack-top { }\n\n.pack-tier {\n  display: inline-flex;\n  font-size: 0.68rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  padding: 5px 12px;\n  border-radius: 100px;\n  border: 1px solid;\n}\n\n.pack-name {\n  font-size: 1.6rem;\n  font-weight: 800;\n  letter-spacing: -0.03em;\n  color: #f9fafb;\n}\n\n.pack-price {\n  display: flex;\n  align-items: baseline;\n  gap: 8px;\n}\n\n.price-amount {\n  font-size: 2rem;\n  font-weight: 800;\n  letter-spacing: -0.04em;\n  color: #f9fafb;\n}\n\n.price-note {\n  font-size: 0.82rem;\n  color: #4b5563;\n}\n\n.pack-tagline {\n  font-size: 0.88rem;\n  color: #6b7280;\n  line-height: 1.5;\n}\n\n.pack-features {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n  flex: 1;\n}\n\n.pack-features li {\n  display: flex;\n  align-items: flex-start;\n  gap: 9px;\n  font-size: 0.88rem;\n  color: #9ca3af;\n  line-height: 1.5;\n}\n\n.pack-features li svg {\n  color: #10b981;\n  flex-shrink: 0;\n  margin-top: 2px;\n}\n\n.pack-meta {\n  display: flex;\n  gap: 16px;\n  font-size: 0.78rem;\n  color: #4b5563;\n}\n\n.pack-meta span {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n}\n\n.pack-cta {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  padding: 12px 18px;\n  border-radius: 12px;\n  border: 1px solid;\n  font-size: 0.9rem;\n  font-weight: 600;\n  font-family: inherit;\n  cursor: pointer;\n  transition: all 0.25s ease;\n  backdrop-filter: blur(8px);\n}\n\n.pack-cta:hover {\n  transform: translateY(-2px);\n  filter: brightness(1.15);\n}\n\n/* ============================================================\n   MISSION CARD\n   ============================================================ */\n.mission-card {\n  background: rgba(17,24,39,0.5);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 28px;\n  overflow: hidden;\n}\n\n.mission-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 32px 36px;\n  border-bottom: 1px solid rgba(255,255,255,0.06);\n  background: rgba(255,255,255,0.02);\n  gap: 20px;\n}\n\n.mission-header-left {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.mission-icon {\n  width: 52px;\n  height: 52px;\n  border-radius: 16px;\n  background: linear-gradient(135deg, rgba(59,130,246,0.2), rgba(139,92,246,0.15));\n  border: 1px solid rgba(59,130,246,0.25);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #93c5fd;\n  flex-shrink: 0;\n}\n\n.mission-header-left h3 {\n  font-size: 1.3rem;\n  font-weight: 700;\n  color: #f9fafb;\n  letter-spacing: -0.02em;\n  margin-bottom: 4px;\n}\n\n.mission-header-left p {\n  font-size: 0.85rem;\n  color: #4b5563;\n}\n\n.mission-tjm {\n  display: flex;\n  align-items: baseline;\n  gap: 6px;\n  flex-shrink: 0;\n}\n\n.tjm-amount {\n  font-size: 2.4rem;\n  font-weight: 800;\n  letter-spacing: -0.04em;\n  color: #f9fafb;\n}\n\n.tjm-unit {\n  font-size: 0.9rem;\n  color: #4b5563;\n}\n\n/* Domaines */\n.mission-domains {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0;\n  border-bottom: 1px solid rgba(255,255,255,0.05);\n}\n\n.domain-col {\n  padding: 28px 32px;\n  border-right: 1px solid rgba(255,255,255,0.05);\n}\n\n.domain-col:last-child { border-right: none; }\n\n.domain-icon {\n  width: 36px;\n  height: 36p