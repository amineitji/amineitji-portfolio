{"ast":null,"code":"import { resolveComponent as _resolveComponent, createVNode as _createVNode, resolveDynamicComponent as _resolveDynamicComponent, openBlock as _openBlock, createBlock as _createBlock, Transition as _Transition, withCtx as _withCtx, createElementVNode as _createElementVNode, createElementBlock as _createElementBlock } from \"vue\";\nconst _hoisted_1 = {\n  id: \"app\",\n  class: \"app-container\"\n};\nconst _hoisted_2 = {\n  class: \"main-content\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  const _component_SiteHeader = _resolveComponent(\"SiteHeader\");\n  const _component_router_view = _resolveComponent(\"router-view\");\n  const _component_SiteFooter = _resolveComponent(\"SiteFooter\");\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [_createVNode(_component_SiteHeader), _createElementVNode(\"main\", _hoisted_2, [_createVNode(_component_router_view, null, {\n    default: _withCtx(({\n      Component\n    }) => [_createVNode(_Transition, {\n      name: \"page\",\n      mode: \"out-in\"\n    }, {\n      default: _withCtx(() => [(_openBlock(), _createBlock(_resolveDynamicComponent(Component)))]),\n      _: 2 /* DYNAMIC */\n    }, 1024 /* DYNAMIC_SLOTS */)]),\n    _: 1 /* STABLE */\n  })]), _createVNode(_component_SiteFooter)]);\n}","map":{"version":3,"names":["id","class","_createElementBlock","_hoisted_1","_createVNode","_component_SiteHeader","_createElementVNode","_hoisted_2","_component_router_view","default","_withCtx","Component","_Transition","name","mode","_createBlock","_resolveDynamicComponent","_","_component_SiteFooter"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"app-container\">\n    <SiteHeader />\n    \n    <main class=\"main-content\">\n      <router-view v-slot=\"{ Component }\">\n        <transition name=\"page\" mode=\"out-in\">\n          <component :is=\"Component\" />\n        </transition>\n      </router-view>\n    </main>\n\n    <SiteFooter />\n  </div>\n</template>\n\n<script>\nimport SiteFooter from './components/SiteFooter.vue';\nimport SiteHeader from './components/SiteHeader.vue';\n\nexport default {\n  name: 'App',\n  components: {\n    SiteHeader,\n    SiteFooter,\n  },\n};\n</script>\n\n<style>\n/* ==========================================================================\n   VARIABLES GLOBALES (Thème Premium Dark)\n   ========================================================================== */\n:root {\n  --bg-dark: #030712; /* Noir bleuté profond */\n  --bg-card: rgba(17, 24, 39, 0.4); /* Base Glassmorphism */\n  \n  --border-color: rgba(255, 255, 255, 0.08);\n  --border-hover: rgba(255, 255, 255, 0.2);\n  \n  --text-primary: #f9fafb;\n  --text-secondary: #9ca3af;\n  --text-muted: #6b7280;\n  \n  --primary-blue: #3b82f6;\n  --primary-purple: #8b5cf6;\n  --primary-cyan: #06b6d4;\n  --success-green: #10b981;\n  \n  --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n  --radius-lg: 24px;\n  --radius-md: 16px;\n}\n\n/* ==========================================================================\n   RESET & BASE\n   ========================================================================== */\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n  line-height: 1.6;\n  background-color: var(--bg-dark);\n  color: var(--text-primary);\n  overflow-x: hidden;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* Structure globale (Flexbox pour le Sticky Footer) */\n#app {\n  display: flex;\n  flex-direction: column;\n  min-height: 100vh;\n}\n\n.main-content {\n  flex: 1; /* Permet au contenu principal de pousser le footer vers le bas */\n  position: relative;\n  z-index: 1;\n  width: 100%;\n}\n\n/* ==========================================================================\n   SCROLLBAR PREMIUM\n   ========================================================================== */\n::-webkit-scrollbar {\n  width: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--bg-dark);\n}\n\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 10px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* ==========================================================================\n   TRANSITIONS DE PAGE (Vue Router)\n   ========================================================================== */\n.page-enter-active,\n.page-leave-active {\n  transition: opacity 0.4s ease, transform 0.4s ease;\n}\n\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(15px);\n}\n\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-15px);\n}\n\n/* ==========================================================================\n   STYLES GLOBAUX UTILES (Typographie, Liens, Cartes génériques)\n   ========================================================================== */\nh1, h2, h3, h4, h5 {\n  font-weight: 700;\n  line-height: 1.2;\n  margin-bottom: 1rem;\n  letter-spacing: -0.02em;\n  color: var(--text-primary);\n}\n\np {\n  color: var(--text-secondary);\n  margin-bottom: 1rem;\n}\n\na {\n  color: var(--primary-blue);\n  text-decoration: none;\n  transition: var(--transition-smooth);\n}\n\na:hover {\n  color: var(--primary-cyan);\n}\n\n/* Style de carte générique Glassmorphism */\n.glass-card {\n  background: var(--bg-card);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border: 1px solid var(--border-color);\n  border-radius: var(--radius-lg);\n  padding: 24px;\n  transition: var(--transition-smooth);\n}\n\n.glass-card:hover {\n  border-color: var(--border-hover);\n  transform: translateY(-4px);\n  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);\n}\n\n/* Inputs globaux */\ninput, textarea, select {\n  background: rgba(255, 255, 255, 0.03);\n  color: var(--text-primary);\n  border: 1px solid var(--border-color);\n  padding: 12px 16px;\n  border-radius: 12px;\n  font-family: 'Inter', sans-serif;\n  transition: var(--transition-smooth);\n  width: 100%;\n}\n\ninput:focus, textarea:focus, select:focus {\n  outline: none;\n  border-color: var(--primary-blue);\n  background: rgba(255, 255, 255, 0.05);\n  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);\n}\n\ninput::placeholder, textarea::placeholder {\n  color: var(--text-muted);\n}\n\n/* Ligne de séparation douce */\n.divider {\n  width: 100%;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, var(--border-color), transparent);\n  margin: 32px 0;\n}\n\n/* ==========================================================================\n   SÉLECTION DE TEXTE (Highlight)\n   ========================================================================== */\n::selection {\n  background: rgba(59, 130, 246, 0.3); /* Fond bleu transparent */\n  color: #000000;\n}\n</style>"],"mappings":";;EACOA,EAAE,EAAC,KAAK;EAACC,KAAK,EAAC;;;EAGZA,KAAK,EAAC;AAAc;;;;;uBAH5BC,mBAAA,CAYM,OAZNC,UAYM,GAXJC,YAAA,CAAcC,qBAAA,GAEdC,mBAAA,CAMO,QANPC,UAMO,GALLH,YAAA,CAIcI,sBAAA;IATpBC,OAAA,EAAAC,QAAA,CAMQ,CAEa;MAHQC;IAAS,OAC9BP,YAAA,CAEaQ,WAAA;MAFDC,IAAI,EAAC,MAAM;MAACC,IAAI,EAAC;;MANrCL,OAAA,EAAAC,QAAA,CAOU,MAA6B,E,cAA7BK,YAAA,CAA6BC,wBAPvC,CAO0BL,SAAS,I;MAPnCM,CAAA;;IAAAA,CAAA;QAYIb,YAAA,CAAcc,qBAAA,E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}