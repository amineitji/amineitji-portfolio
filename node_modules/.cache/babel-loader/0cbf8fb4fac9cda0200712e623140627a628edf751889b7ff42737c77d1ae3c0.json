{"ast":null,"code":"export default {\n  name: 'SiteHeader',\n  inject: ['getLang', 'setLang'],\n  data() {\n    return {\n      menuOpen: false,\n      isScrolled: false,\n      navItems: [{\n        fr: 'Accueil',\n        en: 'Home',\n        to: '/'\n      }, {\n        fr: 'À propos',\n        en: 'About',\n        to: '/profil'\n      }, {\n        fr: 'Projets',\n        en: 'Projects',\n        to: '/projets'\n      }, {\n        fr: 'Services',\n        en: 'Services',\n        to: '/services'\n      }]\n    };\n  },\n  computed: {\n    currentLang() {\n      return this.getLang();\n    }\n  },\n  methods: {\n    isActive(to) {\n      if (to === '/') return this.$route.path === '/';\n      return this.$route.path.startsWith(to);\n    },\n    close() {\n      this.menuOpen = false;\n    },\n    onScroll() {\n      this.isScrolled = window.scrollY > 10;\n    }\n  },\n  watch: {\n    menuOpen(v) {\n      document.body.style.overflow = v ? 'hidden' : '';\n    },\n    $route() {\n      this.close();\n    }\n  },\n  mounted() {\n    window.addEventListener('scroll', this.onScroll, {\n      passive: true\n    });\n  },\n  beforeUnmount() {\n    window.removeEventListener('scroll', this.onScroll);\n    document.body.style.overflow = '';\n  }\n};","map":{"version":3,"names":["name","inject","data","menuOpen","isScrolled","navItems","fr","en","to","computed","currentLang","getLang","methods","isActive","$route","path","startsWith","close","onScroll","window","scrollY","watch","v","document","body","style","overflow","mounted","addEventListener","passive","beforeUnmount","removeEventListener"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/SiteHeader.vue"],"sourcesContent":["<template>\n  <nav class=\"navbar\" :class=\"{ scrolled: isScrolled }\">\n    <div class=\"nav-inner\">\n      <router-link to=\"/\" class=\"logo\" @click=\"close\">\n        Amine<span class=\"logo-dot\">.</span>\n      </router-link>\n\n      <ul class=\"nav-links\">\n        <li v-for=\"item in navItems\" :key=\"item.fr\">\n          <router-link :to=\"item.to\" class=\"nav-link\" :class=\"{ active: isActive(item.to) }\" @click=\"close\">\n            {{ currentLang === 'en' ? item.en : item.fr }}\n          </router-link>\n        </li>\n      </ul>\n\n      <div class=\"nav-right\">\n        <div class=\"lang-toggle\">\n          <button @click=\"setLang('fr')\" :class=\"{ on: currentLang === 'fr' }\">FR</button>\n          <span class=\"sep\">|</span>\n          <button @click=\"setLang('en')\" :class=\"{ on: currentLang === 'en' }\">EN</button>\n        </div>\n        <div class=\"avail\">\n          <span class=\"avail-dot\"></span>\n          {{ currentLang === 'en' ? 'Available' : 'Disponible' }}\n        </div>\n        <a href=\"mailto:amineitji@gmail.com\" class=\"nav-cta\">\n          {{ currentLang === 'en' ? 'Contact' : 'Contact' }}\n        </a>\n      </div>\n\n      <button class=\"burger\" :class=\"{ open: menuOpen }\" @click=\"menuOpen = !menuOpen\" aria-label=\"Menu\">\n        <span></span><span></span><span></span>\n      </button>\n    </div>\n\n    <transition name=\"mobile-menu\">\n      <div class=\"mobile-panel\" v-if=\"menuOpen\">\n        <ul class=\"mobile-links\">\n          <li v-for=\"item in navItems\" :key=\"item.fr\">\n            <router-link :to=\"item.to\" class=\"mobile-link\" :class=\"{ active: isActive(item.to) }\" @click=\"close\">\n              {{ currentLang === 'en' ? item.en : item.fr }}\n            </router-link>\n          </li>\n        </ul>\n        <div class=\"mobile-bottom\">\n          <div class=\"lang-toggle large\">\n            <button @click=\"setLang('fr')\" :class=\"{ on: currentLang === 'fr' }\">Français</button>\n            <span class=\"sep\">|</span>\n            <button @click=\"setLang('en')\" :class=\"{ on: currentLang === 'en' }\">English</button>\n          </div>\n          <a href=\"mailto:amineitji@gmail.com\" class=\"nav-cta full\" @click=\"close\">\n            {{ currentLang === 'en' ? 'Send a message' : 'Envoyer un message' }}\n          </a>\n        </div>\n      </div>\n    </transition>\n  </nav>\n</template>\n\n<script>\nexport default {\n  name: 'SiteHeader',\n  inject: ['getLang', 'setLang'],\n  data() {\n    return {\n      menuOpen: false,\n      isScrolled: false,\n      navItems: [\n        { fr: 'Accueil',  en: 'Home',     to: '/' },\n        { fr: 'À propos', en: 'About',    to: '/profil' },\n        { fr: 'Projets',  en: 'Projects', to: '/projets' },\n        { fr: 'Services', en: 'Services', to: '/services' },\n      ],\n    };\n  },\n  computed: {\n    currentLang() { return this.getLang(); },\n  },\n  methods: {\n    isActive(to) {\n      if (to === '/') return this.$route.path === '/';\n      return this.$route.path.startsWith(to);\n    },\n    close() { this.menuOpen = false; },\n    onScroll() { this.isScrolled = window.scrollY > 10; },\n  },\n  watch: {\n    menuOpen(v) { document.body.style.overflow = v ? 'hidden' : ''; },\n    $route() { this.close(); },\n  },\n  mounted()      { window.addEventListener('scroll', this.onScroll, { passive: true }); },\n  beforeUnmount(){ window.removeEventListener('scroll', this.onScroll); document.body.style.overflow = ''; },\n};\n</script>\n\n<style scoped>\n.navbar {\n  position: sticky; top: 0; z-index: 500;\n  background: rgba(255,255,255,0.92);\n  border-bottom: 1px solid var(--gray-100);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  transition: box-shadow 0.25s ease;\n}\n.navbar.scrolled { box-shadow: 0 1px 14px rgba(0,0,0,0.07); }\n\n.nav-inner {\n  max-width: var(--max-w); margin: 0 auto; padding: 0 var(--px);\n  height: var(--nav-h); display: flex; align-items: center; gap: 28px;\n}\n\n.logo {\n  font-size: 1.28rem; font-weight: 900; letter-spacing: -0.05em;\n  color: var(--gray-900); text-decoration: none; flex-shrink: 0;\n  transition: opacity 0.18s;\n}\n.logo:hover { opacity: 0.65; }\n.logo-dot { color: var(--blue); }\n\n.nav-links { display: flex; list-style: none; gap: 2px; flex: 1; }\n\n.nav-link {\n  display: block; padding: 7px 13px; border-radius: 8px;\n  font-size: 0.875rem; font-weight: 500; color: var(--gray-500);\n  text-decoration: none; transition: color 0.18s, background 0.18s;\n}\n.nav-link:hover { color: var(--gray-900); background: var(--gray-100); }\n.nav-link.active { color: var(--gray-900); font-weight: 600; background: var(--gray-100); }\n\n.nav-right { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }\n\n.lang-toggle {\n  display: flex; align-items: center; gap: 3px;\n  background: var(--gray-100); border-radius: 8px; padding: 3px 5px;\n}\n.lang-toggle button {\n  background: none; border: none; cursor: pointer;\n  font-family: var(--font); font-size: 0.72rem; font-weight: 700;\n  letter-spacing: 0.06em; color: var(--gray-400);\n  padding: 4px 8px; border-radius: 5px; transition: all 0.18s;\n}\n.lang-toggle button:hover { color: var(--gray-700); }\n.lang-toggle button.on { color: var(--gray-900); background: var(--white); box-shadow: var(--shadow-sm); }\n.lang-toggle.large button { font-size: 0.9rem; padding: 8px 14px; }\n.sep { color: var(--gray-300); font-size: 0.7rem; }\n\n.avail {\n  display: flex; align-items: center; gap: 6px;\n  font-size: 0.77rem; font-weight: 600; color: var(--green);\n}\n.avail-dot {\n  width: 7px; height: 7px; border-radius: 50%; background: var(--green);\n  animation: blink 2s ease-in-out infinite;\n}\n@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }\n\n.nav-cta {\n  display: inline-flex; align-items: center; padding: 9px 18px;\n  background: var(--gray-900); color: white;\n  text-decoration: none; border-radius: 100px;\n  font-size: 0.825rem; font-weight: 600;\n  transition: background 0.18s, transform 0.18s;\n}\n.nav-cta:hover { background: var(--gray-700); transform: translateY(-1px); color: white; }\n.nav-cta.full { width: 100%; justify-content: center; padding: 14px; border-radius: 14px; }\n\n.burger {\n  display: none; flex-direction: column; justify-content: center; align-items: center;\n  gap: 5px; width: 36px; height: 36px; background: none; border: none; cursor: pointer;\n}\n.burger span { display: block; width: 20px; height: 2px; background: var(--gray-900); border-radius: 2px; transition: all 0.25s; }\n.burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }\n.burger.open span:nth-child(2) { opacity: 0; }\n.burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }\n\n.mobile-panel {\n  position: fixed; top: var(--nav-h); left: 0; right: 0; bottom: 0;\n  background: var(--white); padding: 20px var(--px) 32px;\n  display: flex; flex-direction: column; gap: 6px;\n  z-index: 400; border-top: 1px solid var(--gray-100); overflow-y: auto;\n}\n.mobile-links { list-style: none; display: flex; flex-direction: column; gap: 3px; flex: 1; }\n.mobile-link {\n  display: block; padding: 14px 16px; font-size: 1.1rem; font-weight: 600;\n  color: var(--gray-600); text-decoration: none; border-radius: 12px; transition: all 0.18s;\n}\n.mobile-link:hover, .mobile-link.active { background: var(--gray-100); color: var(--gray-900); }\n.mobile-bottom { display: flex; flex-direction: column; gap: 12px; padding-top: 16px; border-top: 1px solid var(--gray-100); }\n\n.mobile-menu-enter-active { transition: opacity 0.22s ease, transform 0.28s var(--ease); }\n.mobile-menu-leave-active  { transition: opacity 0.18s ease, transform 0.22s ease; }\n.mobile-menu-enter-from    { opacity: 0; transform: translateY(-8px); }\n.mobile-menu-leave-to      { opacity: 0; }\n\n@media (max-width: 768px) {\n  .nav-links, .avail { display: none; }\n  .burger { display: flex; }\n}\n@media (max-width: 520px) {\n  .nav-cta:not(.full) { display: none; }\n}\n</style>"],"mappings":"AA4DA,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,MAAM,EAAE,CAAC,SAAS,EAAE,SAAS,CAAC;EAC9BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,KAAK;MACfC,UAAU,EAAE,KAAK;MACjBC,QAAQ,EAAE,CACR;QAAEC,EAAE,EAAE,SAAS;QAAG