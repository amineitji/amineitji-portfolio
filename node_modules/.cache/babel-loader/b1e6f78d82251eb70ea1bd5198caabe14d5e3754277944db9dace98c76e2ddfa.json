{"ast":null,"code":"export default {\n  name: 'UserProfile'\n};","map":{"version":3,"names":["name"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/views/UserProfile.vue"],"sourcesContent":["<template>\n  <div class=\"innovative-layout\">\n    <div class=\"bg-grid\"></div>\n    <div class=\"blob blob-blue\"></div>\n    <div class=\"blob blob-purple\"></div>\n\n    <div class=\"profile-header fade-in-up\">\n      <h1 class=\"page-title\">Parcours & Expertise</h1>\n      <p class=\"page-subtitle\">Une double compétence académique et professionnelle au service de l'innovation technologique.</p>\n    </div>\n\n    <div class=\"profile-grid\">\n      <div class=\"glass-card timeline-card fade-in-up\" style=\"animation-delay: 0.2s;\">\n        <div class=\"card-header\">\n          <div class=\"icon-box blue\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"></rect><path d=\"M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\"></path></svg>\n          </div>\n          <h2>Parcours Professionnel</h2>\n        </div>\n        \n        <div class=\"timeline\">\n          <div class=\"timeline-item current\">\n            <div class=\"timeline-marker\">\n              <div class=\"pulse-dot\"></div>\n            </div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date highlight\">Depuis Février 2026</span>\n              <h3>AI Project Manager</h3>\n              <p class=\"company\">Michelin</p>\n              <ul class=\"timeline-details\">\n                <li>Pilotage stratégique de projets d'Intelligence Artificielle.</li>\n                <li>Déploiement de solutions Data innovantes à grande échelle.</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"timeline-item current\">\n            <div class=\"timeline-marker\">\n              <div class=\"pulse-dot secondary\"></div>\n            </div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date\">Depuis Juin 2023</span>\n              <h3>Freelance Full-Stack & IA</h3>\n              <p class=\"company\">Indépendant</p>\n              <ul class=\"timeline-details\">\n                <li>Développement sur-mesure d'applications web et SaaS (Vue.js / Django).</li>\n                <li>Intégration d'agents IA, LLMs et automatisation de processus métiers.</li>\n                <li>Web scraping massif et analyse de données (Python).</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"timeline-item\">\n            <div class=\"timeline-marker solid\"></div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date\">Janvier 2025 - Mars 2025</span>\n              <h3>Stage - Digitalisation & Web</h3>\n              <p class=\"company\">ALSTOM - Villeurbanne</p>\n              <ul class=\"timeline-details\">\n                <li>Digitalisation des processus d'inspection (KIZEO).</li>\n                <li>Développement d'outils internes et reporting analytique.</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"timeline-item\">\n            <div class=\"timeline-marker solid\"></div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date\">Mai 2023 - Juin 2023</span>\n              <h3>Stage - Développeur Full-Stack</h3>\n              <p class=\"company\">ANEQQIS - Paris</p>\n              <ul class=\"timeline-details\">\n                <li>Création de A à Z d'une architecture SaaS (Django/Vue.js).</li>\n                <li>Intégration des paiements Stripe et génération de PDF complexes.</li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"glass-card timeline-card fade-in-up\" style=\"animation-delay: 0.3s;\">\n        <div class=\"card-header\">\n          <div class=\"icon-box purple\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"></path><path d=\"M6 12v5c3 3 9 3 12 0v-5\"></path></svg>\n          </div>\n          <h2>Parcours Académique</h2>\n        </div>\n        \n        <div class=\"timeline\">\n          <div class=\"timeline-item current\">\n            <div class=\"timeline-marker\">\n              <div class=\"pulse-dot\"></div>\n            </div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date highlight\">Diplômé en 2026</span>\n              <h3>Master 2 Intelligence Artificielle</h3>\n              <p class=\"company\">Université Claude Bernard Lyon 1</p>\n              <ul class=\"timeline-details\">\n                <li>Spécialisation Machine Learning & Deep Learning.</li>\n                <li>Expertise en Computer Vision, NLP et Data Science.</li>\n                <li>Réalisation de projets de recherche appliquée en IA.</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"timeline-item\">\n            <div class=\"timeline-marker solid\"></div>\n            <div class=\"timeline-content\">\n              <span class=\"timeline-date\">2020 - 2023</span>\n              <h3>Licence Informatique</h3>\n              <p class=\"company\">Université Claude Bernard Lyon 1</p>\n              <ul class=\"timeline-details\">\n                <li>Acquisition de bases solides en algorithmique et architecture logicielle.</li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"glass-card objectives-section fade-in-up\" style=\"animation-delay: 0.4s;\">\n      <div class=\"card-header center\">\n        <div class=\"icon-box cyan\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\"></line><line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\"></line></svg>\n        </div>\n        <h2>Mon Offre de Service Freelance</h2>\n        <p class=\"subtitle\">Des solutions techniques pointues pour répondre à vos enjeux métiers.</p>\n      </div>\n\n      <div class=\"objectives-grid\">\n        <div class=\"objective-card\">\n          <div class=\"obj-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"16 18 22 12 16 6\"></polyline><polyline points=\"8 6 2 12 8 18\"></polyline></svg></div>\n          <h3>Développement Web sur-mesure</h3>\n          <p>Sites vitrines modernes, plateformes E-commerce complexes, et applications SaaS scalables. Je transforme vos idées en produits digitaux performants, sécurisés et optimisés pour le SEO.</p>\n        </div>\n        \n        <div class=\"objective-card\">\n          <div class=\"obj-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg></div>\n          <h3>Intelligence Artificielle</h3>\n          <p>Intégration d'agents IA, création de pipelines RAG, analyse d'images (Computer Vision) et automatisation de tâches répétitives pour vous redonner du temps à forte valeur ajoutée.</p>\n        </div>\n      </div>\n\n      <div class=\"cta-actions\">\n        <a href=\"mailto:amineitji@gmail.com?subject=Proposition de mission\" class=\"btn-glow large\">\n          <span class=\"btn-content\">Me contacter pour un projet</span>\n        </a>\n        <a href=\"/CV.pdf\" download=\"CV_Amine_ITJI.pdf\" class=\"btn-outline\">\n          Télécharger mon CV (PDF)\n        </a>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'UserProfile'\n};\n</script>\n\n<style scoped>\n/* ==========================================================================\n   VARIABLES & THEME GLOBAL\n   ========================================================================== */\n:root {\n  --color-bg: #030712;\n  --color-card: rgba(17, 24, 39, 0.4);\n  --color-border: rgba(255, 255, 255, 0.08);\n  --color-border-hover: rgba(255, 255, 255, 0.15);\n  \n  --text-main: #f9fafb;\n  --text-muted: #9ca3af;\n  \n  --primary-blue: #3b82f6;\n  --primary-purple: #8b5cf6;\n  --primary-cyan: #06b6d4;\n  \n  --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.innovative-layout {\n  position: relative;\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 40px 24px 80px;\n  z-index: 1;\n}\n\n/* ==========================================================================\n   ARRIÈRE-PLAN ANIMÉ\n   ========================================================================== */\n.bg-grid {\n  position: fixed;\n  inset: 0;\n  background-image: \n    linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);\n  background-size: 40px 40px;\n  z-index: -1;\n  pointer-events: none;\n}\n\n.blob {\n  position: fixed;\n  border-radius: 50%;\n  filter: blur(120px);\n  opacity: 0.3;\n  z-index: -1;\n  pointer-events: none;\n  animation: float 20s ease-in-out infinite alternate;\n}\n.blob-blue {\n  top: 10%; left: -10%;\n  width: 500px; height: 500px;\n  background: var(--primary-blue);\n}\n.blob-purple {\n  bottom: 10%; right: -10%;\n  width: 400px; height: 400px;\n  background: var(--primary-purple);\n  animation-delay: -5s;\n}\n\n@keyframes float {\n  0% { transform: translate(0, 0) scale(1); }\n  100% { transform: translate(30px, 30px) scale(1.1); }\n}\n\n/* ==========================================================================\n   EN-TÊTE DE PAGE\n   ========================================================================== */\n.profile-header {\n  text-align: center;\n  margin-bottom: 60px;\n}\n.page-title {\n  font-size: clamp(2.5rem, 4vw, 3.5rem);\n  font-weight: 800;\n  letter-spacing: -0.03em;\n  margin-bottom: 16px;\n  background: linear-gradient(to right, #ffffff, #a1a1aa);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n.page-subtitle {\n  color: var(--text-muted);\n  font-size: 1.15rem;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n/* ==========================================================================\n   CARTES GLASSMORPHISM & GRILLE\n   ========================================================================== */\n.profile-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 32px;\n  margin-bottom: 40px;\n}\n\n.glass-card {\n  background: var(--color-card);\n  border: 1px solid var(--color-border);\n  border-radius: 30px;\n  padding: 40px;\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  transition: var(--transition-smooth);\n}\n.glass-card:hover {\n  border-color: var(--color-border-hover);\n  box-shadow: 0 20px 40px rgba(0,0,0,0.3);\n}\n\n.card-header {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  margin-bottom: 40px;\n}\n.card-header.center {\n  flex-direction: column;\n  text-align: center;\n  gap: 12px;\n}\n.card-header h2 {\n  font-size: 1.5rem;\n  font-weight: 700;\n  color: white;\n  margin: 0;\n}\n.subtitle {\n  color: var(--text-muted);\n  font-size: 1.05rem;\n}\n\n.icon-box {\n  width: 48px; height: 48px;\n  border-radius: 14px;\n  display: flex; align-items: center; justify-content: center;\n}\n.icon-box svg { width: 24px; height: 24px; }\n.icon-box.blue { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }\n.icon-box.purple { background: rgba(139, 92, 246, 0.15); color: #a78bfa; }\n.icon-box.cyan { background: rgba(6, 182, 212, 0.15); color: #22d3ee; }\n\n/* ==========================================================================\n   TIMELINE (Parcours)\n   ========================================================================== */\n.timeline {\n  position: relative;\n  padding-left: 24px;\n}\n.timeline::before {\n  content: '';\n  position: absolute;\n  top: 0; bottom: 0; left: 7px;\n  width: 2px;\n  background: linear-gradient(to bottom, var(--color-border-hover), transparent);\n}\n\n.timeline-item {\n  position: relative;\n  margin-bottom: 40px;\n}\n.timeline-item:last-child {\n  margin-bottom: 0;\n}\n\n.timeline-marker {\n  position: absolute;\n  left: -24px;\n  display: flex; align-items: center; justify-content: center;\n  width: 16px; height: 16px;\n  transform: translateX(-50%);\n  background: #0f172a;\n  border-radius: 50%;\n}\n.timeline-marker.solid {\n  width: 10px; height: 10px;\n  background: var(--text-muted);\n  border: 2px solid #0f172a;\n}\n\n.pulse-dot {\n  width: 10px; height: 10px;\n  background: var(--primary-blue);\n  border-radius: 50%;\n  box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7);\n  animation: pulseBlue 2s infinite;\n}\n.pulse-dot.secondary {\n  background: var(--primary-cyan);\n  box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.7);\n  animation: pulseCyan 2s infinite;\n}\n\n@keyframes pulseBlue {\n  0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }\n  70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }\n  100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }\n}\n@keyframes pulseCyan {\n  0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.4); }\n  70% { box-shadow: 0 0 0 10px rgba(6, 182, 212, 0); }\n  100% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0); }\n}\n\n.timeline-content {\n  padding-left: 16px;\n}\n\n.timeline-date {\n  display: inline-block;\n  font-size: 0.8rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: var(--text-muted);\n  margin-bottom: 8px;\n  padding: 4px 10px;\n  border-radius: 100px;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid var(--color-border);\n}\n.timeline-date.highlight {\n  color: #60a5fa;\n  background: rgba(59, 130, 246, 0.1);\n  border-color: rgba(59, 130, 246, 0.2);\n}\n\n.timeline-content h3 {\n  font-size: 1.2rem;\n  color: white;\n  margin-bottom: 4px;\n}\n.company {\n  font-size: 0.95rem;\n  color: var(--primary-cyan);\n  font-weight: 500;\n  margin-bottom: 12px;\n}\n\n.timeline-details {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n}\n.timeline-details li {\n  position: relative;\n  padding-left: 16px;\n  color: var(--text-muted);\n  font-size: 0.95rem;\n  margin-bottom: 6px;\n  line-height: 1.5;\n}\n.timeline-details li::before {\n  content: '';\n  position: absolute;\n  left: 0; top: 10px;\n  width: 4px; height: 4px;\n  background: var(--text-muted);\n  border-radius: 50%;\n}\n\n/* ==========================================================================\n   OBJECTIFS & OFFRES DE SERVICE\n   ========================================================================== */\n.objectives-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 24px;\n  margin-bottom: 40px;\n}\n\n.objective-card {\n  background: rgba(255, 255, 255, 0.02);\n  border: 1px solid var(--color-border);\n  border-radius: 20px;\n  padding: 32px;\n  transition: var(--transition-smooth);\n}\n.objective-card:hover {\n  background: rgba(255, 255, 255, 0.04);\n  border-color: rgba(255, 255, 255, 0.1);\n}\n\n.obj-icon {\n  width: 40px; height: 40px;\n  color: var(--primary-blue);\n  margin-bottom: 20px;\n}\n.obj-icon svg { width: 100%; height: 100%; }\n\n.objective-card h3 {\n  font-size: 1.25rem;\n  color: white;\n  margin-bottom: 12px;\n}\n.objective-card p {\n  color: var(--text-muted);\n  font-size: 0.95rem;\n  line-height: 1.6;\n}\n\n/* ==========================================================================\n   BOUTONS CTA\n   ========================================================================== */\n.cta-actions {\n  display: flex;\n  gap: 16px;\n  justify-content: center;\n  flex-wrap: wrap;\n}\n\n.btn-glow {\n  position: relative;\n  display: inline-flex;\n  border-radius: 100px;\n  padding: 2px;\n  background: linear-gradient(90deg, var(--primary-blue), var(--primary-purple), var(--primary-cyan));\n  background-size: 200% auto;\n  animation: gradientShift 3s linear infinite;\n  text-decoration: none;\n  cursor: pointer;\n  transition: transform 0.2s ease;\n}\n.btn-glow:hover {\n  transform: scale(1.02);\n  box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);\n}\n.btn-content {\n  background: #0f172a;\n  color: white;\n  padding: 14px 32px;\n  border-radius: 100px;\n  font-weight: 600;\n  transition: background 0.3s ease;\n}\n.btn-glow:hover .btn-content { background: transparent; }\n\n.btn-outline {\n  display: inline-flex;\n  align-items: center;\n  padding: 14px 32px;\n  border-radius: 100px;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid var(--color-border);\n  color: white;\n  font-weight: 600;\n  text-decoration: none;\n  transition: var(--transition-smooth);\n}\n.btn-outline:hover {\n  background: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.2);\n}\n\n@keyframes gradientShift {\n  0% { background-position: 0% 50%; }\n  100% { background-position: 200% 50%; }\n}\n\n/* ==========================================================================\n   ANIMATIONS D'ENTRÉE\n   ========================================================================== */\n.fade-in-up {\n  opacity: 0;\n  transform: translateY(30px);\n  animation: fadeInUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n@keyframes fadeInUpAnim {\n  to { opacity: 1; transform: translateY(0); }\n}\n\n/* ==========================================================================\n   RESPONSIVE DESIGN\n   ========================================================================== */\n@media (max-width: 992px) {\n  .profile-grid { grid-template-columns: 1fr; }\n}\n\n@media (max-width: 768px) {\n  .innovative-layout { padding: 24px 16px 60px; }\n  .page-title { font-size: 2.2rem; }\n  .glass-card { padding: 24px; }\n  .objectives-grid { grid-template-columns: 1fr; gap: 16px; }\n  .cta-actions { flex-direction: column; width: 100%; }\n  .btn-glow, .btn-outline { width: 100%; justify-content: center; text-align: center; }\n  .btn-content { width: 100%; }\n}\n</style>"],"mappings":"AA4JA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}