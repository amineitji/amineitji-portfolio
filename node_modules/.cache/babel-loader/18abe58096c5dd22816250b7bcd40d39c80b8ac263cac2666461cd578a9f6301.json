{"ast":null,"code":"export default {\n  name: 'HomePage'\n};","map":{"version":3,"names":["name"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/HomePage.vue"],"sourcesContent":["<template>\n  <div class=\"landing-container\">\n    <div class=\"bg-glow glow-top-left\"></div>\n    <div class=\"bg-glow glow-bottom-right\"></div>\n    <div class=\"grid-pattern\"></div>\n\n    <section class=\"hero-section\">\n      <div class=\"hero-content\">\n        <div class=\"availability-badge\">\n          <span class=\"pulse-dot\"></span>\n          Disponible pour de nouvelles missions\n        </div>\n        \n        <h1 class=\"hero-title\">\n          Propulsez votre entreprise avec des solutions \n          <span class=\"text-gradient\">Web & IA sur-mesure</span>\n        </h1>\n        \n        <p class=\"hero-subtitle\">\n          Développeur Full-Stack & AI Project Manager. Je conçois des plateformes SaaS performantes et j'intègre des systèmes d'Intelligence Artificielle (LLMs, Agents) pour automatiser votre croissance.\n        </p>\n        \n        <div class=\"hero-cta\">\n          <a href=\"mailto:amineitji@gmail.com?subject=Demande de devis - Projet Web/IA\" class=\"btn btn-primary\">\n            Parler de votre projet\n            <svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>\n          </a>\n          <router-link to=\"/projets\" class=\"btn btn-secondary\">\n            Voir mes réalisations\n          </router-link>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"trust-section\">\n      <p class=\"trust-title\">Une expertise technique forgée auprès des meilleurs</p>\n      <div class=\"trust-logos\">\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🏭</span>\n          <div class=\"trust-text\">\n            <strong>Michelin</strong>\n            <span>AI Project Manager</span>\n          </div>\n        </div>\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🚀</span>\n          <div class=\"trust-text\">\n            <strong>DiagERP</strong>\n            <span>Co-fondateur & CTO</span>\n          </div>\n        </div>\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🎓</span>\n          <div class=\"trust-text\">\n            <strong>Université Lyon 1</strong>\n            <span>Master 2 IA</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"services-section\">\n      <div class=\"section-header\">\n        <h2 class=\"section-title\">Comment je peux vous aider ?</h2>\n        <p class=\"section-subtitle\">Une double compétence rare pour répondre à tous vos défis techniques.</p>\n      </div>\n\n      <div class=\"services-grid\">\n        <div class=\"service-card\">\n          <div class=\"service-icon-wrapper web-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"></path><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"></polyline><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"></line></svg>\n          </div>\n          <h3>Développement Web & SaaS</h3>\n          <p>Création d'applications web complètes, robustes et scalables. De l'architecture de la base de données jusqu'au déploiement final et l'intégration de paiements (Stripe).</p>\n          <ul class=\"service-features\">\n            <li>Vue.js / Django</li>\n            <li>Plateformes sur-mesure</li>\n            <li>Optimisation SEO & Perf</li>\n          </ul>\n        </div>\n\n        <div class=\"service-card featured-service\">\n          <div class=\"service-icon-wrapper ai-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"></line><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path></svg>\n          </div>\n          <h3>Intelligence Artificielle & LLMs</h3>\n          <p>Intégration de l'IA générative dans vos processus métier pour gagner un temps précieux. Création d'agents intelligents autonomes capables de raisonner sur vos données privées.</p>\n          <ul class=\"service-features\">\n            <li>Agents IA & Prompt Engineering</li>\n            <li>Pipelines RAG (LangChain)</li>\n            <li>Computer Vision (YOLO)</li>\n          </ul>\n        </div>\n\n        <div class=\"service-card\">\n          <div class=\"service-icon-wrapper data-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"></ellipse><path d=\"M21 12c0 1.66-4 3-9 3s-9-1.34-9-3\"></path><path d=\"M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5\"></path></svg>\n          </div>\n          <h3>Data & Automatisation</h3>\n          <p>Ne perdez plus de temps sur des tâches répétitives. Je mets en place des scripts d'extraction de données (Scraping) et d'automatisation de vos flux de travail.</p>\n          <ul class=\"service-features\">\n            <li>Web Scraping massif</li>\n            <li>Traitement de données (Python)</li>\n            <li>Création d'API REST</li>\n          </ul>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"work-section\">\n      <div class=\"section-header\">\n        <h2 class=\"section-title\">Ils me font confiance</h2>\n      </div>\n      \n      <div class=\"projects-showcase\">\n        <div class=\"showcase-card\">\n          <div class=\"showcase-content\">\n            <span class=\"project-tag\">SaaS en production</span>\n            <h3>DiagERP</h3>\n            <p>Logiciel métier complet pour les diagnostiqueurs immobiliers. Gestion de la facturation, génération de rapports complexes et espace client sécurisé.</p>\n            <a href=\"https://diagerp.fr/\" target=\"_blank\" class=\"text-link\">Voir le site en direct →</a>\n          </div>\n        </div>\n\n        <div class=\"showcase-card\">\n          <div class=\"showcase-content\">\n            <span class=\"project-tag\">Site Vitrine Premium</span>\n            <h3>DiagImmoMarches</h3>\n            <p>Conception d'une présence en ligne optimisée pour la conversion et le SEO local pour une entreprise d'immobilier.</p>\n            <a href=\"https://diagimmomarches.fr/\" target=\"_blank\" class=\"text-link\">Voir le site en direct →</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"bottom-cta\">\n      <div class=\"cta-box glass-panel\">\n        <h2>Prêt à accélérer votre business ?</h2>\n        <p>Discutons de vos objectifs lors d'un premier échange gratuit et sans engagement.</p>\n        <div class=\"cta-actions\">\n          <a href=\"mailto:amineitji@gmail.com\" class=\"btn btn-primary btn-lg\">\n            Me contacter maintenant\n          </a>\n        </div>\n        <div class=\"profile-mini\">\n          <img src=\"pp.jpeg\" alt=\"Amine ITJI\" class=\"avatar-mini\">\n          <div>\n            <strong>Amine ITJI</strong>\n            <span>Réponse sous 24h</span>\n          </div>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'HomePage'\n};\n</script>\n\n<style scoped>\n/* Design System Variables */\n:root {\n  --bg-dark: #050505;\n  --bg-card: rgba(20, 20, 22, 0.6);\n  --border-color: rgba(255, 255, 255, 0.1);\n  --text-main: #ffffff;\n  --text-muted: #a0a0ab;\n  --primary: #3b82f6; /* Blue */\n  --primary-hover: #2563eb;\n  --accent: #8b5cf6; /* Purple */\n  --success: #10b981;\n  --gradient-text: linear-gradient(135deg, #60a5fa, #c084fc);\n  --glass-blur: blur(12px);\n}\n\n/* Global Container */\n.landing-container {\n  background-color: var(--bg-dark);\n  color: var(--text-main);\n  min-height: 100vh;\n  position: relative;\n  overflow: hidden;\n  font-family: 'Inter', system-ui, -apple-system, sans-serif;\n  padding-bottom: 80px;\n}\n\n/* Background Effects */\n.bg-glow {\n  position: absolute;\n  width: 600px;\n  height: 600px;\n  border-radius: 50%;\n  filter: blur(120px);\n  z-index: 0;\n  opacity: 0.15;\n  pointer-events: none;\n}\n.glow-top-left {\n  top: -200px;\n  left: -200px;\n  background: var(--primary);\n}\n.glow-bottom-right {\n  bottom: -200px;\n  right: -200px;\n  background: var(--accent);\n}\n.grid-pattern {\n  position: absolute;\n  inset: 0;\n  background-image: linear-gradient(var(--border-color) 1px, transparent 1px),\n    linear-gradient(90deg, var(--border-color) 1px, transparent 1px);\n  background-size: 40px 40px;\n  opacity: 0.2;\n  z-index: 0;\n  pointer-events: none;\n  mask-image: radial-gradient(circle at center, black, transparent 80%);\n  -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);\n}\n\n/* Base Layout */\nsection {\n  position: relative;\n  z-index: 1;\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 24px;\n}\n\n/* Generic Section Header */\n.section-header {\n  text-align: center;\n  margin-bottom: 60px;\n}\n.section-title {\n  font-size: clamp(2rem, 4vw, 2.5rem);\n  font-weight: 700;\n  margin-bottom: 16px;\n  letter-spacing: -0.02em;\n}\n.section-subtitle {\n  color: var(--text-muted);\n  font-size: 1.125rem;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n/* 1. Hero Section */\n.hero-section {\n  padding: 120px 24px 80px;\n  display: flex;\n  justify-content: center;\n  text-align: center;\n}\n.hero-content {\n  max-width: 800px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n.availability-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  background: rgba(16, 185, 129, 0.1);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n  color: var(--success);\n  padding: 6px 16px;\n  border-radius: 100px;\n  font-size: 0.875rem;\n  font-weight: 500;\n  margin-bottom: 32px;\n}\n.pulse-dot {\n  width: 8px;\n  height: 8px;\n  background-color: var(--success);\n  border-radius: 50%;\n  box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);\n  animation: pulse 2s infinite;\n}\n@keyframes pulse {\n  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }\n  70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }\n  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }\n}\n.hero-title {\n  font-size: clamp(2.5rem, 6vw, 4rem);\n  font-weight: 800;\n  line-height: 1.1;\n  margin-bottom: 24px;\n  letter-spacing: -0.03em;\n}\n.text-gradient {\n  background: var(--gradient-text);\n  -webkit-background-clip: text;\n  background-clip: text;\n  color: transparent;\n}\n.hero-subtitle {\n  font-size: clamp(1.1rem, 2vw, 1.25rem);\n  color: var(--text-muted);\n  line-height: 1.6;\n  margin-bottom: 40px;\n  max-width: 650px;\n}\n.hero-cta {\n  display: flex;\n  gap: 16px;\n  flex-wrap: wrap;\n  justify-content: center;\n}\n\n/* Buttons */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  padding: 14px 28px;\n  border-radius: 12px;\n  font-weight: 600;\n  font-size: 1rem;\n  text-decoration: none;\n  transition: all 0.2s ease;\n  cursor: pointer;\n}\n.btn-primary {\n  background-color: var(--text-main);\n  color: var(--bg-dark);\n}\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);\n}\n.btn-secondary {\n  background-color: rgba(255, 255, 255, 0.05);\n  color: var(--text-main);\n  border: 1px solid var(--border-color);\n  backdrop-filter: var(--glass-blur);\n}\n.btn-secondary:hover {\n  background-color: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.2);\n}\n.icon {\n  width: 20px;\n  height: 20px;\n}\n\n/* 2. Trust Section */\n.trust-section {\n  padding: 40px 24px;\n  border-top: 1px solid var(--border-color);\n  border-bottom: 1px solid var(--border-color);\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);\n  margin-bottom: 100px;\n}\n.trust-title {\n  text-align: center;\n  color: var(--text-muted);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 32px;\n}\n.trust-logos {\n  display: flex;\n  justify-content: center;\n  gap: 40px;\n  flex-wrap: wrap;\n}\n.trust-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  opacity: 0.8;\n  transition: opacity 0.3s ease;\n}\n.trust-item:hover {\n  opacity: 1;\n}\n.trust-icon {\n  font-size: 1.5rem;\n}\n.trust-text {\n  display: flex;\n  flex-direction: column;\n}\n.trust-text strong {\n  font-size: 1.1rem;\n  color: var(--text-main);\n}\n.trust-text span {\n  font-size: 0.8rem;\n  color: var(--text-muted);\n}\n\n/* 3. Services Section */\n.services-section {\n  margin-bottom: 120px;\n}\n.services-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n  gap: 24px;\n}\n.service-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  border-radius: 20px;\n  padding: 40px 32px;\n  backdrop-filter: var(--glass-blur);\n  transition: transform 0.3s ease, border-color 0.3s ease;\n  display: flex;\n  flex-direction: column;\n}\n.service-card:hover {\n  transform: translateY(-5px);\n  border-color: rgba(255, 255, 255, 0.2);\n}\n.featured-service {\n  position: relative;\n  border-color: rgba(139, 92, 246, 0.3); /* Purple tint */\n}\n.featured-service::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; height: 2px;\n  background: var(--gradient-text);\n  border-top-left-radius: 20px;\n  border-top-right-radius: 20px;\n}\n.service-icon-wrapper {\n  width: 48px;\n  height: 48px;\n  border-radius: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 24px;\n}\n.service-icon-wrapper svg {\n  width: 24px;\n  height: 24px;\n}\n.web-icon { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }\n.ai-icon { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; }\n.data-icon { background: rgba(16, 185, 129, 0.1); color: #10b981; }\n\n.service-card h3 {\n  font-size: 1.5rem;\n  margin-bottom: 16px;\n  font-weight: 600;\n}\n.service-card p {\n  color: var(--text-muted);\n  line-height: 1.6;\n  margin-bottom: 24px;\n  flex-grow: 1;\n}\n.service-features {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  border-top: 1px solid var(--border-color);\n  padding-top: 24px;\n}\n.service-features li {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  color: var(--text-main);\n  font-size: 0.9rem;\n  margin-bottom: 12px;\n}\n.service-features li::before {\n  content: '→';\n  color: var(--accent);\n}\n\n/* 4. Work Section */\n.work-section {\n  margin-bottom: 120px;\n}\n.projects-showcase {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));\n  gap: 24px;\n}\n.showcase-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-color);\n  border-radius: 20px;\n  padding: 32px;\n  backdrop-filter: var(--glass-blur);\n}\n.project-tag {\n  display: inline-block;\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: var(--primary);\n  margin-bottom: 12px;\n}\n.showcase-card h3 {\n  font-size: 1.5rem;\n  margin-bottom: 12px;\n}\n.showcase-card p {\n  color: var(--text-muted);\n  line-height: 1.6;\n  margin-bottom: 24px;\n}\n.text-link {\n  color: var(--text-main);\n  text-decoration: none;\n  font-weight: 500;\n  font-size: 0.9rem;\n  transition: color 0.2s ease;\n}\n.text-link:hover {\n  color: var(--primary);\n}\n\n/* 5. Bottom CTA */\n.glass-panel {\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 24px;\n  padding: 60px 40px;\n  text-align: center;\n  backdrop-filter: blur(20px);\n  position: relative;\n  overflow: hidden;\n}\n.glass-panel::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; width: 100%; height: 100%;\n  background: radial-gradient(circle at center, rgba(139, 92, 246, 0.1) 0%, transparent 70%);\n  pointer-events: none;\n}\n.cta-box h2 {\n  font-size: clamp(2rem, 4vw, 2.5rem);\n  margin-bottom: 16px;\n}\n.cta-box p {\n  color: var(--text-muted);\n  font-size: 1.1rem;\n  margin-bottom: 32px;\n  max-width: 500px;\n  margin-left: auto;\n  margin-right: auto;\n}\n.btn-lg {\n  padding: 16px 36px;\n  font-size: 1.1rem;\n  border-radius: 16px;\n}\n.profile-mini {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 12px;\n  margin-top: 32px;\n}\n.avatar-mini {\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  object-fit: cover;\n  border: 2px solid var(--bg-dark);\n}\n.profile-mini div {\n  text-align: left;\n  display: flex;\n  flex-direction: column;\n}\n.profile-mini strong {\n  font-size: 0.95rem;\n}\n.profile-mini span {\n  font-size: 0.8rem;\n  color: var(--success);\n}\n\n/* Responsive Adjustments */\n@media (max-width: 768px) {\n  .hero-section {\n    padding: 80px 16px 60px;\n  }\n  .hero-cta {\n    flex-direction: column;\n    width: 100%;\n  }\n  .btn {\n    width: 100%;\n  }\n  .trust-logos {\n    flex-direction: column;\n    align-items: center;\n    gap: 24px;\n  }\n  .trust-item {\n    width: 100%;\n    justify-content: center;\n  }\n  .glass-panel {\n    padding: 40px 20px;\n  }\n}\n</style>"],"mappings":"AA6JA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}