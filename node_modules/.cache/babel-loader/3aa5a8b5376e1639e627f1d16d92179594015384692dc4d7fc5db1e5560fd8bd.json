{"ast":null,"code":"export default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n  data() {\n    return {\n      activeCity: null,\n      places: [{\n        id: 'michelin',\n        name: 'Michelin – DOTI/ISPARK',\n        sub: 'Lyon · 2025–2026',\n        color: '#1B4332'\n      }, {\n        id: 'ucbl',\n        name: 'Université Claude Bernard',\n        sub: 'Lyon 1 · 2020–2026',\n        color: '#059669'\n      }, {\n        id: 'alstom',\n        name: 'Alstom',\n        sub: 'Villeurbanne · 2025',\n        color: '#D97706'\n      }, {\n        id: 'paris',\n        name: 'Aneqqis',\n        sub: 'Paris · 2023',\n        color: '#1D4ED8'\n      }],\n      cityData: {\n        michelin: {\n          city: 'Lyon',\n          org: 'Michelin – DOTI/ISPARK',\n          period: '2025–2026',\n          color: '#1B4332',\n          descFr: 'AI Project Manager au sein de l\\'équipe d\\'innovation digitale. Conception et déploiement d\\'AInsights (RAG), webapp Dunning Rules augmentée par IA, consulting IA interne.',\n          descEn: 'AI Project Manager in the digital innovation team. Designed and shipped AInsights (RAG system), AI-powered Dunning Rules webapp, internal AI consulting.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'AI PM']\n        },\n        ucbl: {\n          city: 'Lyon',\n          org: 'Université Claude Bernard Lyon 1',\n          period: '2020–2026',\n          color: '#059669',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science.',\n          descEn: 'BSc Computer Science then MSc Artificial Intelligence. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision', 'Master IA']\n        },\n        alstom: {\n          city: 'Villeurbanne',\n          org: 'Alstom',\n          period: 'Jan–Mar 2025',\n          color: '#D97706',\n          descFr: 'Stage Digitalisation des Inspections. Mise en place de formulaires digitaux d\\'inspection avec KIZEO, développement d\\'outils internes et reporting.',\n          descEn: 'Inspection Digitalisation internship. Digital inspection forms with KIZEO, internal tools development and reporting.',\n          tags: ['KIZEO', 'Process', 'Reporting']\n        },\n        paris: {\n          city: 'Paris',\n          org: 'Aneqqis',\n          period: 'Mai–Juin 2023',\n          color: '#1D4ED8',\n          descFr: 'Stage développeur Django/Vue.js. Architecture SaaS de zéro, intégration Stripe, génération de PDF complexes.',\n          descEn: 'Django/Vue.js developer internship. Full SaaS architecture from scratch, Stripe integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS']\n        }\n      }\n    };\n  },\n  computed: {\n    lang() {\n      return this.getLang();\n    }\n  },\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    }\n  }\n};","map":{"version":3,"names":["name","inject","data","activeCity","places","id","sub","color","cityData","michelin","city","org","period","descFr","descEn","tags","ucbl","alstom","paris","computed","lang","getLang","methods","toggleCity"],"sources":["/home/amine/Bureau/amineitji-portfolio/src/components/FranceMap.vue"],"sourcesContent":["<template>\n  <div class=\"map-wrapper\">\n    <div class=\"map-container\">\n      <!-- SVG France -->\n      <svg\n        class=\"france-svg\"\n        viewBox=\"0 0 540 580\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        aria-label=\"Carte de France avec expériences professionnelles\"\n      >\n        <defs>\n          <!-- Glow filter -->\n          <filter id=\"glow-green\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"4\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n          <filter id=\"glow-blue\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"3\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n\n          <!-- Lyon region radial gradient -->\n          <radialGradient id=\"lyon-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1B4332\" stop-opacity=\"0.25\"/>\n            <stop offset=\"100%\" stop-color=\"#1B4332\" stop-opacity=\"0\"/>\n          </radialGradient>\n          <radialGradient id=\"paris-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1D4ED8\" stop-opacity=\"0.18\"/>\n            <stop offset=\"100%\" stop-color=\"#1D4ED8\" stop-opacity=\"0\"/>\n          </radialGradient>\n        </defs>\n\n        <!-- France outline — simplified but recognizable path -->\n        <path\n          class=\"france-path\"\n          d=\"\n            M 200 42\n            L 238 36 L 280 38 L 310 42\n            L 355 38 L 395 48 L 420 55\n            L 448 68 L 462 82 L 468 100\n            L 478 115 L 485 132 L 488 152\n            L 495 170 L 498 192 L 495 215\n            L 490 240 L 488 262 L 490 280\n            L 495 300 L 498 320 L 492 342\n            L 480 362 L 465 378 L 450 392\n            L 435 408 L 420 425 L 405 442\n            L 388 458 L 370 470 L 350 478\n            L 328 482 L 305 480 L 282 478\n            L 260 475 L 238 468 L 218 458\n            L 198 448 L 178 438 L 160 425\n            L 142 410 L 125 395 L 110 378\n            L 98 360 L 88 340 L 82 318\n            L 78 295 L 78 272 L 82 248\n            L 85 225 L 82 202 L 78 178\n            L 75 155 L 75 132 L 80 112\n            L 88 95 L 100 80 L 115 68\n            L 132 58 L 152 50 L 175 44\n            Z\n          \"\n        />\n\n        <!-- Corsica (simplified) -->\n        <path\n          class=\"france-path corsica\"\n          d=\"M 465 468 L 470 458 L 475 450 L 480 458 L 478 470 L 472 478 Z\"\n        />\n\n        <!-- Lyon region glow -->\n        <ellipse cx=\"362\" cy=\"312\" rx=\"70\" ry=\"60\" fill=\"url(#lyon-glow)\" class=\"region-glow lyon-region\"/>\n\n        <!-- Paris region glow -->\n        <ellipse cx=\"248\" cy=\"162\" rx=\"55\" ry=\"45\" fill=\"url(#paris-glow)\" class=\"region-glow paris-region\"/>\n\n        <!-- Connection lines (dashed, from Paris to Lyon area) -->\n        <line\n          class=\"connection-line\"\n          x1=\"248\" y1=\"165\"\n          x2=\"355\" y2=\"300\"\n          stroke=\"rgba(27,67,50,0.2)\"\n          stroke-width=\"1\"\n          stroke-dasharray=\"4 4\"\n        />\n        <line\n          class=\"connection-line\"\n          x1=\"355\" y1=\"300\"\n          x2=\"362\" y2=\"315\"\n          stroke=\"rgba(27,67,50,0.3)\"\n          stroke-width=\"1\"\n          stroke-dasharray=\"3 3\"\n        />\n\n        <!-- ══ CITY MARKERS ══ -->\n\n        <!-- Paris — Aneqqis -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'paris' }\"\n          @mouseenter=\"activeCity = 'paris'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('paris')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Paris – Aneqqis\">\n          <circle cx=\"248\" cy=\"162\" r=\"22\" fill=\"rgba(29,78,216,0.08)\" class=\"marker-ring\" />\n          <circle cx=\"248\" cy=\"162\" r=\"6\" fill=\"#1D4ED8\" class=\"marker-dot\" filter=\"url(#glow-blue)\"/>\n          <circle cx=\"248\" cy=\"162\" r=\"6\" fill=\"none\" stroke=\"#1D4ED8\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"248\" y=\"148\" text-anchor=\"middle\" class=\"city-label\">Paris</text>\n        </g>\n\n        <!-- Lyon — Michelin ISPARK -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'michelin' }\"\n          @mouseenter=\"activeCity = 'michelin'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('michelin')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Lyon – Michelin\">\n          <circle cx=\"355\" cy=\"305\" r=\"28\" fill=\"rgba(27,67,50,0.1)\" class=\"marker-ring\"/>\n          <circle cx=\"355\" cy=\"305\" r=\"8\" fill=\"#1B4332\" class=\"marker-dot\" filter=\"url(#glow-green)\"/>\n          <circle cx=\"355\" cy=\"305\" r=\"8\" fill=\"none\" stroke=\"#1B4332\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"355\" y=\"288\" text-anchor=\"middle\" class=\"city-label\">Lyon</text>\n        </g>\n\n        <!-- Lyon — Université Claude Bernard (slightly offset) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'ucbl' }\"\n          @mouseenter=\"activeCity = 'ucbl'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('ucbl')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Lyon – UCBL\">\n          <circle cx=\"372\" cy=\"318\" r=\"6\" fill=\"#059669\" class=\"marker-dot\"/>\n          <circle cx=\"372\" cy=\"318\" r=\"6\" fill=\"none\" stroke=\"#059669\" stroke-width=\"1\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n\n        <!-- Villeurbanne — Alstom -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'alstom' }\"\n          @mouseenter=\"activeCity = 'alstom'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('alstom')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Villeurbanne – Alstom\">\n          <circle cx=\"368\" cy=\"308\" r=\"5\" fill=\"#D97706\" class=\"marker-dot\"/>\n          <circle cx=\"368\" cy=\"308\" r=\"5\" fill=\"none\" stroke=\"#D97706\" stroke-width=\"1\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n\n        <!-- Grid overlay — subtle dot grid -->\n        <pattern id=\"dot-grid\" x=\"0\" y=\"0\" width=\"30\" height=\"30\" patternUnits=\"userSpaceOnUse\">\n          <circle cx=\"1\" cy=\"1\" r=\"0.7\" fill=\"rgba(27,67,50,0.12)\"/>\n        </pattern>\n        <rect width=\"540\" height=\"580\" fill=\"url(#dot-grid)\" pointer-events=\"none\" opacity=\"0.6\"/>\n      </svg>\n\n      <!-- Legend -->\n      <div class=\"map-legend\">\n        <div\n          v-for=\"place in places\"\n          :key=\"place.id\"\n          class=\"legend-item\"\n          :class=\"{ active: activeCity === place.id }\"\n          @mouseenter=\"activeCity = place.id\"\n          @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity(place.id)\"\n        >\n          <span class=\"legend-dot\" :style=\"{ background: place.color }\"></span>\n          <div class=\"legend-text\">\n            <span class=\"legend-name\">{{ place.name }}</span>\n            <span class=\"legend-sub\">{{ place.sub }}</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Detail card -->\n    <transition name=\"card-slide\">\n      <div v-if=\"activeCity && cityData[activeCity]\" class=\"detail-card\">\n        <div class=\"dc-header\">\n          <span class=\"dc-dot\" :style=\"{ background: cityData[activeCity].color }\"></span>\n          <div>\n            <div class=\"dc-city\">{{ cityData[activeCity].city }}</div>\n            <div class=\"dc-org\">{{ cityData[activeCity].org }}</div>\n          </div>\n          <span class=\"dc-period\">{{ cityData[activeCity].period }}</span>\n        </div>\n        <p class=\"dc-desc\">{{ lang === 'en' ? cityData[activeCity].descEn : cityData[activeCity].descFr }}</p>\n        <div class=\"dc-tags\">\n          <span class=\"chip\" v-for=\"t in cityData[activeCity].tags\" :key=\"t\">{{ t }}</span>\n        </div>\n      </div>\n    </transition>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n\n  data() {\n    return {\n      activeCity: null,\n      places: [\n        { id: 'michelin', name: 'Michelin – DOTI/ISPARK', sub: 'Lyon · 2025–2026', color: '#1B4332' },\n        { id: 'ucbl',     name: 'Université Claude Bernard', sub: 'Lyon 1 · 2020–2026', color: '#059669' },\n        { id: 'alstom',   name: 'Alstom', sub: 'Villeurbanne · 2025', color: '#D97706' },\n        { id: 'paris',    name: 'Aneqqis', sub: 'Paris · 2023', color: '#1D4ED8' },\n      ],\n      cityData: {\n        michelin: {\n          city: 'Lyon', org: 'Michelin – DOTI/ISPARK', period: '2025–2026',\n          color: '#1B4332',\n          descFr: 'AI Project Manager au sein de l\\'équipe d\\'innovation digitale. Conception et déploiement d\\'AInsights (RAG), webapp Dunning Rules augmentée par IA, consulting IA interne.',\n          descEn: 'AI Project Manager in the digital innovation team. Designed and shipped AInsights (RAG system), AI-powered Dunning Rules webapp, internal AI consulting.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'AI PM'],\n        },\n        ucbl: {\n          city: 'Lyon', org: 'Université Claude Bernard Lyon 1', period: '2020–2026',\n          color: '#059669',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science.',\n          descEn: 'BSc Computer Science then MSc Artificial Intelligence. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision', 'Master IA'],\n        },\n        alstom: {\n          city: 'Villeurbanne', org: 'Alstom', period: 'Jan–Mar 2025',\n          color: '#D97706',\n          descFr: 'Stage Digitalisation des Inspections. Mise en place de formulaires digitaux d\\'inspection avec KIZEO, développement d\\'outils internes et reporting.',\n          descEn: 'Inspection Digitalisation internship. Digital inspection forms with KIZEO, internal tools development and reporting.',\n          tags: ['KIZEO', 'Process', 'Reporting'],\n        },\n        paris: {\n          city: 'Paris', org: 'Aneqqis', period: 'Mai–Juin 2023',\n          color: '#1D4ED8',\n          descFr: 'Stage développeur Django/Vue.js. Architecture SaaS de zéro, intégration Stripe, génération de PDF complexes.',\n          descEn: 'Django/Vue.js developer internship. Full SaaS architecture from scratch, Stripe integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS'],\n        },\n      },\n    };\n  },\n\n  computed: {\n    lang() { return this.getLang(); },\n  },\n\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    },\n  },\n};\n</script>\n\n<style scoped>\n.map-wrapper {\n  display: grid;\n  grid-template-columns: 1fr 320px;\n  gap: 24px;\n  align-items: start;\n}\n\n/* ── Map container ── */\n.map-container {\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.france-svg {\n  width: 100%;\n  max-width: 480px;\n  height: auto;\n  display: block;\n  margin: 0 auto;\n}\n\n/* ── France paths ── */\n.france-path {\n  fill: rgba(27, 67, 50, 0.06);\n  stroke: rgba(27, 67, 50, 0.25);\n  stroke-width: 1.5;\n  stroke-linejoin: round;\n  transition: fill 0.3s ease;\n}\n\n.corsica {\n  fill: rgba(27, 67, 50, 0.04);\n}\n\n/* ── Region glows ── */\n.region-glow {\n  opacity: 0;\n  transition: opacity 0.4s ease;\n}\n\n.lyon-region { opacity: 1; }\n.paris-region { opacity: 0.6; }\n\n/* ── City markers ── */\n.city-label {\n  font-family: var(--mono);\n  font-size: 10px;\n  font-weight: 600;\n  fill: rgba(27, 67, 50, 0.7);\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  pointer-events: none;\n}\n\n.marker-dot {\n  transition: r 0.2s ease;\n}\n\n.city-marker:hover .marker-dot,\n.city-marker.active .marker-dot {\n  r: 9;\n}\n\n.marker-ring {\n  opacity: 0;\n  transition: opacity 0.25s ease;\n}\n.city-marker:hover .marker-ring,\n.city-marker.active .marker-ring {\n  opacity: 1;\n}\n\n.marker-pulse {\n  animation: pulse-marker 2.5s ease-in-out infinite;\n  transform-origin: center;\n  transform-box: fill-box;\n}\n.marker-pulse-slow {\n  animation-duration: 3.5s;\n  animation-delay: 0.5s;\n}\n\n@keyframes pulse-marker {\n  0%, 100% { r: 9; opacity: 0.5; }\n  50% { r: 16; opacity: 0; }\n}\n\n.connection-line {\n  animation: dash-flow 3s linear infinite;\n}\n\n@keyframes dash-flow {\n  to { stroke-dashoffset: -20; }\n}\n\n/* ── Legend ── */\n.map-legend {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  padding: 0 12px;\n}\n\n.legend-item {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 7px 12px;\n  background: rgba(255,255,255,0.7);\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  cursor: pointer;\n  transition: all 0.18s ease;\n}\n.legend-item:hover,\n.legend-item.active {\n  background: var(--surface);\n  border-color: rgba(27,67,50,0.2);\n  box-shadow: var(--shadow-sm);\n}\n\n.legend-dot {\n  width: 9px;\n  height: 9px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.legend-text {\n  display: flex;\n  flex-direction: column;\n  gap: 1px;\n}\n\n.legend-name {\n  font-size: 0.72rem;\n  font-weight: 700;\n  color: var(--ink);\n  line-height: 1.2;\n}\n\n.legend-sub {\n  font-family: var(--mono);\n  font-size: 0.6rem;\n  color: var(--muted);\n  letter-spacing: 0.04em;\n}\n\n/* ── Detail card ── */\n.detail-card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: var(--radius-lg);\n  padding: 22px;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  box-shadow: var(--shadow-md);\n  align-self: start;\n  position: sticky;\n  top: calc(var(--nav-h) + 20px);\n}\n\n.dc-header {\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n}\n\n.dc-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  flex-shrink: 0;\n  margin-top: 4px;\n}\n\n.dc-city {\n  font-size: 0.88rem;\n  font-weight: 800;\n  color: var(--ink);\n  letter-spacing: -0.01em;\n}\n\n.dc-org {\n  font-size: 0.75rem;\n  color: var(--muted);\n  font-weight: 500;\n}\n\n.dc-period {\n  margin-left: auto;\n  font-family: var(--mono);\n  font-size: 0.62rem;\n  font-weight: 600;\n  color: var(--muted);\n  letter-spacing: 0.06em;\n  white-space: nowrap;\n}\n\n.dc-desc {\n  font-size: 0.82rem;\n  color: var(--muted);\n  line-height: 1.7;\n}\n\n.dc-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 5px;\n}\n\n/* Transitions */\n.card-slide-enter-active, .card-slide-leave-active {\n  transition: opacity 0.25s ease, transform 0.25s var(--ease);\n}\n.card-slide-enter-from, .card-slide-leave-to {\n  opacity: 0;\n  transform: translateY(10px);\n}\n\n/* Responsive */\n@media (max-width: 900px) {\n  .map-wrapper {\n    grid-template-columns: 1fr;\n  }\n  .detail-card {\n    position: static;\n  }\n}\n</style>\n"],"mappings":"AAiLA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,MAAM,EAAE,CAAC,SAAS,CAAC;EAEnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE,IAAI;MAChBC,MAAM,EAAE,CACN;QAAEC,EAAE,EAAE,UAAU;QAAEL,IAAI,EAAE,wBAAwB;QAAEM,GAAG,EAAE,kBAAkB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAC7F;QAAEF,EAAE,EAAE,MAAM;QAAML,IAAI,EAAE,2BAA2B;QAAEM,GAAG,EAAE,oBAAoB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAClG;QAAEF,EAAE,EAAE,QAAQ;QAAIL,IAAI,EAAE,QAAQ;QAAEM,GAAG,EAAE,qBAAqB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAChF;QAAEF,EAAE,EAAE,OAAO;QAAKL,IAAI,EAAE,SAAS;QAAEM,GAAG,EAAE,cAAc;QAAEC,KAAK,EAAE;MAAU,CAAC,CAC3E;MACDC,QAAQ,EAAE;QACRC,QAAQ,EAAE;UACRC,IAAI,EAAE,MAAM;UAAEC,GAAG,EAAE,wBAAwB;UAAEC,MAAM,EAAE,WAAW;UAChEL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,6KAA6K;UACrLC,MAAM,EAAE,0JAA0J;UAClKC,IAAI,EAAE,CAAC,OAAO,EAAE,KAAK,EAAE,KAAK,EAAE,QAAQ,EAAE,OAAO;QACjD,CAAC;QACDC,IAAI,EAAE;UACJN,IAAI,EAAE,MAAM;UAAEC,GAAG,EAAE,kCAAkC;UAAEC,MAAM,EAAE,WAAW;UAC1EL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,kIAAkI;UAC1IC,MAAM,EAAE,6HAA6H;UACrIC,IAAI,EAAE,CAAC,IAAI,EAAE,eAAe,EAAE,KAAK,EAAE,iBAAiB,EAAE,WAAW;QACrE,CAAC;QACDE,MAAM,EAAE;UACNP,IAAI,EAAE,cAAc;UAAEC,GAAG,EAAE,QAAQ;UAAEC,MAAM,EAAE,cAAc;UAC3DL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,sJAAsJ;UAC9JC,MAAM,EAAE,sHAAsH;UAC9HC,IAAI,EAAE,CAAC,OAAO,EAAE,SAAS,EAAE,WAAW;QACxC,CAAC;QACDG,KAAK,EAAE;UACLR,IAAI,EAAE,OAAO;UAAEC,GAAG,EAAE,SAAS;UAAEC,MAAM,EAAE,eAAe;UACtDL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,8GAA8G;UACtHC,MAAM,EAAE,sHAAsH;UAC9HC,IAAI,EAAE,CAAC,QAAQ,EAAE,QAAQ,EAAE,QAAQ,EAAE,MAAM;QAC7C;MACF;IACF,CAAC;EACH,CAAC;EAEDI,QAAQ,EAAE;IACRC,IAAIA,CAAA,EAAG;MAAE,OAAO,IAAI,CAACC,OAAO,CAAC,CAAC;IAAE;EAClC,CAAC;EAEDC,OAAO,EAAE;IACPC,UAAUA,CAAClB,EAAE,EAAE;MACb,IAAI,CAACF,UAAS,GAAI,IAAI,CAACA,UAAS,KAAME,EAAC,GAAI,IAAG,GAAIA,EAAE;IACtD;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}