{"ast":null,"code":"import SiteHeader from './components/SiteHeader.vue';\nimport SiteFooter from './components/SiteFooter.vue';\nimport EmailComposerModal from './components/EmailComposerModal.vue';\nimport { CONTACT_EMAIL } from './utils/emailComposer';\nexport default {\n  name: 'App',\n  components: {\n    SiteHeader,\n    SiteFooter,\n    EmailComposerModal\n  },\n  data() {\n    return {\n      lang: localStorage.getItem('ai_lang') || 'fr',\n      contactEmail: CONTACT_EMAIL,\n      emailComposer: {\n        isOpen: false,\n        context: {}\n      },\n      previousBodyOverflow: ''\n    };\n  },\n  provide() {\n    return {\n      getLang: () => this.lang,\n      setLang: l => {\n        this.lang = l;\n        localStorage.setItem('ai_lang', l);\n        document.documentElement.lang = l;\n      },\n      openEmailComposer: (context = {}) => this.openEmailComposer(context)\n    };\n  },\n  methods: {\n    openEmailComposer(context = {}) {\n      this.previousBodyOverflow = document.body.style.overflow;\n      this.emailComposer = {\n        isOpen: true,\n        context: {\n          ...context\n        }\n      };\n      document.body.style.overflow = 'hidden';\n    },\n    closeEmailComposer() {\n      this.emailComposer = {\n        isOpen: false,\n        context: {}\n      };\n      document.body.style.overflow = this.previousBodyOverflow;\n      this.previousBodyOverflow = '';\n    }\n  },\n  mounted() {\n    document.documentElement.lang = this.lang;\n  },\n  beforeUnmount() {\n    document.body.style.overflow = '';\n  }\n};","map":{"version":3,"names":["SiteHeader","SiteFooter","EmailComposerModal","CONTACT_EMAIL","name","components","data","lang","localStorage","getItem","contactEmail","emailComposer","isOpen","context","previousBodyOverflow","provide","getLang","setLang","l","setItem","document","documentElement","openEmailComposer","methods","body","style","overflow","closeEmailComposer","mounted","beforeUnmount"],"sources":["/home/amine/Bureau/amineitji-portfolio/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <SiteHeader />\n    <main class=\"main-content\">\n      <router-view v-slot=\"{ Component, route }\">\n        <transition name=\"page\" mode=\"out-in\">\n          <component :is=\"Component\" :key=\"route.path\" />\n        </transition>\n      </router-view>\n    </main>\n    <SiteFooter />\n    <EmailComposerModal\n      :visible=\"emailComposer.isOpen\"\n      :context=\"emailComposer.context\"\n      :lang=\"lang\"\n      :contact-email=\"contactEmail\"\n      @close=\"closeEmailComposer\"\n    />\n  </div>\n</template>\n\n<script>\nimport SiteHeader from './components/SiteHeader.vue';\nimport SiteFooter from './components/SiteFooter.vue';\nimport EmailComposerModal from './components/EmailComposerModal.vue';\nimport { CONTACT_EMAIL } from './utils/emailComposer';\n\nexport default {\n  name: 'App',\n  components: { SiteHeader, SiteFooter, EmailComposerModal },\n\n  data() {\n    return {\n      lang: localStorage.getItem('ai_lang') || 'fr',\n      contactEmail: CONTACT_EMAIL,\n      emailComposer: { isOpen: false, context: {} },\n      previousBodyOverflow: '',\n    };\n  },\n\n  provide() {\n    return {\n      getLang: () => this.lang,\n      setLang: (l) => {\n        this.lang = l;\n        localStorage.setItem('ai_lang', l);\n        document.documentElement.lang = l;\n      },\n      openEmailComposer: (context = {}) => this.openEmailComposer(context),\n    };\n  },\n\n  methods: {\n    openEmailComposer(context = {}) {\n      this.previousBodyOverflow = document.body.style.overflow;\n      this.emailComposer = { isOpen: true, context: { ...context } };\n      document.body.style.overflow = 'hidden';\n    },\n    closeEmailComposer() {\n      this.emailComposer = { isOpen: false, context: {} };\n      document.body.style.overflow = this.previousBodyOverflow;\n      this.previousBodyOverflow = '';\n    },\n  },\n\n  mounted() {\n    document.documentElement.lang = this.lang;\n  },\n\n  beforeUnmount() {\n    document.body.style.overflow = '';\n  },\n};\n</script>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   DESIGN TOKENS вЂ” Blanc cassГ© + Vert foncГ©\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n:root {\n  --bg:           #F8F7F4;\n  --surface:      #FFFFFF;\n  --forest:       #1B4332;\n  --forest-md:    #2D6A4F;\n  --forest-lt:    #ECFDF5;\n  --forest-border: rgba(27, 67, 50, 0.15);\n  --ink:          #111827;\n  --muted:        #6B7280;\n  --border:       #E5E7EB;\n  --border-dark:  rgba(17, 24, 39, 0.15);\n\n  --green:        #16a34a;\n  --green-light:  #DCFCE7;\n\n  --font:         'Inter', system-ui, -apple-system, sans-serif;\n  --max-w:        1140px;\n  --px:           24px;\n  --nav-h:        68px;\n  --radius:       8px;\n\n  --shadow-sm:    0 1px 3px rgba(17, 24, 39, 0.06), 0 1px 2px rgba(17, 24, 39, 0.04);\n  --shadow-md:    0 4px 12px rgba(17, 24, 39, 0.08);\n  --shadow-lg:    0 10px 30px rgba(17, 24, 39, 0.10);\n\n  --ease:         cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   RESET & BASE\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n*, *::before, *::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  font-family: var(--font);\n  background-color: var(--bg);\n  color: var(--ink);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n  scroll-behavior: smooth;\n  overflow-x: hidden;\n}\n\nbody {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n\n#app {\n  display: flex;\n  flex-direction: column;\n  min-height: 100vh;\n}\n\n.main-content {\n  flex: 1;\n  width: 100%;\n  max-width: var(--max-w);\n  margin: 0 auto;\n  padding: 0 var(--px);\n  padding-bottom: 60px;\n}\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   SCROLLBAR\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n::-webkit-scrollbar { width: 6px; height: 6px; }\n::-webkit-scrollbar-track { background: var(--bg); }\n::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 3px; }\n::-webkit-scrollbar-thumb:hover { background: #9CA3AF; }\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   GLOBAL BUTTONS\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 10px 20px;\n  font-family: var(--font);\n  font-size: 0.875rem;\n  font-weight: 600;\n  border-radius: var(--radius);\n  text-decoration: none;\n  cursor: pointer;\n  border: 1px solid transparent;\n  transition: all 0.2s ease;\n  white-space: nowrap;\n}\n\n.btn-forest {\n  background: var(--forest);\n  color: #fff;\n  border-color: var(--forest);\n}\n.btn-forest:hover {\n  background: var(--forest-md);\n  border-color: var(--forest-md);\n  transform: translateY(-1px);\n  box-shadow: 0 4px 12px rgba(27, 67, 50, 0.25);\n  color: #fff;\n}\n\n.btn-outline {\n  background: transparent;\n  color: var(--ink);\n  border-color: var(--border);\n}\n.btn-outline:hover {\n  border-color: var(--forest);\n  color: var(--forest);\n  background: var(--forest-lt);\n}\n\n.btn-dark {\n  background: var(--ink);\n  color: #fff;\n  border-color: var(--ink);\n}\n.btn-dark:hover {\n  background: #1F2937;\n  transform: translateY(-1px);\n  box-shadow: var(--shadow-md);\n  color: #fff;\n}\n\n.btn-ghost {\n  background: transparent;\n  color: var(--muted);\n  border-color: var(--border);\n}\n.btn-ghost:hover {\n  color: var(--ink);\n  border-color: #9CA3AF;\n  background: var(--surface);\n}\n\n/* в”Ђв”Ђ Status pill в”Ђв”Ђ */\n.status-pill {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  font-size: 0.75rem;\n  font-weight: 600;\n  color: var(--green);\n  padding: 5px 12px;\n  background: var(--green-light);\n  border: 1px solid rgba(22, 163, 74, 0.2);\n  border-radius: 100px;\n  width: fit-content;\n}\n\n.status-dot {\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--green);\n  animation: pulse-green 2s infinite;\n}\n\n@keyframes pulse-green {\n  0%, 100% { transform: scale(1); opacity: 1; }\n  50% { transform: scale(1.15); opacity: 0.7; }\n}\n\n/* в”Ђв”Ђ Typography helpers в”Ђв”Ђ */\n.eyebrow {\n  font-size: 0.72rem;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: var(--forest-md);\n}\n\n.s-title {\n  font-size: clamp(1.8rem, 3.5vw, 2.6rem);\n  font-weight: 800;\n  letter-spacing: -0.03em;\n  color: var(--ink);\n  line-height: 1.15;\n}\n\n.s-sub {\n  font-size: 1rem;\n  color: var(--muted);\n  line-height: 1.75;\n  max-width: 580px;\n}\n\n.chip {\n  display: inline-flex;\n  align-items: center;\n  padding: 3px 10px;\n  border-radius: 4px;\n  font-size: 0.72rem;\n  font-weight: 600;\n  background: var(--bg);\n  border: 1px solid var(--border);\n  color: var(--muted);\n}\n\n/* в”Ђв”Ђ Focus в”Ђв”Ђ */\n:focus-visible {\n  outline: 2px solid var(--forest);\n  outline-offset: 2px;\n  border-radius: 4px;\n}\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   TRANSITIONS VUE-ROUTER\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n.page-enter-active,\n.page-leave-active {\n  transition: opacity 0.25s ease, transform 0.25s var(--ease);\n}\n.page-enter-from { opacity: 0; transform: translateY(12px); }\n.page-leave-to   { opacity: 0; transform: translateY(-8px); }\n\n/* в”Ђв”Ђ Fade-up animation в”Ђв”Ђ */\n.fu { animation: fadeUp 0.5s var(--ease) both; }\n\n@keyframes fadeUp {\n  from { opacity: 0; transform: translateY(16px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\n   RESPONSIVE\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */\n@media (max-width: 768px) {\n  :root { --px: 16px; --nav-h: 60px; }\n}\n</style>\n"],"mappings":"AAsBA,OAAOA,UAAS,MAAO,6BAA6B;AACpD,OAAOC,UAAS,MAAO,6BAA6B;AACpD,OAAOC,kBAAiB,MAAO,qCAAqC;AACpE,SAASC,aAAY,QAAS,uBAAuB;AAErD,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IAAEL,UAAU;IAAEC,UAAU;IAAEC;EAAmB,CAAC;EAE1DI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAEC,YAAY,CAACC,OAAO,CAAC,SAAS,KAAK,IAAI;MAC7CC,YAAY,EAAEP,aAAa;MAC3BQ,aAAa,EAAE;QAAEC,MAAM,EAAE,KAAK;QAAEC,OAAO,EAAE,CAAC;MAAE,CAAC;MAC7CC,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR,OAAO;MACLC,OAAO,EAAEA,CAAA,KAAM,IAAI,CAACT,IAAI;MACxBU,OAAO,EAAGC,CAAC,IAAK;QACd,IAAI,CAACX,IAAG,GAAIW,CAAC;QACbV,YAAY,CAACW,OAAO,CAAC,SAAS,EAAED,CAAC,CAAC;QAClCE,QAAQ,CAACC,eAAe,CAACd,IAAG,GAAIW,CAAC;MACnC,CAAC;MACDI,iBAAiB,EAAEA,CAACT,OAAM,GAAI,CAAC,CAAC,KAAK,IAAI,CAACS,iBAAiB,CAACT,OAAO;IACrE,CAAC;EACH,CAAC;EAEDU,OAAO,EAAE;IACPD,iBAAiBA,CAACT,OAAM,GAAI,CAAC,CAAC,EAAE;MAC9B,IAAI,CAACC,oBAAmB,GAAIM,QAAQ,CAACI,IAAI,CAACC,KAAK,CAACC,QAAQ;MACxD,IAAI,CAACf,aAAY,GAAI;QAAEC,MAAM,EAAE,IAAI;QAAEC,OAAO,EAAE;UAAE,GAAGA;QAAQ;MAAE,CAAC;MAC9DO,QAAQ,CAACI,IAAI,CAACC,KAAK,CAACC,QAAO,GAAI,QAAQ;IACzC,CAAC;IACDC,kBAAkBA,CAAA,EAAG;MACnB,IAAI,CAAChB,aAAY,GAAI;QAAEC,MAAM,EAAE,KAAK;QAAEC,OAAO,EAAE,CAAC;MAAE,CAAC;MACnDO,QAAQ,CAACI,IAAI,CAACC,KAAK,CAACC,QAAO,GAAI,IAAI,CAACZ,oBAAoB;MACxD,IAAI,CAACA,oBAAmB,GAAI,EAAE;IAChC;EACF,CAAC;EAEDc,OAAOA,CAAA,EAAG;IACRR,QAAQ,CAACC,eAAe,CAACd,IAAG,GAAI,IAAI,CAACA,IAAI;EAC3C,CAAC;EAEDsB,aAAaA,CAAA,EAAG;IACdT,QAAQ,CAACI,IAAI,CAACC,KAAK,CAACC,QAAO,GAAI,EAAE;EACnC;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}