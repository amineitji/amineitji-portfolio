{"ast":null,"code":"export default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n  data() {\n    return {\n      activeCity: null,\n      places: [{\n        id: 'michelin',\n        name: 'Michelin – DOTI/ISPARK',\n        sub: 'Lyon · 2026',\n        color: '#1B4332'\n      }, {\n        id: 'ucbl',\n        name: 'Université Claude Bernard',\n        sub: 'Lyon 1 · 2020–2026',\n        color: '#059669'\n      }, {\n        id: 'alstom',\n        name: 'Alstom',\n        sub: 'Villeurbanne · 2025',\n        color: '#D97706'\n      }, {\n        id: 'paris',\n        name: 'Aneqqis',\n        sub: 'Paris · 2023',\n        color: '#1D4ED8'\n      }],\n      cityData: {\n        michelin: {\n          city: 'Lyon',\n          org: 'Michelin – DOTI/ISPARK',\n          period: 'Fév–Juil 2026',\n          color: '#1B4332',\n          descFr: 'AI Project Manager au sein de l\\'équipe d\\'innovation digitale. Conception et déploiement d\\'AInsights (pipeline RAG), webapp Dunning Rules augmentée par IA, consulting IA interne.',\n          descEn: 'AI Project Manager in the digital innovation team. Designed and shipped AInsights (RAG pipeline), AI-powered Dunning Rules webapp, internal AI consulting.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'AI PM']\n        },\n        ucbl: {\n          city: 'Lyon',\n          org: 'Université Claude Bernard Lyon 1',\n          period: '2020–2026',\n          color: '#059669',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science appliquée.',\n          descEn: 'BSc Computer Science then Master of Science in Artificial Intelligence. Machine Learning, Deep Learning, NLP, Computer Vision, applied Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision', 'Master IA']\n        },\n        alstom: {\n          city: 'Villeurbanne',\n          org: 'Alstom',\n          period: 'Jan–Mar 2025',\n          color: '#D97706',\n          descFr: 'Stage Digitalisation des Inspections. Mise en place de formulaires digitaux avec KIZEO, développement d\\'outils internes et reporting analytique.',\n          descEn: 'Inspection Digitalisation internship. Digital inspection forms with KIZEO, internal tools development and analytical reporting.',\n          tags: ['KIZEO', 'Digitalisation', 'Reporting']\n        },\n        paris: {\n          city: 'Paris',\n          org: 'Aneqqis',\n          period: 'Mai–Juin 2023',\n          color: '#1D4ED8',\n          descFr: 'Stage développeur Django/Vue.js. Architecture SaaS de zéro, intégration paiements Stripe, génération de PDF complexes et multiples.',\n          descEn: 'Django/Vue.js developer internship. Full SaaS architecture from scratch, Stripe payment integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS']\n        }\n      }\n    };\n  },\n  computed: {\n    lang() {\n      return this.getLang();\n    }\n  },\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    }\n  }\n};","map":{"version":3,"names":["name","inject","data","activeCity","places","id","sub","color","cityData","michelin","city","org","period","descFr","descEn","tags","ucbl","alstom","paris","computed","lang","getLang","methods","toggleCity"],"sources":["/home/amine/Bureau/amineitji-portfolio/src/components/FranceMap.vue"],"sourcesContent":["<template>\n  <div class=\"map-wrapper\">\n    <div class=\"map-container\">\n      <svg\n        class=\"france-svg\"\n        viewBox=\"0 0 560 620\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        aria-label=\"Carte de France avec expériences professionnelles\"\n      >\n        <defs>\n          <filter id=\"glow-green\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"4\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n          <filter id=\"glow-blue\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"3\" result=\"blur\"/>\n            <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n          <radialGradient id=\"lyon-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1B4332\" stop-opacity=\"0.30\"/>\n            <stop offset=\"100%\" stop-color=\"#1B4332\" stop-opacity=\"0\"/>\n          </radialGradient>\n          <radialGradient id=\"paris-glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stop-color=\"#1D4ED8\" stop-opacity=\"0.20\"/>\n            <stop offset=\"100%\" stop-color=\"#1D4ED8\" stop-opacity=\"0\"/>\n          </radialGradient>\n          <pattern id=\"dot-grid\" x=\"0\" y=\"0\" width=\"28\" height=\"28\" patternUnits=\"userSpaceOnUse\">\n            <circle cx=\"1\" cy=\"1\" r=\"0.7\" fill=\"rgba(27,67,50,0.10)\"/>\n          </pattern>\n        </defs>\n\n        <!-- Dot overlay -->\n        <rect width=\"560\" height=\"620\" fill=\"url(#dot-grid)\" pointer-events=\"none\" opacity=\"0.7\"/>\n\n        <!--\n          France mainland — real Mercator projection\n          Bounds: lon [-5.2, 9.5]  lat [41.2, 51.5]\n          x = 15 + (lon + 5.2) × 36.1   y = 15 + (51.5 − lat) × 57.3\n          Key cities: Paris (288,166)  Lyon (377,345)\n        -->\n        <path class=\"france-path\" d=\"\n          M 289 40\n          C 272 37 263 37 256 38\n          L 247 53 L 238 70\n          C 228 84 215 97 204 113\n          L 193 120 L 175 128\n          L 169 126 L 142 108\n          L 126 127 L 118 144\n          C 115 153 113 161 112 167\n          L 82 166 L 56 168\n          C 42 170 30 178 28 183\n          L 18 205\n          C 27 209 36 211 44 211\n          L 75 230 L 107 247\n          C 121 271 136 292 148 310\n          L 150 330 L 151 352\n          C 148 376 141 413 134 438\n          L 126 475\n          C 152 497 176 513 203 523\n          C 237 517 270 511 296 505\n          L 315 483 L 323 466\n          C 347 468 368 468 385 469\n          L 417 462 L 445 455\n          C 449 452 452 449 453 447\n          L 458 445 L 462 443\n          C 454 427 443 406 429 385\n          C 433 362 436 346 438 330\n          C 427 323 418 317 410 309\n          C 415 292 417 281 418 269\n          C 434 253 444 235 454 220\n          L 453 199 L 466 172\n          C 455 159 446 148 440 139\n          C 430 120 420 110 410 102\n          C 392 93 377 90 360 87\n          C 340 78 323 70 310 65\n          Z\n        \"/>\n\n        <!-- Corsica (lon ~9°E, lat ~42°N) -->\n        <path class=\"france-path corsica\" d=\"\n          M 521 508\n          C 524 500 532 508 534 518\n          L 532 540\n          C 530 552 525 560 519 564\n          L 514 546\n          C 514 530 518 518 521 508\n          Z\n        \"/>\n\n        <!-- Region glows -->\n        <ellipse cx=\"380\" cy=\"348\" rx=\"68\" ry=\"58\" fill=\"url(#lyon-glow)\" class=\"region-glow lyon-region\"/>\n        <ellipse cx=\"288\" cy=\"166\" rx=\"52\" ry=\"44\" fill=\"url(#paris-glow)\" class=\"region-glow paris-region\"/>\n\n        <!-- Connection line Paris → Lyon cluster -->\n        <line\n          class=\"connection-line\"\n          x1=\"288\" y1=\"170\"\n          x2=\"375\" y2=\"340\"\n          stroke=\"rgba(27,67,50,0.20)\"\n          stroke-width=\"1.2\"\n          stroke-dasharray=\"5 4\"\n        />\n\n        <!-- ══ CITY MARKERS ══ -->\n\n        <!-- Paris — Aneqqis (lon 2.35, lat 48.87) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'paris' }\"\n          @mouseenter=\"activeCity = 'paris'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('paris')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Paris – Aneqqis\">\n          <circle cx=\"288\" cy=\"166\" r=\"24\" fill=\"rgba(29,78,216,0.08)\" class=\"marker-ring\"/>\n          <circle cx=\"288\" cy=\"166\" r=\"6\" fill=\"#1D4ED8\" class=\"marker-dot\" filter=\"url(#glow-blue)\"/>\n          <circle cx=\"288\" cy=\"166\" r=\"6\" fill=\"none\" stroke=\"#1D4ED8\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"288\" y=\"151\" text-anchor=\"middle\" class=\"city-label\">Paris</text>\n        </g>\n\n        <!-- Lyon — Michelin (lon 4.83, lat 45.75) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'michelin' }\"\n          @mouseenter=\"activeCity = 'michelin'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('michelin')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Lyon – Michelin\">\n          <circle cx=\"377\" cy=\"345\" r=\"28\" fill=\"rgba(27,67,50,0.12)\" class=\"marker-ring\"/>\n          <circle cx=\"377\" cy=\"345\" r=\"8\" fill=\"#1B4332\" class=\"marker-dot\" filter=\"url(#glow-green)\"/>\n          <circle cx=\"377\" cy=\"345\" r=\"8\" fill=\"none\" stroke=\"#1B4332\" stroke-width=\"1.5\" opacity=\"0.5\" class=\"marker-pulse\"/>\n          <text x=\"377\" y=\"328\" text-anchor=\"middle\" class=\"city-label\">Lyon</text>\n        </g>\n\n        <!-- UCBL — slightly SE of Lyon -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'ucbl' }\"\n          @mouseenter=\"activeCity = 'ucbl'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('ucbl')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Lyon – UCBL\">\n          <circle cx=\"386\" cy=\"357\" r=\"6\" fill=\"#059669\" class=\"marker-dot\"/>\n          <circle cx=\"386\" cy=\"357\" r=\"6\" fill=\"none\" stroke=\"#059669\" stroke-width=\"1.2\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n\n        <!-- Villeurbanne — Alstom (slightly NE of Lyon) -->\n        <g class=\"city-marker\" :class=\"{ active: activeCity === 'alstom' }\"\n          @mouseenter=\"activeCity = 'alstom'\" @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity('alstom')\" style=\"cursor:pointer;\" role=\"button\" aria-label=\"Villeurbanne – Alstom\">\n          <circle cx=\"385\" cy=\"337\" r=\"5\" fill=\"#D97706\" class=\"marker-dot\"/>\n          <circle cx=\"385\" cy=\"337\" r=\"5\" fill=\"none\" stroke=\"#D97706\" stroke-width=\"1\" opacity=\"0.4\" class=\"marker-pulse marker-pulse-slow\"/>\n        </g>\n      </svg>\n\n      <!-- Legend -->\n      <div class=\"map-legend\">\n        <div\n          v-for=\"place in places\"\n          :key=\"place.id\"\n          class=\"legend-item\"\n          :class=\"{ active: activeCity === place.id }\"\n          @mouseenter=\"activeCity = place.id\"\n          @mouseleave=\"activeCity = null\"\n          @click=\"toggleCity(place.id)\"\n        >\n          <span class=\"legend-dot\" :style=\"{ background: place.color }\"></span>\n          <div class=\"legend-text\">\n            <span class=\"legend-name\">{{ place.name }}</span>\n            <span class=\"legend-sub\">{{ place.sub }}</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Detail card -->\n    <transition name=\"card-slide\">\n      <div v-if=\"activeCity && cityData[activeCity]\" class=\"detail-card\">\n        <div class=\"dc-header\">\n          <span class=\"dc-dot\" :style=\"{ background: cityData[activeCity].color }\"></span>\n          <div>\n            <div class=\"dc-city\">{{ cityData[activeCity].city }}</div>\n            <div class=\"dc-org\">{{ cityData[activeCity].org }}</div>\n          </div>\n          <span class=\"dc-period\">{{ cityData[activeCity].period }}</span>\n        </div>\n        <p class=\"dc-desc\">{{ lang === 'en' ? cityData[activeCity].descEn : cityData[activeCity].descFr }}</p>\n        <div class=\"dc-tags\">\n          <span class=\"chip\" v-for=\"t in cityData[activeCity].tags\" :key=\"t\">{{ t }}</span>\n        </div>\n      </div>\n    </transition>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'FranceMap',\n  inject: ['getLang'],\n\n  data() {\n    return {\n      activeCity: null,\n      places: [\n        { id: 'michelin', name: 'Michelin – DOTI/ISPARK', sub: 'Lyon · 2026', color: '#1B4332' },\n        { id: 'ucbl',     name: 'Université Claude Bernard', sub: 'Lyon 1 · 2020–2026', color: '#059669' },\n        { id: 'alstom',   name: 'Alstom', sub: 'Villeurbanne · 2025', color: '#D97706' },\n        { id: 'paris',    name: 'Aneqqis', sub: 'Paris · 2023', color: '#1D4ED8' },\n      ],\n      cityData: {\n        michelin: {\n          city: 'Lyon', org: 'Michelin – DOTI/ISPARK', period: 'Fév–Juil 2026',\n          color: '#1B4332',\n          descFr: 'AI Project Manager au sein de l\\'équipe d\\'innovation digitale. Conception et déploiement d\\'AInsights (pipeline RAG), webapp Dunning Rules augmentée par IA, consulting IA interne.',\n          descEn: 'AI Project Manager in the digital innovation team. Designed and shipped AInsights (RAG pipeline), AI-powered Dunning Rules webapp, internal AI consulting.',\n          tags: ['GenAI', 'RAG', 'LLM', 'Python', 'AI PM'],\n        },\n        ucbl: {\n          city: 'Lyon', org: 'Université Claude Bernard Lyon 1', period: '2020–2026',\n          color: '#059669',\n          descFr: 'Licence Informatique puis Master Intelligence Artificielle. Machine Learning, Deep Learning, NLP, Computer Vision, Data Science appliquée.',\n          descEn: 'BSc Computer Science then Master of Science in Artificial Intelligence. Machine Learning, Deep Learning, NLP, Computer Vision, applied Data Science.',\n          tags: ['ML', 'Deep Learning', 'NLP', 'Computer Vision', 'Master IA'],\n        },\n        alstom: {\n          city: 'Villeurbanne', org: 'Alstom', period: 'Jan–Mar 2025',\n          color: '#D97706',\n          descFr: 'Stage Digitalisation des Inspections. Mise en place de formulaires digitaux avec KIZEO, développement d\\'outils internes et reporting analytique.',\n          descEn: 'Inspection Digitalisation internship. Digital inspection forms with KIZEO, internal tools development and analytical reporting.',\n          tags: ['KIZEO', 'Digitalisation', 'Reporting'],\n        },\n        paris: {\n          city: 'Paris', org: 'Aneqqis', period: 'Mai–Juin 2023',\n          color: '#1D4ED8',\n          descFr: 'Stage développeur Django/Vue.js. Architecture SaaS de zéro, intégration paiements Stripe, génération de PDF complexes et multiples.',\n          descEn: 'Django/Vue.js developer internship. Full SaaS architecture from scratch, Stripe payment integration, complex PDF generation.',\n          tags: ['Django', 'Vue.js', 'Stripe', 'SaaS'],\n        },\n      },\n    };\n  },\n\n  computed: {\n    lang() { return this.getLang(); },\n  },\n\n  methods: {\n    toggleCity(id) {\n      this.activeCity = this.activeCity === id ? null : id;\n    },\n  },\n};\n</script>\n\n<style scoped>\n.map-wrapper {\n  display: grid;\n  grid-template-columns: 1fr 300px;\n  gap: 24px;\n  align-items: start;\n}\n\n/* ── Map container ── */\n.map-container {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.france-svg {\n  width: 100%;\n  max-width: 500px;\n  height: auto;\n  display: block;\n  margin: 0 auto;\n}\n\n/* ── France outline ── */\n.france-path {\n  fill: rgba(27, 67, 50, 0.07);\n  stroke: rgba(27, 67, 50, 0.28);\n  stroke-width: 1.5;\n  stroke-linejoin: round;\n  stroke-linecap: round;\n}\n.corsica {\n  fill: rgba(27, 67, 50, 0.05);\n  stroke: rgba(27, 67, 50, 0.20);\n}\n\n/* ── Region glows ── */\n.region-glow { transition: opacity 0.4s ease; }\n.lyon-region  { opacity: 1; }\n.paris-region { opacity: 0.7; }\n\n/* ── City labels ── */\n.city-label {\n  font-family: var(--mono);\n  font-size: 9px;\n  font-weight: 700;\n  fill: rgba(15, 22, 18, 0.65);\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  pointer-events: none;\n}\n\n/* ── Markers ── */\n.marker-dot { transition: r 0.2s ease; }\n\n.city-marker:hover .marker-dot,\n.city-marker.active .marker-dot { r: 10; }\n\n.marker-ring { opacity: 0; transition: opacity 0.22s ease; }\n.city-marker:hover .marker-ring,\n.city-marker.active .marker-ring { opacity: 1; }\n\n.marker-pulse {\n  animation: pulse-marker 2.5s ease-in-out infinite;\n  transform-origin: center;\n  transform-box: fill-box;\n}\n.marker-pulse-slow { animation-duration: 3.5s; animation-delay: 0.6s; }\n\n@keyframes pulse-marker {\n  0%, 100% { r: 9; opacity: 0.5; }\n  50%       { r: 18; opacity: 0; }\n}\n\n/* ── Connection line ── */\n.connection-line { animation: dash-flow 3s linear infinite; }\n@keyframes dash-flow { to { stroke-dashoffset: -18; } }\n\n/* ── Legend ── */\n.map-legend {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  padding: 0 4px;\n}\n\n.legend-item {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 7px 12px;\n  background: rgba(255,255,255,0.75);\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  cursor: pointer;\n  transition: all 0.18s ease;\n}\n.legend-item:hover,\n.legend-item.active {\n  background: var(--surface);\n  border-color: rgba(27,67,50,0.22);\n  box-shadow: var(--shadow-sm);\n}\n\n.legend-dot {\n  width: 9px; height: 9px;\n  border-radius: 50%; flex-shrink: 0;\n}\n\n.legend-text { display: flex; flex-direction: column; gap: 1px; }\n\n.legend-name {\n  font-size: 0.72rem; font-weight: 700;\n  color: var(--ink); line-height: 1.2;\n}\n\n.legend-sub {\n  font-family: var(--mono);\n  font-size: 0.58rem; color: var(--muted); letter-spacing: 0.04em;\n}\n\n/* ── Detail card ── */\n.detail-card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: var(--radius-lg);\n  padding: 22px;\n  display: flex; flex-direction: column; gap: 12px;\n  box-shadow: var(--shadow-md);\n  align-self: start;\n  position: sticky;\n  top: calc(var(--nav-h) + 20px);\n}\n\n.dc-header {\n  display: flex; align-items: flex-start; gap: 10px;\n}\n.dc-dot {\n  width: 10px; height: 10px; border-radius: 50%;\n  flex-shrink: 0; margin-top: 4px;\n}\n.dc-city { font-size: 0.88rem; font-weight: 800; color: var(--ink); letter-spacing: -0.01em; }\n.dc-org  { font-size: 0.74rem; color: var(--muted); font-weight: 500; margin-top: 2px; }\n.dc-period {\n  margin-left: auto;\n  font-family: var(--mono); font-size: 0.6rem; font-weight: 600;\n  color: var(--muted); letter-spacing: 0.06em; white-space: nowrap;\n}\n.dc-desc { font-size: 0.81rem; color: var(--muted); line-height: 1.7; }\n.dc-tags { display: flex; flex-wrap: wrap; gap: 5px; }\n\n/* ── Transitions ── */\n.card-slide-enter-active, .card-slide-leave-active {\n  transition: opacity 0.25s ease, transform 0.25s var(--ease);\n}\n.card-slide-enter-from, .card-slide-leave-to { opacity: 0; transform: translateY(10px); }\n\n/* ── Responsive ── */\n@media (max-width: 900px) {\n  .map-wrapper {\n    grid-template-columns: 1fr;\n    gap: 20px;\n  }\n  .detail-card { position: static; }\n  .france-svg { max-width: 420px; }\n}\n\n@media (max-width: 540px) {\n  .france-svg { max-width: 100%; }\n  .map-legend { gap: 6px; }\n  .legend-item { padding: 6px 10px; }\n  .legend-name { font-size: 0.68rem; }\n}\n</style>\n"],"mappings":"AAuLA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,MAAM,EAAE,CAAC,SAAS,CAAC;EAEnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE,IAAI;MAChBC,MAAM,EAAE,CACN;QAAEC,EAAE,EAAE,UAAU;QAAEL,IAAI,EAAE,wBAAwB;QAAEM,GAAG,EAAE,aAAa;QAAEC,KAAK,EAAE;MAAU,CAAC,EACxF;QAAEF,EAAE,EAAE,MAAM;QAAML,IAAI,EAAE,2BAA2B;QAAEM,GAAG,EAAE,oBAAoB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAClG;QAAEF,EAAE,EAAE,QAAQ;QAAIL,IAAI,EAAE,QAAQ;QAAEM,GAAG,EAAE,qBAAqB;QAAEC,KAAK,EAAE;MAAU,CAAC,EAChF;QAAEF,EAAE,EAAE,OAAO;QAAKL,IAAI,EAAE,SAAS;QAAEM,GAAG,EAAE,cAAc;QAAEC,KAAK,EAAE;MAAU,CAAC,CAC3E;MACDC,QAAQ,EAAE;QACRC,QAAQ,EAAE;UACRC,IAAI,EAAE,MAAM;UAAEC,GAAG,EAAE,wBAAwB;UAAEC,MAAM,EAAE,eAAe;UACpEL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,sLAAsL;UAC9LC,MAAM,EAAE,4JAA4J;UACpKC,IAAI,EAAE,CAAC,OAAO,EAAE,KAAK,EAAE,KAAK,EAAE,QAAQ,EAAE,OAAO;QACjD,CAAC;QACDC,IAAI,EAAE;UACJN,IAAI,EAAE,MAAM;UAAEC,GAAG,EAAE,kCAAkC;UAAEC,MAAM,EAAE,WAAW;UAC1EL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,4IAA4I;UACpJC,MAAM,EAAE,sJAAsJ;UAC9JC,IAAI,EAAE,CAAC,IAAI,EAAE,eAAe,EAAE,KAAK,EAAE,iBAAiB,EAAE,WAAW;QACrE,CAAC;QACDE,MAAM,EAAE;UACNP,IAAI,EAAE,cAAc;UAAEC,GAAG,EAAE,QAAQ;UAAEC,MAAM,EAAE,cAAc;UAC3DL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,mJAAmJ;UAC3JC,MAAM,EAAE,iIAAiI;UACzIC,IAAI,EAAE,CAAC,OAAO,EAAE,gBAAgB,EAAE,WAAW;QAC/C,CAAC;QACDG,KAAK,EAAE;UACLR,IAAI,EAAE,OAAO;UAAEC,GAAG,EAAE,SAAS;UAAEC,MAAM,EAAE,eAAe;UACtDL,KAAK,EAAE,SAAS;UAChBM,MAAM,EAAE,qIAAqI;UAC7IC,MAAM,EAAE,8HAA8H;UACtIC,IAAI,EAAE,CAAC,QAAQ,EAAE,QAAQ,EAAE,QAAQ,EAAE,MAAM;QAC7C;MACF;IACF,CAAC;EACH,CAAC;EAEDI,QAAQ,EAAE;IACRC,IAAIA,CAAA,EAAG;MAAE,OAAO,IAAI,CAACC,OAAO,CAAC,CAAC;IAAE;EAClC,CAAC;EAEDC,OAAO,EAAE;IACPC,UAAUA,CAAClB,EAAE,EAAE;MACb,IAAI,CAACF,UAAS,GAAI,IAAI,CAACA,UAAS,KAAME,EAAC,GAAI,IAAG,GAAIA,EAAE;IACtD;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}