{"ast":null,"code":"const CONTACT_EMAIL = 'amineitji@gmail.com';\nconst MICHELIN_END = new Date('2026-08-01');\nexport default {\n  name: 'HomePage',\n  inject: ['getLang', 'openEmailComposer'],\n  data() {\n    return {\n      contactEmail: CONTACT_EMAIL\n    };\n  },\n  computed: {\n    lang() {\n      return this.getLang();\n    },\n    isMichelinActive() {\n      return new Date() < MICHELIN_END;\n    },\n    expItems() {\n      return this.t.exp.items.map(item => ({\n        ...item,\n        current: item.isMichelin ? this.isMichelinActive : !!item.current\n      }));\n    },\n    t() {\n      const isEn = this.lang === 'en';\n      return {\n        ptitle: isEn ? 'AI Engineer · Full-Stack Developer · MSc Artificial Intelligence' : 'Ingénieur IA · Développeur Full-Stack · Master Intelligence Artificielle',\n        bio: isEn ? 'AI Engineer currently AI Project Manager at Michelin (until July 2026). I build end-to-end AI systems — RAG pipelines, autonomous agents, Computer Vision — and deploy full-stack products from scratch. Co-founder of DiagERP, a B2B SaaS live in production.' : 'Ingénieur IA, actuellement AI Project Manager chez Michelin (jusqu\\'en juil. 2026). Je construis des systèmes IA complets — pipelines RAG, agents autonomes, Computer Vision — et déploie des produits full-stack de A à Z. Co-fondateur de DiagERP, un SaaS B2B en production.',\n        stats: isEn ? [{\n          value: '3+',\n          label: 'Years dev'\n        }, {\n          value: '1 SaaS',\n          label: 'In production'\n        }, {\n          value: 'M2 IA',\n          label: 'Lyon 1'\n        }, {\n          value: '< 24h',\n          label: 'Response time'\n        }] : [{\n          value: '3+',\n          label: 'Ans de dev'\n        }, {\n          value: '1 SaaS',\n          label: 'En production'\n        }, {\n          value: 'M2 IA',\n          label: 'Lyon 1'\n        }, {\n          value: '< 24h',\n          label: 'Réponse garantie'\n        }],\n        skills: {\n          label: isEn ? 'Tech Stack' : 'Stack Technique',\n          groups: [{\n            name: isEn ? 'Languages' : 'Langages',\n            items: ['Python', 'JavaScript', 'SQL', 'C/C++']\n          }, {\n            name: 'IA & GenAI',\n            items: ['LLM', 'RAG', 'Agents', 'PyTorch', 'YOLO', 'LangChain']\n          }, {\n            name: isEn ? 'Web & Backend' : 'Web & Backend',\n            items: ['Django', 'Vue.js', 'FastAPI', 'REST API']\n          }, {\n            name: 'Cloud & DevOps',\n            items: ['AWS', 'Docker', 'CI/CD', 'PostgreSQL', 'Nginx']\n          }]\n        },\n        exp: {\n          label: isEn ? 'Experience' : 'Expériences',\n          now: isEn ? 'current' : 'en cours',\n          items: [{\n            date: '2025–2026',\n            role: isEn ? 'AI Project Manager' : 'AI Project Manager',\n            company: 'Michelin – DOTI / ISPARK · Lyon',\n            desc: isEn ? 'Designed and shipped AInsights, a RAG-based strategic intelligence system. Developed an AI-powered Dunning Rules webapp. Internal AI consultant driving GenAI adoption.' : 'Conception et déploiement d\\'AInsights, système de veille RAG. Développement complet d\\'une webapp Dunning Rules augmentée par IA. Consultant IA interne pour l\\'adoption de la GenAI.',\n            isMichelin: true\n          }, {\n            date: '2023–présent',\n            role: isEn ? 'Co-Founder & CTO' : 'Co-Fondateur & CTO',\n            company: 'DiagERP – SaaS B2B (diagerp.fr) · Lyon',\n            desc: isEn ? 'Founded and shipped a SaaS platform automating ERP compliance reports for real-estate professionals. Django, Vue.js, Stripe, AWS, Docker, CI/CD. Live with real users.' : 'Création et mise en production d\\'une plateforme SaaS automatisant les rapports ERP réglementaires pour l\\'immobilier. Django, Vue.js, Stripe, AWS, Docker, CI/CD. Actif en production.',\n            current: false\n          }, {\n            date: '2024–présent',\n            role: isEn ? 'Freelance Developer' : 'Développeur Freelance',\n            company: isEn ? 'Independent · Remote' : 'Indépendant · Remote',\n            desc: isEn ? 'Custom web & AI solutions: Django/Vue.js apps, REST APIs, automated workflows, cloud deployments.' : 'Solutions web et IA sur mesure : applications Django/Vue.js, APIs REST, workflows automatisés, déploiements cloud.',\n            current: false\n          }, {\n            date: '2024',\n            role: isEn ? 'Intern – Inspection Digitalisation' : 'Stage – Digitalisation Inspections',\n            company: 'Alstom · Lyon',\n            desc: isEn ? 'Digitalisation of inspection forms with KIZEO.' : 'Implémentation de formulaires d\\'inspection avec KIZEO.'\n          }]\n        },\n        projects: {\n          label: isEn ? 'Featured Projects' : 'Projets phares',\n          more: isEn ? 'All projects' : 'Tous les projets',\n          items: [{\n            name: 'DiagERP',\n            type: isEn ? 'SaaS B2B · Co-founder & CTO' : 'SaaS B2B · Co-fondateur & CTO',\n            desc: isEn ? 'Platform for real estate diagnosticians automating regulatory ERP reports. Full-stack Django/Vue.js, Stripe, AWS. Live in production.' : 'Plateforme pour diagnostiqueurs immobiliers automatisant les rapports ERP réglementaires. Full-stack Django/Vue.js, Stripe, AWS. En production.',\n            stack: ['Django', 'Vue.js', 'PostgreSQL', 'Stripe', 'AWS'],\n            url: 'https://diagerp.fr'\n          }, {\n            name: isEn ? 'AInsights @ Michelin' : 'AInsights @ Michelin',\n            type: isEn ? 'RAG · Strategic Intelligence' : 'RAG · Veille Stratégique',\n            desc: isEn ? 'RAG-based strategic intelligence system: Tavily ingestion, vector embeddings, semantic retrieval, LLM-powered automated content generation.' : 'Système de veille stratégique basé sur RAG : ingestion Tavily, vector embeddings, recherche sémantique et génération de contenu automatisée par LLM.',\n            stack: ['RAG', 'LLM', 'Tavily', 'Embeddings', 'Python'],\n            url: null\n          }]\n        },\n        cta: {\n          badge: isEn ? 'Open to freelance missions' : 'Disponible pour missions freelance',\n          title: isEn ? 'Let\\'s build your next project.' : 'Construisons votre prochain projet.',\n          sub: isEn ? 'AI development (RAG, agents, LLM), full-stack web, data pipelines, automation — I respond within 24h with a clear proposal.' : 'Développement IA (RAG, agents, LLM), fullstack web, data, automatisation — Je réponds sous 24h avec une proposition claire et sans engagement.',\n          btn: isEn ? 'Send a message' : 'Envoyer un message',\n          services: isEn ? 'View services' : 'Voir les services',\n          note: isEn ? '✓ Free · ✓ No commitment · ✓ Response < 24h' : '✓ Gratuit · ✓ Sans engagement · ✓ Réponse < 24h'\n        }\n      };\n    }\n  },\n  methods: {\n    openHeroComposer() {\n      this.openEmailComposer({\n        source: 'Home hero',\n        intent: 'mission',\n        service: 'general'\n      });\n    },\n    openEmailLinkComposer() {\n      this.openEmailComposer({\n        source: 'Home contact',\n        intent: 'project',\n        service: 'general'\n      });\n    },\n    openFreelanceComposer() {\n      this.openEmailComposer({\n        source: 'Home CTA freelance',\n        intent: 'mission',\n        service: 'general'\n      });\n    }\n  }\n};","map":{"version":3,"names":["CONTACT_EMAIL","MICHELIN_END","Date","name","inject","data","contactEmail","computed","lang","getLang","isMichelinActive","expItems","t","exp","items","map","item","current","isMichelin","isEn","ptitle","bio","stats","value","label","skills","groups","now","date","role","company","desc","projects","more","type","stack","url","cta","badge","title","sub","btn","services","note","methods","openHeroComposer","openEmailComposer","source","intent","service","openEmailLinkComposer","openFreelanceComposer"],"sources":["/home/amine/Bureau/amineitji-portfolio/src/components/HomePage.vue"],"sourcesContent":["<template>\n  <div class=\"ph\">\n\n    <!-- ══ PROFILE CARD ══ -->\n    <div class=\"pcard fu\">\n      <div class=\"pcard-cover\"></div>\n\n      <div class=\"pcard-photo-row\">\n        <div class=\"photo-ring\">\n          <img src=\"pp.jpeg\" alt=\"Amine ITJI\" class=\"pphoto\" loading=\"eager\" />\n        </div>\n        <div class=\"pbadges\">\n          <div v-if=\"isMichelinActive\" class=\"pbadge pbadge-michelin\">\n            <span class=\"bdot bdot-orange\"></span>\n            AI PM · Michelin\n            <span class=\"pbadge-until\">→ juil. 2026</span>\n          </div>\n          <div class=\"pbadge pbadge-open\">\n            <span class=\"bdot bdot-green\"></span>\n            {{ lang === 'en' ? 'Freelance · Open' : 'Freelance · Disponible' }}\n          </div>\n        </div>\n      </div>\n\n      <div class=\"pcard-body\">\n        <div class=\"pname-row\">\n          <h1 class=\"pname\">Amine ITJI</h1>\n          <div class=\"pcard-actions\">\n            <a :href=\"`mailto:${contactEmail}?subject=Mission`\" class=\"btn btn-forest\"\n              @click.prevent=\"openHeroComposer\">\n              {{ lang === 'en' ? 'Contact' : 'Me contacter' }}\n            </a>\n            <a href=\"/CV.pdf\" download=\"CV_Amine_ITJI.pdf\" class=\"btn btn-outline\">CV ↓</a>\n          </div>\n        </div>\n\n        <p class=\"ptitle\">{{ t.ptitle }}</p>\n\n        <div class=\"pmeta\">\n          <span class=\"pmeta-item\">\n            <svg aria-hidden=\"true\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n            Lyon · Paris · Genève\n          </span>\n          <span class=\"pmeta-sep\" aria-hidden=\"true\">·</span>\n          <span class=\"pmeta-item\">\n            <svg aria-hidden=\"true\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"/><path d=\"M6 12v5c3 3 9 3 12 0v-5\"/></svg>\n            Master 2 IA · Lyon 1\n          </span>\n          <span class=\"pmeta-sep\" aria-hidden=\"true\">·</span>\n          <span class=\"pmeta-item\">\n            <svg aria-hidden=\"true\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\"/><path d=\"M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\"/></svg>\n            Freelance · 2023–présent\n          </span>\n        </div>\n\n        <p class=\"pbio\">{{ t.bio }}</p>\n\n        <div class=\"socials-row\">\n          <a href=\"https://linkedin.com/in/amine-itji\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"slink\">\n            <svg aria-hidden=\"true\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z\"/></svg>\n            LinkedIn\n          </a>\n          <a href=\"https://github.com/amineitji\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"slink\">\n            <svg aria-hidden=\"true\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z\"/></svg>\n            GitHub\n          </a>\n          <a :href=\"`mailto:${contactEmail}`\" class=\"slink\" @click.prevent=\"openEmailLinkComposer\">\n            <svg aria-hidden=\"true\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>\n            amineitji@gmail.com\n          </a>\n        </div>\n      </div>\n    </div>\n\n    <!-- ══ STATS BAR ══ -->\n    <div class=\"stats-bar fu\" style=\"animation-delay:.06s;\">\n      <div class=\"stat\" v-for=\"s in t.stats\" :key=\"s.label\">\n        <span class=\"stat-val\">{{ s.value }}</span>\n        <span class=\"stat-lbl\">{{ s.label }}</span>\n      </div>\n    </div>\n\n    <!-- ══ SKILLS ══ -->\n    <section class=\"section fu\" style=\"animation-delay:.1s;\">\n      <div class=\"sec-label\">{{ t.skills.label }}</div>\n      <div class=\"skill-groups\">\n        <div class=\"skg\" v-for=\"g in t.skills.groups\" :key=\"g.name\">\n          <span class=\"skg-name\">{{ g.name }}</span>\n          <div class=\"skg-chips\">\n            <span class=\"skchip\" v-for=\"c in g.items\" :key=\"c\">{{ c }}</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ══ EXPERIENCE ══ -->\n    <section class=\"section fu\" style=\"animation-delay:.14s;\">\n      <div class=\"sec-label\">{{ t.exp.label }}</div>\n      <div class=\"timeline\">\n        <div class=\"tl-item\" v-for=\"item in expItems\" :key=\"item.role\" :class=\"{ active: item.current }\">\n          <div class=\"tl-left\">\n            <span class=\"tl-date\">{{ item.date }}</span>\n            <div class=\"tl-bar\"></div>\n          </div>\n          <div class=\"tl-right\">\n            <div class=\"tl-head\">\n              <h3 class=\"tl-role\">{{ item.role }}</h3>\n              <span v-if=\"item.current\" class=\"tl-now-tag\">{{ t.exp.now }}</span>\n            </div>\n            <p class=\"tl-co\">{{ item.company }}</p>\n            <p class=\"tl-desc\">{{ item.desc }}</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- ══ PROJECTS PREVIEW ══ -->\n    <section class=\"section fu\" style=\"animation-delay:.18s;\">\n      <div class=\"sec-label\">{{ t.projects.label }}</div>\n      <div class=\"proj-grid\">\n        <component\n          :is=\"p.url ? 'a' : 'div'\"\n          v-for=\"p in t.projects.items\"\n          :key=\"p.name\"\n          class=\"proj-card\"\n          :href=\"p.url || undefined\"\n          :target=\"p.url ? '_blank' : undefined\"\n          rel=\"noopener noreferrer\"\n        >\n          <div class=\"proj-top\">\n            <span class=\"proj-type\">{{ p.type }}</span>\n            <span v-if=\"p.url\" class=\"proj-arrow\">↗</span>\n          </div>\n          <h3 class=\"proj-name\">{{ p.name }}</h3>\n          <p class=\"proj-desc\">{{ p.desc }}</p>\n          <div class=\"proj-stack\">\n            <span class=\"skchip\" v-for=\"c in p.stack\" :key=\"c\">{{ c }}</span>\n          </div>\n        </component>\n      </div>\n      <div class=\"section-more\">\n        <router-link to=\"/projets\" class=\"btn btn-outline\">{{ t.projects.more }} →</router-link>\n      </div>\n    </section>\n\n    <!-- ══ CTA FREELANCE ══ -->\n    <section class=\"cta-band fu\" style=\"animation-delay:.22s;\">\n      <div class=\"cta-inner\">\n        <div class=\"cta-avail\">\n          <span class=\"bdot bdot-green\" style=\"width:8px;height:8px;border-radius:50%;display:inline-block;\"></span>\n          {{ t.cta.badge }}\n        </div>\n        <h2 class=\"cta-title\">{{ t.cta.title }}</h2>\n        <p class=\"cta-sub\">{{ t.cta.sub }}</p>\n        <div class=\"cta-actions\">\n          <a :href=\"`mailto:${contactEmail}?subject=Mission freelance`\" class=\"btn btn-forest\"\n            @click.prevent=\"openFreelanceComposer\">\n            {{ t.cta.btn }}\n          </a>\n          <router-link to=\"/services\" class=\"btn btn-outline\">{{ t.cta.services }}</router-link>\n        </div>\n        <p class=\"cta-note\">{{ t.cta.note }}</p>\n      </div>\n    </section>\n\n  </div>\n</template>\n\n<script>\nconst CONTACT_EMAIL = 'amineitji@gmail.com';\nconst MICHELIN_END = new Date('2026-08-01');\n\nexport default {\n  name: 'HomePage',\n  inject: ['getLang', 'openEmailComposer'],\n\n  data() {\n    return { contactEmail: CONTACT_EMAIL };\n  },\n\n  computed: {\n    lang() { return this.getLang(); },\n    isMichelinActive() { return new Date() < MICHELIN_END; },\n    expItems() {\n      return this.t.exp.items.map(item => ({\n        ...item,\n        current: item.isMichelin ? this.isMichelinActive : !!item.current,\n      }));\n    },\n\n    t() {\n      const isEn = this.lang === 'en';\n      return {\n        ptitle: isEn\n          ? 'AI Engineer · Full-Stack Developer · MSc Artificial Intelligence'\n          : 'Ingénieur IA · Développeur Full-Stack · Master Intelligence Artificielle',\n\n        bio: isEn\n          ? 'AI Engineer currently AI Project Manager at Michelin (until July 2026). I build end-to-end AI systems — RAG pipelines, autonomous agents, Computer Vision — and deploy full-stack products from scratch. Co-founder of DiagERP, a B2B SaaS live in production.'\n          : 'Ingénieur IA, actuellement AI Project Manager chez Michelin (jusqu\\'en juil. 2026). Je construis des systèmes IA complets — pipelines RAG, agents autonomes, Computer Vision — et déploie des produits full-stack de A à Z. Co-fondateur de DiagERP, un SaaS B2B en production.',\n\n        stats: isEn\n          ? [\n              { value: '3+', label: 'Years dev' },\n              { value: '1 SaaS', label: 'In production' },\n              { value: 'M2 IA', label: 'Lyon 1' },\n              { value: '< 24h', label: 'Response time' },\n            ]\n          : [\n              { value: '3+', label: 'Ans de dev' },\n              { value: '1 SaaS', label: 'En production' },\n              { value: 'M2 IA', label: 'Lyon 1' },\n              { value: '< 24h', label: 'Réponse garantie' },\n            ],\n\n        skills: {\n          label: isEn ? 'Tech Stack' : 'Stack Technique',\n          groups: [\n            { name: isEn ? 'Languages' : 'Langages', items: ['Python', 'JavaScript', 'SQL', 'C/C++'] },\n            { name: 'IA & GenAI', items: ['LLM', 'RAG', 'Agents', 'PyTorch', 'YOLO', 'LangChain'] },\n            { name: isEn ? 'Web & Backend' : 'Web & Backend', items: ['Django', 'Vue.js', 'FastAPI', 'REST API'] },\n            { name: 'Cloud & DevOps', items: ['AWS', 'Docker', 'CI/CD', 'PostgreSQL', 'Nginx'] },\n          ],\n        },\n\n        exp: {\n          label: isEn ? 'Experience' : 'Expériences',\n          now: isEn ? 'current' : 'en cours',\n          items: [\n            {\n              date: '2025–2026',\n              role: isEn ? 'AI Project Manager' : 'AI Project Manager',\n              company: 'Michelin – DOTI / ISPARK · Lyon',\n              desc: isEn\n                ? 'Designed and shipped AInsights, a RAG-based strategic intelligence system. Developed an AI-powered Dunning Rules webapp. Internal AI consultant driving GenAI adoption.'\n                : 'Conception et déploiement d\\'AInsights, système de veille RAG. Développement complet d\\'une webapp Dunning Rules augmentée par IA. Consultant IA interne pour l\\'adoption de la GenAI.',\n              isMichelin: true,\n            },\n            {\n              date: '2023–présent',\n              role: isEn ? 'Co-Founder & CTO' : 'Co-Fondateur & CTO',\n              company: 'DiagERP – SaaS B2B (diagerp.fr) · Lyon',\n              desc: isEn\n                ? 'Founded and shipped a SaaS platform automating ERP compliance reports for real-estate professionals. Django, Vue.js, Stripe, AWS, Docker, CI/CD. Live with real users.'\n                : 'Création et mise en production d\\'une plateforme SaaS automatisant les rapports ERP réglementaires pour l\\'immobilier. Django, Vue.js, Stripe, AWS, Docker, CI/CD. Actif en production.',\n              current: false,\n            },\n            {\n              date: '2024–présent',\n              role: isEn ? 'Freelance Developer' : 'Développeur Freelance',\n              company: isEn ? 'Independent · Remote' : 'Indépendant · Remote',\n              desc: isEn\n                ? 'Custom web & AI solutions: Django/Vue.js apps, REST APIs, automated workflows, cloud deployments.'\n                : 'Solutions web et IA sur mesure : applications Django/Vue.js, APIs REST, workflows automatisés, déploiements cloud.',\n              current: false,\n            },\n            {\n              date: '2024',\n              role: isEn ? 'Intern – Inspection Digitalisation' : 'Stage – Digitalisation Inspections',\n              company: 'Alstom · Lyon',\n              desc: isEn\n                ? 'Digitalisation of inspection forms with KIZEO.'\n                : 'Implémentation de formulaires d\\'inspection avec KIZEO.',\n            },\n          ],\n        },\n\n        projects: {\n          label: isEn ? 'Featured Projects' : 'Projets phares',\n          more: isEn ? 'All projects' : 'Tous les projets',\n          items: [\n            {\n              name: 'DiagERP',\n              type: isEn ? 'SaaS B2B · Co-founder & CTO' : 'SaaS B2B · Co-fondateur & CTO',\n              desc: isEn\n                ? 'Platform for real estate diagnosticians automating regulatory ERP reports. Full-stack Django/Vue.js, Stripe, AWS. Live in production.'\n                : 'Plateforme pour diagnostiqueurs immobiliers automatisant les rapports ERP réglementaires. Full-stack Django/Vue.js, Stripe, AWS. En production.',\n              stack: ['Django', 'Vue.js', 'PostgreSQL', 'Stripe', 'AWS'],\n              url: 'https://diagerp.fr',\n            },\n            {\n              name: isEn ? 'AInsights @ Michelin' : 'AInsights @ Michelin',\n              type: isEn ? 'RAG · Strategic Intelligence' : 'RAG · Veille Stratégique',\n              desc: isEn\n                ? 'RAG-based strategic intelligence system: Tavily ingestion, vector embeddings, semantic retrieval, LLM-powered automated content generation.'\n                : 'Système de veille stratégique basé sur RAG : ingestion Tavily, vector embeddings, recherche sémantique et génération de contenu automatisée par LLM.',\n              stack: ['RAG', 'LLM', 'Tavily', 'Embeddings', 'Python'],\n              url: null,\n            },\n          ],\n        },\n\n        cta: {\n          badge: isEn ? 'Open to freelance missions' : 'Disponible pour missions freelance',\n          title: isEn ? 'Let\\'s build your next project.' : 'Construisons votre prochain projet.',\n          sub: isEn\n            ? 'AI development (RAG, agents, LLM), full-stack web, data pipelines, automation — I respond within 24h with a clear proposal.'\n            : 'Développement IA (RAG, agents, LLM), fullstack web, data, automatisation — Je réponds sous 24h avec une proposition claire et sans engagement.',\n          btn: isEn ? 'Send a message' : 'Envoyer un message',\n          services: isEn ? 'View services' : 'Voir les services',\n          note: isEn ? '✓ Free · ✓ No commitment · ✓ Response < 24h' : '✓ Gratuit · ✓ Sans engagement · ✓ Réponse < 24h',\n        },\n      };\n    },\n  },\n\n  methods: {\n    openHeroComposer() {\n      this.openEmailComposer({ source: 'Home hero', intent: 'mission', service: 'general' });\n    },\n    openEmailLinkComposer() {\n      this.openEm