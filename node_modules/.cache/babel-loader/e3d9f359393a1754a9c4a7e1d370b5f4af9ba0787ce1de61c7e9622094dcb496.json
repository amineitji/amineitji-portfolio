{"ast":null,"code":"export default {\n  name: 'HomePage'\n};","map":{"version":3,"names":["name"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/HomePage.vue"],"sourcesContent":["<template>\n  <div class=\"hybrid-container\">\n    <div class=\"bg-shape shape-1\"></div>\n    <div class=\"bg-shape shape-2\"></div>\n\n    <section class=\"hero-section\">\n      <div class=\"hero-grid\">\n        <div class=\"hero-content animated-entry left\">\n          <div class=\"badge-container\">\n            <span class=\"status-badge\">\n              <span class=\"pulsing-dot\"></span>\n              Disponible pour missions Freelance\n            </span>\n          </div>\n          \n          <h1 class=\"hero-title\">\n            Je transforme vos idées en solutions \n            <span class=\"highlight-text\">Web & IA</span> performantes.\n          </h1>\n          \n          <p class=\"hero-subtitle\">\n            Alliez la robustesse du développement Full-Stack à la puissance de l'Intelligence Artificielle. \n            En tant qu'<strong>AI Project Manager (Michelin)</strong> et développeur freelance expérimenté, je conçois les outils qui feront grandir votre entreprise.\n          </p>\n          \n          <div class=\"hero-actions\">\n            <a href=\"mailto:amineitji@gmail.com?subject=Discussion projet\" class=\"btn btn-primary\">\n              Discuter de votre projet\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"></line><polygon points=\"22 2 15 22 11 13 2 9 22 2\"></polygon></svg>\n            </a>\n            <router-link to=\"/projets\" class=\"btn btn-text\">\n              Voir mes réalisations →\n            </router-link>\n          </div>\n        </div>\n        \n        <div class=\"hero-image-container animated-entry right\">\n          <div class=\"image-wrapper neon-box\">\n            <img src=\"pp.jpeg\" alt=\"Amine ITJI - Expert IA & Développeur\" class=\"hero-photo\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class=\"trust-banner animated-entry up\" style=\"animation-delay: 0.2s;\">\n      <div class=\"trust-grid\">\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🎓</span>\n          <div>\n            <strong>Master 2 IA</strong>\n            <span>Diplômé Université Lyon 1</span>\n          </div>\n        </div>\n        <div class=\"trust-sep\"></div>\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🏭</span>\n          <div>\n            <strong>Michelin</strong>\n            <span>AI Project Manager</span>\n          </div>\n        </div>\n        <div class=\"trust-sep\"></div>\n        <div class=\"trust-item\">\n          <span class=\"trust-icon\">🚀</span>\n          <div>\n            <strong>Co-fondateur SaaS</strong>\n            <span>CTO de DiagERP.fr</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <section class=\"services-section animated-entry up\" style=\"animation-delay: 0.4s;\">\n      <div class=\"section-header\">\n        <h2 class=\"section-title\">Mes expertises à votre service</h2>\n        <p class=\"section-subtitle\">Une double compétence rare pour répondre aux défis techniques modernes.</p>\n      </div>\n      \n      <div class=\"services-grid\">\n        <div class=\"service-card\">\n          <div class=\"card-icon-box blue\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"16 18 22 12 16 6\"></polyline><polyline points=\"8 6 2 12 8 18\"></polyline></svg>\n          </div>\n          <h3>Développement Web & SaaS Sur-Mesure</h3>\n          <p class=\"service-desc\">\n            Conception d'applications web robustes, scalables et sécurisées. Je transforme vos processus métiers en plateformes numériques performantes.\n          </p>\n          <ul class=\"tech-list\">\n            <li>Vue.js 3 / Interfaces Réactives</li>\n            <li>Django (Python) / Backend Solide</li>\n            <li>Intégration Stripe & API</li>\n          </ul>\n        </div>\n        \n        <div class=\"service-card featured\">\n          <div class=\"card-icon-box purple\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg>\n          </div>\n          <h3>Intégration d'IA & Agents Intelligents</h3>\n          <p class=\"service-desc\">\n            Passez au niveau supérieur en intégrant l'IA générative. Création d'agents capables de raisonner sur vos données et d'automatiser des tâches complexes.\n          </p>\n          <ul class=\"tech-list\">\n            <li>LLMs (GPT, Claude, Llama)</li>\n            <li>Agents Autonomes & RAG</li>\n            <li>Prompt Engineering Avancé</li>\n          </ul>\n        </div>\n        \n        <div class=\"service-card\">\n          <div class=\"card-icon-box green\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"></path><polyline points=\"7 10 12 15 17 10\"></polyline><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"></line></svg>\n          </div>\n          <h3>Data Scraping & Automatisation</h3>\n          <p class=\"service-desc\">\n            Ne perdez plus de temps à collecter la donnée manuellement. Je développe des scripts d'extraction de masse et des pipelines de traitement de données.\n          </p>\n          <ul class=\"tech-list\">\n            <li>Web Scraping Massif</li>\n            <li>Nettoyage & Structuration Data</li>\n            <li>Automatisation de workflows</li>\n          </ul>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"projects-section animated-entry up\" style=\"animation-delay: 0.6s;\">\n       <div class=\"section-header\">\n        <h2 class=\"section-title\">Réalisations concrètes</h2>\n        <p class=\"section-subtitle\">Des projets en production qui génèrent de la valeur aujourd'hui.</p>\n      </div>\n\n      <div class=\"featured-project-grid\">\n        <a href=\"https://diagerp.fr\" target=\"_blank\" class=\"project-showcase\">\n          <div class=\"project-content\">\n            <div class=\"project-tags\">\n              <span class=\"p-tag saas\">SaaS en Production</span>\n              <span class=\"p-tag\">Co-fondateur</span>\n            </div>\n            <h3>DiagERP.fr</h3>\n            <p>L'ERP de référence pour les diagnostiqueurs immobiliers. Gestion complète d'activité, facturation, et génération automatique de rapports complexes.</p>\n            <span class=\"project-link-text\">Voir le site en direct →</span>\n          </div>\n          <div class=\"project-image-placeholder diagerp-bg\">\n            <div class=\"placeholder-overlay\"></div>\n          </div>\n        </a>\n\n         <a href=\"https://diagimmomarches.fr/\" target=\"_blank\" class=\"project-showcase\">\n           <div class=\"project-content\">\n            <div class=\"project-tags\">\n              <span class=\"p-tag client\">Projet Client</span>\n              <span class=\"p-tag\">Web & SEO</span>\n            </div>\n            <h3>DiagImmoMarches</h3>\n            <p>Plateforme web sur-mesure optimisée pour la conversion client et le référencement local dans le secteur immobilier.</p>\n             <span class=\"project-link-text\">Voir le site en direct →</span>\n          </div>\n           <div class=\"project-image-placeholder diagimmo-bg\">\n             <div class=\"placeholder-overlay\"></div>\n           </div>\n        </a>\n      </div>\n      \n      <div class=\"center-cta\">\n         <router-link to=\"/projets\" class=\"btn btn-text\">\n              Voir le portfolio complet →\n         </router-link>\n      </div>\n    </section>\n\n    <section class=\"cta-section animated-entry up\" style=\"animation-delay: 0.8s;\">\n      <div class=\"cta-card\">\n        <h2>Prêt à lancer votre projet ?</h2>\n        <p>Que vous ayez besoin d'une application web complexe ou d'intégrer de l'IA dans vos processus, discutons de vos objectifs.</p>\n        <div class=\"cta-contact-wrapper\">\n           <a href=\"mailto:amineitji@gmail.com\" class=\"btn btn-primary btn-large\">\n            Demander un devis gratuit\n          </a>\n          <div class=\"contact-subtext\">\n            <span class=\"contact-avatar\">\n              <img src=\"pp.jpeg\" alt=\"Amine\">\n            </span>\n            <span>Réponse directe sous 24h ouvrées.</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'HomePage'\n};\n</script>\n\n<style scoped>\n/* --- Design Tokens --- */\n:root {\n  /* Palette Bleu Nuit Professionnel */\n  --bg-main: #0a0e17;\n  --bg-secondary: #111827;\n  --bg-card: rgba(30, 41, 59, 0.7);\n  \n  --text-primary: #ffffff;\n  --text-secondary: #94a3b8;\n  --text-highlight: #38bdf8; /* Bleu clair lumineux */\n  \n  --accent-blue: #2563eb;\n  --accent-purple: #7c3aed;\n  --accent-green: #059669;\n  \n  --gradient-primary: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));\n  --gradient-glow: linear-gradient(45deg, var(--accent-blue), var(--accent-highlight), var(--accent-purple));\n\n  --border-light: rgba(255, 255, 255, 0.1);\n  \n  --radius-md: 12px;\n  --radius-lg: 24px;\n}\n\n/* --- Base Layout --- */\n.hybrid-container {\n  background-color: var(--bg-main);\n  color: var(--text-primary);\n  min-height: 100vh;\n  position: relative;\n  overflow: hidden;\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n}\n\nsection {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 80px 24px;\n  position: relative;\n  z-index: 2;\n}\n\n/* --- Background Decorations --- */\n.bg-shape {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(100px);\n  z-index: 0;\n  opacity: 0.15;\n}\n.shape-1 {\n  top: -10%;\n  left: -10%;\n  width: 600px;\n  height: 600px;\n  background: var(--accent-blue);\n}\n.shape-2 {\n  bottom: 10%;\n  right: -5%;\n  width: 500px;\n  height: 500px;\n  background: var(--accent-purple);\n}\n\n/* --- Typography & Utilities --- */\n.highlight-text {\n  color: transparent;\n  background: linear-gradient(90deg, var(--text-highlight), var(--accent-purple));\n  -webkit-background-clip: text;\n  background-clip: text;\n}\n\n.section-header {\n  text-align: center;\n  margin-bottom: 60px;\n}\n.section-title {\n  font-size: 2.5rem;\n  font-weight: 700;\n  margin-bottom: 16px;\n}\n.section-subtitle {\n  color: var(--text-secondary);\n  font-size: 1.1rem;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n/* --- Buttons --- */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 12px 24px;\n  border-radius: var(--radius-md);\n  font-weight: 600;\n  text-decoration: none;\n  transition: all 0.3s ease;\n  cursor: pointer;\n}\n.btn-primary {\n  background: var(--gradient-primary);\n  color: white;\n  border: none;\n  box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);\n}\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(37, 99, 235, 0.4);\n}\n.btn-text {\n  background: transparent;\n  color: var(--text-primary);\n  border: 1px solid var(--border-light);\n}\n.btn-text:hover {\n  border-color: var(--text-highlight);\n  color: var(--text-highlight);\n}\n.btn-large {\n    padding: 16px 32px;\n    font-size: 1.1rem;\n}\n\n/* --- 1. Hero Section --- */\n.hero-section {\n  padding-top: 120px; /* Space for header */\n  padding-bottom: 40px;\n}\n\n.hero-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 60px;\n  align-items: center;\n}\n\n.hero-content {\n  max-width: 600px;\n}\n\n/* Status Badge */\n.badge-container { margin-bottom: 24px; }\n.status-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 12px;\n  background: rgba(37, 99, 235, 0.1);\n  border: 1px solid rgba(37, 99, 235, 0.3);\n  border-radius: 20px;\n  color: var(--text-highlight);\n  font-size: 0.9rem;\n  font-weight: 500;\n}\n.pulsing-dot {\n  width: 8px; height: 8px;\n  background: var(--accent-blue);\n  border-radius: 50%;\n  box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.7);\n  animation: pulse 2s infinite;\n}\n@keyframes pulse {\n  0% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.7); }\n  70% { box-shadow: 0 0 0 10px rgba(37, 99, 235, 0); }\n  100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0); }\n}\n\n.hero-title {\n  font-size: clamp(2.5rem, 5vw, 3.5rem);\n  line-height: 1.1;\n  font-weight: 800;\n  margin-bottom: 24px;\n}\n\n.hero-subtitle {\n  font-size: 1.125rem;\n  color: var(--text-secondary);\n  line-height: 1.6;\n  margin-bottom: 40px;\n}\n.hero-subtitle strong { color: var(--text-primary); }\n\n.hero-actions {\n  display: flex;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n/* Hero Image Styling */\n.hero-image-container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n\n.image-wrapper.neon-box {\n  position: relative;\n  width: 100%;\n  max-width: 550px; /* Augmenté de 450px à 550px */\n  aspect-ratio: 1 / 1; /* Square */\n  border-radius: var(--radius-lg);\n  padding: 8px; /* Space for inner border */\n  background: var(--bg-secondary);\n  /* Subtle glowing border effect */\n  box-shadow: \n      0 0 0 1px var(--border-light),\n      0 20px 40px rgba(0,0,0,0.4);\n  overflow: hidden;\n}\n\n/* Création d'une bordure dégradée subtile */\n.image-wrapper.neon-box::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    border-radius: var(--radius-lg);\n    padding: 2px; /* épaisseur de la bordure colorée */\n    background: linear-gradient(45deg, var(--accent-blue), transparent, var(--accent-purple));\n    -webkit-mask: \n       linear-gradient(#fff 0 0) content-box, \n       linear-gradient(#fff 0 0);\n    -webkit-mask-composite: xor;\n    mask-composite: exclude;\n    opacity: 0.7;\n}\n\n.hero-photo {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 18px; /* Slightly less than wrapper container */\n  position: relative;\n  z-index: 2;\n  filter: saturate(1.1); /* Légère saturation pour faire ressortir la photo */\n}\n\n\n/* --- 2. Trust Banner --- */\n.trust-banner {\n  max-width: 1000px;\n  margin: 0 auto 80px;\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: 20px;\n  padding: 24px 40px;\n  position: relative;\n  z-index: 3;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n}\n\n.trust-grid {\n  display: flex;\n  justify-content: space-around;\n  align-items: center;\n}\n\n.trust-item {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.trust-icon {\n  font-size: 2rem;\n}\n\n.trust-item div {\n  display: flex;\n  flex-direction: column;\n}\n\n.trust-item strong {\n  font-weight: 700;\n  font-size: 1.1rem;\n}\n\n.trust-item span {\n  color: var(--text-secondary);\n  font-size: 0.9rem;\n}\n\n.trust-sep {\n  width: 1px;\n  height: 40px;\n  background: var(--border-light);\n}\n\n\n/* --- 3. Services Section --- */\n.services-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n  gap: 32px;\n}\n\n.service-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  padding: 40px 32px;\n  backdrop-filter: blur(12px);\n  transition: all 0.3s ease;\n}\n\n.service-card:hover {\n  border-color: var(--accent-blue);\n  transform: translateY(-5px);\n  background: rgba(30, 41, 59, 0.9);\n}\n\n.service-card.featured {\n    border-color: rgba(124, 58, 237, 0.5);\n    background: linear-gradient(to bottom right, rgba(124, 58, 237, 0.1), rgba(30, 41, 59, 0.7));\n}\n\n.card-icon-box {\n  width: 56px; height: 56px;\n  border-radius: 16px;\n  display: flex; align-items: center; justify-content: center;\n  margin-bottom: 24px;\n}\n.card-icon-box.blue { background: rgba(37, 99, 235, 0.2); color: var(--text-highlight); }\n.card-icon-box.purple { background: rgba(124, 58, 237, 0.2); color: var(--accent-purple); }\n.card-icon-box.green { background: rgba(5, 150, 105, 0.2); color: var(--accent-green); }\n\n.service-card h3 {\n  font-size: 1.4rem;\n  margin-bottom: 16px;\n}\n\n.service-desc {\n  color: var(--text-secondary);\n  line-height: 1.6;\n  margin-bottom: 24px;\n  min-height: 80px;\n}\n\n.tech-list {\n  list-style: none;\n  padding: 0;\n  border-top: 1px solid var(--border-light);\n  padding-top: 24px;\n}\n\n.tech-list li {\n  margin-bottom: 12px;\n  color: var(--text-secondary);\n  display: flex; align-items: center; gap: 8px;\n  font-size: 0.95rem;\n}\n.tech-list li::before {\n  content: '';\n  width: 6px; height: 6px;\n  border-radius: 50%;\n  background: var(--text-highlight);\n}\n\n\n/* --- 4. Projects Section --- */\n.featured-project-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));\n    gap: 32px;\n    margin-bottom: 40px;\n}\n\n.project-showcase {\n    display: flex;\n    background: var(--bg-card);\n    border: 1px solid var(--border-light);\n    border-radius: var(--radius-lg);\n    overflow: hidden;\n    text-decoration: none;\n    transition: all 0.3s ease;\n    height: 320px; /* Fixed height for alignment */\n}\n.project-showcase:hover {\n    border-color: var(--text-highlight);\n    transform: scale(1.02);\n}\n\n.project-content {\n    flex: 1;\n    padding: 32px;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n}\n\n.project-tags {\n    display: flex; gap: 8px; margin-bottom: 16px;\n}\n.p-tag {\n    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;\n    padding: 4px 10px; border-radius: 20px;\n    background: var(--bg-secondary); color: var(--text-secondary);\n    border: 1px solid var(--border-light);\n}\n.p-tag.saas { color: var(--accent-green); border-color: rgba(5, 150, 105, 0.3); }\n.p-tag.client { color: var(--text-highlight); border-color: rgba(56, 189, 248, 0.3); }\n\n.project-content h3 {\n    color: var(--text-primary);\n    font-size: 1.5rem; margin-bottom: 12px;\n}\n.project-content p {\n    color: var(--text-secondary);\n    line-height: 1.5; margin-bottom: 24px;\n}\n.project-link-text {\n    color: var(--text-highlight); font-weight: 600;\n}\n\n.project-image-placeholder {\n    flex: 1;\n    background-color: var(--bg-secondary);\n    position: relative;\n    /* Ideally replace these gradients with actual screenshots */\n}\n/* Placeholder gradients if no image */\n.diagerp-bg { background: linear-gradient(135deg, #1e293b, #334155); }\n.diagimmo-bg { background: linear-gradient(135deg, #0f172a, #1e293b); }\n\n.placeholder-overlay {\n    position: absolute; inset: 0;\n    background: linear-gradient(to right, var(--bg-card) 0%, transparent 100%);\n}\n\n.center-cta { text-align: center; }\n\n\n/* --- 5. CTA Section --- */\n.cta-card {\n    background: linear-gradient(to bottom right, var(--bg-secondary), var(--bg-main));\n    border: 1px solid var(--border-light);\n    border-radius: var(--radius-lg);\n    padding: 60px 40px;\n    text-align: center;\n    position: relative;\n    overflow: hidden;\n}\n/* Subtle glowing effect on CTA card */\n.cta-card::after {\n    content: '';\n    position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;\n    background: radial-gradient(circle, rgba(37, 99, 235, 0.1) 0%, transparent 60%);\n    pointer-events: none;\n}\n\n.cta-card h2 { font-size: 2.5rem; margin-bottom: 16px; }\n.cta-card p {\n    color: var(--text-secondary); font-size: 1.2rem;\n    max-width: 700px; margin: 0 auto 40px;\n}\n\n.cta-contact-wrapper {\n    display: flex; flex-direction: column; align-items: center; gap: 24px;\n}\n\n.contact-subtext {\n    display: flex; align-items: center; gap: 12px;\n    color: var(--text-secondary);\n}\n.contact-avatar img {\n    width: 40px; height: 40px; border-radius: 50%;\n    border: 2px solid var(--bg-secondary);\n}\n\n/* --- Animations --- */\n@keyframes fadeUp {\n  from { opacity: 0; transform: translateY(30px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n@keyframes fadeLeft {\n  from { opacity: 0; transform: translateX(-30px); }\n  to { opacity: 1; transform: translateX(0); }\n}\n@keyframes fadeRight {\n  from { opacity: 0; transform: translateX(30px); }\n  to { opacity: 1; transform: translateX(0); }\n}\n\n.animated-entry { opacity: 0; animation-fill-mode: forwards; animation-duration: 0.8s; animation-timing-function: ease-out;}\n.animated-entry.up { animation-name: fadeUp; }\n.animated-entry.left { animation-name: fadeLeft; }\n.animated-entry.right { animation-name: fadeRight; }\n\n\n/* --- Responsive Design --- */\n@media (max-width: 992px) {\n    .hero-grid {\n        grid-template-columns: 1fr;\n        text-align: center;\n        gap: 40px;\n    }\n    .hero-content { margin: 0 auto; }\n    .hero-actions { justify-content: center; }\n    .hero-image-container { order: -1; /* Image on top on mobile */ }\n    .image-wrapper.neon-box { max-width: 450px; /* Augmenté de 350px à 450px */ }\n    \n    .trust-grid {\n        flex-direction: column;\n        gap: 24px;\n        align-items: flex-start;\n    }\n    .trust-sep { display: none; }\n    .trust-banner { padding: 32px; }\n\n    .featured-project-grid { grid-template-columns: 1fr; }\n}\n\n@media (max-width: 768px) {\n  .hero-title { font-size: 2.5rem; }\n  .project-showcase { flex-direction: column; height: auto; }\n  .project-image-placeholder { height: 200px; flex: none; }\n  .placeholder-overlay { background: linear-gradient(to top, var(--bg-card) 0%, transparent 100%); }\n}\n</style>"],"mappings":"AAiMA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}