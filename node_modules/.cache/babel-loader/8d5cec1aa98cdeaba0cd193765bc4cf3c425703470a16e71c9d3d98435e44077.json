a {\n  font-size: 0.82rem;\n  font-weight: 500;\n  color: var(--muted);\n  text-decoration: none;\n  transition: color 0.2s;\n}\n.footer-nav a:hover { color: var(--ink); }\n\n.footer-social {\n  display: flex;\n  gap: 10px;\n}\n.social-link {\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius);\n  background: var(--bg);\n  border: 1px solid var(--border);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--muted);\n  text-decoration: none;\n  transition: all 0.2s ease;\n}\n.social-link:hover {\n  background: var(--forest-lt);\n  border-color: var(--forest-border);\n  color: var(--forest);\n  transform: translateY(-2px);\n}\n\n.footer-bottom {\n  max-width: var(--max-w);\n  margin: 0 auto;\n  padding: 20px var(--px) 0;\n  border-top: 1px solid var(--border);\n  text-align: center;\n}\n.footer-bottom p {\n  font-size: 0.73rem;\n  color: var(--muted);\n}\n\n@media (max-width: 768px) {\n  .footer-inner {\n    grid-template-columns: 1fr;\n    text-align: center;\n    gap: 28px;\n  }\n  .footer-brand { display: flex; flex-direction: column; align-items: center; }\n  .brand-sub { max-width: 100%; }\n  .footer-nav { justify-content: center; flex-wrap: wrap; }\n  .footer-social { justify-content: center; }\n}\n</style>\n"],"mappings":"AAoCA,MAAMA,aAAY,GAAI,qBAAqB;AAE3C,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,MAAM,EAAE,CAAC,SAAS,EAAE,mBAAmB,CAAC;EAExCC,IAAIA,CAAA,EAAG;IACL,OAAO;MAAEC,YAAY,EAAEJ;IAAc,CAAC;EACxC,CAAC;EAEDK,QAAQ,EAAE;IACRC,IAAIA,CAAA,EAAG;MAAE,OAAO,IAAI,CAACC,OAAO,CAAC,CAAC;IAAE,CAAC;IACjCC,WAAWA,CAAA,EAAG;MAAE,OAAO,IAAIC,IAAI,CAAC,CAAC,CAACC,WAAW,CAAC,CAAC;IAAE,CAAC;IAClDC,CAACA,CAAA,EAAG;MACF,OAAO,IAAI,CAACL,IAAG,KAAM,IAAG,GACpB;QAAEM,GAAG,EAAE,gDAAgD;QAAEC,IAAI,EAAE,MAAM;QAAEC,KAAK,EAAE,OAAO;QAAEC,QAAQ,EAAE,MAAM;QAAEC,QAAQ,EAAE,UAAU;QAAEC,MAAM,EAAE;MAAsB,IAC7J;QAAEL,GAAG,EAAE,mDAAmD;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE,UAAU;QAAEC,QAAQ,EAAE,SAAS;QAAEC,QAAQ,EAAE,UAAU;QAAEC,MAAM,EAAE;MAAuB,CAAC;IACjL;EACF,CAAC;EAEDC,OAAO,E