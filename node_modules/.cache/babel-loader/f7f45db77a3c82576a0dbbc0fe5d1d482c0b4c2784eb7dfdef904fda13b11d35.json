{"ast":null,"code":"export default {\n  name: 'SiteFooter',\n  data() {\n    return {\n      currentYear: new Date().getFullYear()\n    };\n  }\n};","map":{"version":3,"names":["name","data","currentYear","Date","getFullYear"],"sources":["/home/amine/Bureau/PRO/amineitji-portfolio/src/components/SiteFooter.vue"],"sourcesContent":["<template>\n  <footer class=\"site-footer\">\n    <div class=\"footer-container\">\n      \n      <div class=\"footer-brand\">\n        <span class=\"brand-text\">Amine<span class=\"brand-dot\">.</span></span>\n      </div>\n      \n      <div class=\"footer-copyright\">\n        <span class=\"copyright-text\">&copy; {{ currentYear }} Amine Itji.</span>\n        <span class=\"divider\">|</span>\n        <span class=\"role-text\">AI Project Manager & Freelance</span>\n      </div>\n      \n      <div class=\"footer-socials\">\n        <a href=\"https://github.com/amineitji\" target=\"_blank\" class=\"social-btn\" aria-label=\"GitHub\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"></path></svg>\n        </a>\n        \n        <a href=\"https://fr.linkedin.com/in/amine-itji-5a8696268\" target=\"_blank\" class=\"social-btn\" aria-label=\"LinkedIn\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\"></path><rect x=\"2\" y=\"9\" width=\"4\" height=\"12\"></rect><circle cx=\"4\" cy=\"4\" r=\"2\"></circle></svg>\n        </a>\n        \n        <a href=\"mailto:amineitji@gmail.com\" class=\"social-btn\" aria-label=\"Email\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"></path><polyline points=\"22,6 12,13 2,6\"></polyline></svg>\n        </a>\n      </div>\n\n    </div>\n  </footer>\n</template>\n\n<script>\nexport default {\n  name: 'SiteFooter',\n  data() {\n    return {\n      currentYear: new Date().getFullYear(),\n    };\n  },\n};\n</script>\n\n<style scoped>\n/* Variables alignées avec le thème global */\n:root {\n  --bg-dark: #030712;\n  --bg-panel: rgba(255, 255, 255, 0.02);\n  --border-color: rgba(255, 255, 255, 0.08);\n  --text-primary: #f9fafb;\n  --text-muted: #9ca3af;\n  --primary-blue: #3b82f6;\n  --transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n/* Container Principal */\n.site-footer {\n  background-color: var(--bg-dark);\n  border-top: 1px solid var(--border-color);\n  padding: 30px 0;\n  margin-top: auto;\n  width: 100%;\n  position: relative;\n  z-index: 10;\n}\n\n.footer-container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 24px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n/* 1. Logo Brand */\n.footer-brand {\n  display: flex;\n  align-items: center;\n}\n\n.brand-text {\n  font-family: 'Inter', sans-serif;\n  font-weight: 700;\n  font-size: 1.2rem;\n  color: var(--text-primary);\n  letter-spacing: -0.02em;\n}\n\n.brand-dot {\n  color: var(--primary-blue);\n  font-size: 1.5rem;\n  line-height: 0;\n  position: relative;\n  top: 1px;\n}\n\n/* 2. Copyright */\n.footer-copyright {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  color: var(--text-muted);\n  font-size: 0.9rem;\n}\n\n.divider {\n  color: var(--border-color);\n  font-size: 0.8rem;\n}\n\n.role-text {\n  font-size: 0.85rem;\n  opacity: 0.7;\n}\n\n/* 3. Socials (Glassmorphism) */\n.footer-socials {\n  display: flex;\n  gap: 12px;\n}\n\n.social-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  background: var(--bg-panel);\n  border: 1px solid var(--border-color);\n  color: var(--text-muted);\n  transition: var(--transition);\n}\n\n.social-btn:hover {\n  background: rgba(255, 255, 255, 0.08);\n  border-color: rgba(255, 255, 255, 0.2);\n  color: var(--text-primary);\n  transform: translateY(-2px);\n}\n\n/* Responsive Design */\n@media (max-width: 768px) {\n  .footer-container {\n    flex-direction: column;\n    gap: 24px;\n    text-align: center;\n  }\n  \n  .footer-copyright {\n    flex-direction: column;\n    gap: 4px;\n  }\n  \n  .divider {\n    display: none;\n  }\n}\n</style>"],"mappings":"AAiCA,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,WAAW,CAAC;IACtC,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}